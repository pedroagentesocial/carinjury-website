---
/* Hero.astro — optimizado: lazy load videos, sin lógica de audio muerta,
   solo el primer video se precarga (carga inicial ~6MB en lugar de 79MB) */
import { t, getCurrentLanguage } from '../i18n/index.ts';

const currentLang = getCurrentLanguage();

interface Slide {
  src: string;
  titleKey?: string;
  subtitleKey?: string;
  ctaKey?: string;
  ctaHref?: string;
  durationMs: number;
  showContent?: boolean;
  hasAudio?: boolean;
}

const slides: Slide[] = [
  {
    /* Video principal de presentación de la clínica (54 MB sin comprimir) */
    src: '/video/car-injury.mp4',
    durationMs: 47000,
    showContent: false,
    hasAudio: true,
  },
  {
    src: '/video/hero.mp4',
    titleKey: 'hero.slides.slide3.title',
    subtitleKey: 'hero.slides.slide3.subtitle',
    ctaKey: 'hero.slides.slide3.cta',
    ctaHref: '/schedule',
    durationMs: 8000,
    showContent: true,
  },
  {
    src: '/video/accident.mp4',
    titleKey: 'hero.slides.slide1.title',
    subtitleKey: 'hero.slides.slide1.subtitle',
    ctaKey: 'hero.slides.slide1.cta',
    ctaHref: '/services',
    durationMs: 8000,
    showContent: true,
  },
  {
    src: '/video/chiro.mp4',
    titleKey: 'hero.slides.slide2.title',
    subtitleKey: 'hero.slides.slide2.subtitle',
    ctaKey: 'hero.slides.slide2.cta',
    ctaHref: 'tel:+13852428571',
    durationMs: 8000,
    showContent: true,
  },
];
---

<section class="hero" aria-roledescription="carousel" aria-label="Hero">
  {slides.map((s, i) => (
    <article
      class={`hslide${i === 0 ? ' is-active' : ''}`}
      data-index={i}
      data-duration={s.durationMs}
      data-has-audio={s.hasAudio ? 'true' : 'false'}
      aria-hidden={i === 0 ? 'false' : 'true'}
      role="group"
      aria-label={`${i + 1} / ${slides.length}`}
    >
      <video
        class={`hslide-video${s.hasAudio ? ' has-audio' : ''}`}
        src={i === 0 ? s.src : undefined}
        data-src={s.src}
        autoplay={i === 0}
        loop
        playsinline
        muted
        preload={i === 0 ? 'auto' : 'none'}
        onerror="this.style.display='none'"
      ></video>

      <div class={`hslide-overlay${s.showContent ? '' : ' is-soft'}`} aria-hidden="true"></div>

      {s.showContent && s.titleKey && s.subtitleKey && s.ctaKey && (
        <div class="hslide-content">
          <h1 class="hslide-title" data-i18n={s.titleKey}>{t(s.titleKey, currentLang)}</h1>
          <p class="hslide-subtitle" data-i18n={s.subtitleKey}>{t(s.subtitleKey, currentLang)}</p>
          <a class="hslide-cta" href={s.ctaHref}>
            <span data-i18n={s.ctaKey}>{t(s.ctaKey, currentLang)}</span>
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path d="M5 12h14m0 0l-5-5m5 5l-5 5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      )}
    </article>
  ))}

  <!-- Botón de audio (solo visible en slides con audio) -->
  <button class="hero-audio" type="button" aria-label="Activar sonido" aria-pressed="false" data-audio-toggle hidden>
    <svg class="hero-audio-icon hero-audio-icon-mute" viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M3 9v6h4l5 5V4L7 9H3zm13.59 3L19 14.41l1.41-1.41L18 10.59 20.41 8.18 19 6.77 16.59 9.18 14.18 6.77l-1.41 1.41L15.18 10.59 12.77 13l1.41 1.41L16.59 12z"/>
    </svg>
    <svg class="hero-audio-icon hero-audio-icon-on" viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M3 9v6h4l5 5V4L7 9H3zm10.5 3a4.5 4.5 0 0 0-2.5-4.03v8.05a4.5 4.5 0 0 0 2.5-4.02zM14 3.23v2.06A6.99 6.99 0 0 1 19 12a6.99 6.99 0 0 1-5 6.71v2.06A8.99 8.99 0 0 0 21 12 8.99 8.99 0 0 0 14 3.23z"/>
    </svg>
  </button>

  <!-- Dots de navegación -->
  <div class="hero-dots" role="tablist" aria-label="Slides">
    {slides.map((_, i) => (
      <button
        class={`hero-dot${i === 0 ? ' is-active' : ''}`}
        type="button"
        role="tab"
        aria-controls={`hslide-${i}`}
        aria-selected={i === 0 ? 'true' : 'false'}
        data-index={i}
        aria-label={`Ir al slide ${i + 1}`}
      ></button>
    ))}
  </div>

  <!-- Barra de progreso -->
  <div class="hero-progress" aria-hidden="true">
    <span class="hero-progress-bar"></span>
  </div>
</section>

<style>
  /* ==========================================================================
     HERO — optimizado, mobile-first
     ========================================================================== */
  .hero {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 520px;
    max-height: 900px;
    overflow: hidden;
    isolation: isolate;
    background: var(--c-purple-900);
  }

  /* === Cada slide === */
  .hslide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.7s ease;
  }
  .hslide.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    z-index: 1;
  }

  .hslide-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 35%;
    z-index: 0;
  }

  /* Overlay para legibilidad del texto */
  .hslide-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.55) 100%),
      radial-gradient(60% 50% at 50% 55%, rgba(0,0,0,0.45), rgba(0,0,0,0) 80%);
    pointer-events: none;
  }
  /* Overlay suave para slides sin texto (deja que el video respire) */
  .hslide-overlay.is-soft {
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.25) 100%);
  }

  /* === Contenido del slide === */
  .hslide-content {
    position: absolute;
    left: 50%;
    bottom: 22%;
    transform: translateX(-50%);
    width: min(92%, 880px);
    text-align: center;
    color: #fff;
    z-index: 2;
    opacity: 0;
    transform: translate(-50%, 20px);
  }
  .hslide.is-active .hslide-content {
    opacity: 1;
    transform: translate(-50%, 0);
    transition: opacity 0.7s ease 0.2s, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.2s;
  }

  .hslide-title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(1.85rem, 6vw, 3.25rem);
    line-height: 1.1;
    margin: 0 0 0.85rem;
    text-shadow: 0 2px 12px rgba(0,0,0,0.5);
    text-wrap: balance;
    color: #fff;
  }
  .hslide-subtitle {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.45;
    margin: 0 0 1.5rem;
    text-shadow: 0 2px 8px rgba(0,0,0,0.55);
    text-wrap: pretty;
    color: rgba(255,255,255,0.96);
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .hslide-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.95rem 1.6rem;
    background: var(--c-purple);
    color: #fff;
    border-radius: 999px;
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.01em;
    box-shadow: 0 8px 24px rgba(122, 46, 135, 0.45);
    transition: background 0.25s ease, transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
  }
  .hslide-cta:hover {
    background: #8b3494;
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(122, 46, 135, 0.55);
  }
  .hslide-cta:hover svg { transform: translateX(3px); }
  .hslide-cta svg { transition: transform 0.25s ease; }

  /* === Cursor del video con audio (sugiere que se puede tocar) === */
  .hslide-video.has-audio { cursor: pointer; }

  /* === Botón de audio === */
  .hero-audio {
    position: absolute;
    right: clamp(0.85rem, 3vw, 1.5rem);
    bottom: clamp(96px, 14vh, 130px);
    z-index: 4;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .hero-audio:hover {
    background: rgba(122, 46, 135, 0.7);
    border-color: rgba(255, 255, 255, 0.55);
    transform: scale(1.08);
  }
  .hero-audio:focus-visible {
    outline: 2px solid var(--c-rose);
    outline-offset: 3px;
  }
  .hero-audio.is-visible { display: inline-flex; }
  .hero-audio-icon { width: 22px; height: 22px; }
  /* Por defecto muestra mute (audio off) */
  .hero-audio-icon-on { display: none; }
  .hero-audio.is-on .hero-audio-icon-mute { display: none; }
  .hero-audio.is-on .hero-audio-icon-on { display: block; }
  .hero-audio.is-on {
    background: rgba(122, 46, 135, 0.85);
    border-color: var(--c-rose);
  }

  /* Pulse sutil para invitar a tocar (solo cuando está muteado) */
  .hero-audio:not(.is-on)::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.45);
    animation: heroAudioPulse 2.4s ease-out infinite;
    pointer-events: none;
  }
  @keyframes heroAudioPulse {
    0%   { transform: scale(0.85); opacity: 0.8; }
    100% { transform: scale(1.4);  opacity: 0; }
  }

  /* === Dots === */
  .hero-dots {
    position: absolute;
    left: 50%;
    bottom: 56px;
    transform: translateX(-50%);
    display: flex;
    gap: 0.45rem;
    z-index: 3;
  }
  .hero-dot {
    width: 10px; height: 10px;
    border-radius: 999px;
    border: none;
    background: rgba(255, 255, 255, 0.45);
    cursor: pointer;
    padding: 0;
    transition: width 0.35s cubic-bezier(0.22, 1, 0.36, 1), background 0.25s ease;
  }
  .hero-dot:hover { background: rgba(255, 255, 255, 0.7); }
  .hero-dot.is-active {
    width: 28px;
    background: #fff;
  }

  /* === Barra de progreso === */
  .hero-progress {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 3px;
    background: rgba(255, 255, 255, 0.15);
    z-index: 3;
    pointer-events: none;
  }
  .hero-progress-bar {
    display: block;
    height: 100%;
    width: 0%;
    background: var(--c-rose);
  }

  /* === Breakpoints === */
  @media (min-width: 768px) {
    .hslide-content { bottom: 25%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hslide, .hslide-content, .hero-dot, .hslide-cta {
      transition: none !important;
    }
    .hero-progress-bar { animation: none !important; }
  }
</style>

<script>
  import { animate } from 'motion';

  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.querySelector<HTMLElement>('.hero');
    if (!hero) return;

    const slides = Array.from(hero.querySelectorAll<HTMLElement>('.hslide'));
    const dots = Array.from(hero.querySelectorAll<HTMLButtonElement>('.hero-dot'));
    const progressBar = hero.querySelector<HTMLElement>('.hero-progress-bar');
    const audioBtn = hero.querySelector<HTMLButtonElement>('[data-audio-toggle]');
    if (slides.length <= 1) return;

    let current = 0;
    let timer: number | null = null;
    let audioOn = false; // siempre arranca muteado
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const animateAny = animate as unknown as (...args: any[]) => any;

    const getDuration = (idx: number) => {
      const slide = slides[idx];
      const d = Number(slide?.dataset.duration);
      return Number.isFinite(d) && d > 0 ? d : 8000;
    };

    /* Lazy load: asignar src solo cuando el slide es el siguiente o actual */
    const ensureLoaded = (idx: number) => {
      const video = slides[idx]?.querySelector<HTMLVideoElement>('.hslide-video');
      if (!video) return;
      if (!video.src && video.dataset.src) {
        video.src = video.dataset.src;
        video.load();
      }
    };

    /* === Audio: siempre arranca muteado, usuario lo activa con botón o tap === */
    const slideHasAudio = (idx: number) => slides[idx]?.dataset.hasAudio === 'true';

    const muteAllVideos = () => {
      slides.forEach((s) => {
        const v = s.querySelector<HTMLVideoElement>('.hslide-video');
        if (v) v.muted = true;
      });
    };

    const setAudio = (on: boolean) => {
      audioOn = on && slideHasAudio(current);
      const v = slides[current]?.querySelector<HTMLVideoElement>('.hslide-video');
      if (v) v.muted = !audioOn;
      if (audioBtn) {
        audioBtn.classList.toggle('is-on', audioOn);
        audioBtn.setAttribute('aria-pressed', audioOn ? 'true' : 'false');
        audioBtn.setAttribute('aria-label', audioOn ? 'Silenciar' : 'Activar sonido');
      }
    };

    const refreshAudioBtn = () => {
      if (!audioBtn) return;
      const has = slideHasAudio(current);
      audioBtn.classList.toggle('is-visible', has);
      if (has) audioBtn.removeAttribute('hidden');
      else audioBtn.setAttribute('hidden', '');
    };

    const goTo = (idx: number) => {
      current = (idx + slides.length) % slides.length;

      /* Al cambiar de slide siempre se vuelve a mute */
      muteAllVideos();
      audioOn = false;

      slides.forEach((s, k) => {
        const isActive = k === current;
        s.classList.toggle('is-active', isActive);
        s.setAttribute('aria-hidden', isActive ? 'false' : 'true');

        const video = s.querySelector<HTMLVideoElement>('.hslide-video');
        if (!video) return;

        if (isActive) {
          ensureLoaded(k);
          window.setTimeout(() => {
            video.play().catch(() => { /* autoplay bloqueado, ignorar */ });
          }, 60);
        } else {
          video.pause();
        }
      });

      dots.forEach((d, k) => {
        const isActive = k === current;
        d.classList.toggle('is-active', isActive);
        d.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      /* Precargar el siguiente para transición fluida */
      ensureLoaded((current + 1) % slides.length);

      refreshAudioBtn();
      setAudio(false);
      restartProgress();
      restartTimer();
    };

    const next = () => goTo(current + 1);

    const restartProgress = () => {
      if (!progressBar) return;
      const d = getDuration(current);
      if (reducedMotion) {
        progressBar.style.width = '100%';
        return;
      }
      try {
        progressBar.style.width = '0%';
        animateAny(progressBar, { width: ['0%', '100%'] }, { duration: d / 1000, easing: 'linear' });
      } catch {
        progressBar.style.width = '100%';
      }
    };

    const restartTimer = () => {
      if (timer !== null) clearTimeout(timer);
      timer = window.setTimeout(next, getDuration(current));
    };

    /* Click en dots */
    dots.forEach((d) => {
      d.addEventListener('click', () => {
        const idx = Number(d.dataset.index);
        if (Number.isFinite(idx)) goTo(idx);
      });
    });

    /* Toggle audio: botón + click en el video con audio */
    audioBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      setAudio(!audioOn);
    });

    slides.forEach((s) => {
      const v = s.querySelector<HTMLVideoElement>('.hslide-video.has-audio');
      if (!v) return;
      v.addEventListener('click', () => {
        if (slideHasAudio(current)) setAudio(!audioOn);
      });
    });

    /* Si el usuario cambia el volumen manualmente al activarlo, lo dejamos al 60% */
    slides.forEach((s) => {
      const v = s.querySelector<HTMLVideoElement>('.hslide-video');
      if (!v) return;
      v.volume = 0.6;
    });

    /* Pausar autoplay cuando la pestaña está oculta */
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        if (timer !== null) { clearTimeout(timer); timer = null; }
        const v = slides[current]?.querySelector<HTMLVideoElement>('.hslide-video');
        v?.pause();
      } else {
        const v = slides[current]?.querySelector<HTMLVideoElement>('.hslide-video');
        v?.play().catch(() => {});
        restartTimer();
        restartProgress();
      }
    });

    /* Pausar cuando el hero NO es visible (scroll) */
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const v = slides[current]?.querySelector<HTMLVideoElement>('.hslide-video');
          v?.play().catch(() => {});
          if (timer === null) restartTimer();
          restartProgress();
        } else {
          if (timer !== null) { clearTimeout(timer); timer = null; }
          const v = slides[current]?.querySelector<HTMLVideoElement>('.hslide-video');
          v?.pause();
        }
      });
    }, { threshold: 0.1 });
    io.observe(hero);

    /* Init */
    ensureLoaded(0);
    ensureLoaded(1);
    refreshAudioBtn();
    restartProgress();
    restartTimer();
  });
</script>
