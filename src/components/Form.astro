---
import { t, getCurrentLanguage } from '../i18n/index.ts';

const currentLang = getCurrentLanguage();
const phone = '+1 (385) 242-8571';
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '';
---

<section id="top-rated" class="form-section py-16 px-4">
  <div class="form-container">
    <!-- Columna izquierda: Información -->
    <div class="form-info">
      <div class="info-header">
        <h2 class="main-title" data-i18n="form.title.line1">
          {t('form.title.line1', currentLang)}
        </h2>
        <h3 class="sub-title" data-i18n="form.title.line2">
          {t('form.title.line2', currentLang)}
        </h3>
        <h4 class="accent-title" data-i18n="form.title.line3">
          {t('form.title.line3', currentLang)}
        </h4>
      </div>

      <p class="description">
        <span data-i18n="form.description.main">{t('form.description.main', currentLang)}</span> 
        <span class="highlight" data-i18n="form.description.highlight">{t('form.description.highlight', currentLang)}</span>
      </p>

      <h3 class="benefits-title" data-i18n="form.why_choose_us">{t('form.why_choose_us', currentLang)}</h3>

      <ul class="why-list benefits-list">
        <li class="benefit-item">
          <span class="ck check-icon" aria-hidden="true"></span>
          <span data-i18n="form.benefits.xray">{t('form.benefits.xray', currentLang)}</span>
        </li>
        <li class="benefit-item">
          <span class="ck check-icon" aria-hidden="true"></span>
          <span data-i18n="form.benefits.same_day">{t('form.benefits.same_day', currentLang)}</span>
        </li>
        <li class="benefit-item">
          <span class="ck check-icon" aria-hidden="true"></span>
          <span data-i18n="form.benefits.experienced_team">{t('form.benefits.experienced_team', currentLang)}</span>
        </li>
        <li class="benefit-item">
          <span class="ck check-icon" aria-hidden="true"></span>
          <span data-i18n="form.benefits.lawyer_support">{t('form.benefits.lawyer_support', currentLang)}</span>
        </li>
        <li class="benefit-item">
          <span class="ck check-icon" aria-hidden="true"></span>
          <span data-i18n="form.benefits.insurance_process">{t('form.benefits.insurance_process', currentLang)}</span>
        </li>
        <li class="benefit-item">
          <span class="ck check-icon" aria-hidden="true"></span>
          <span data-i18n="form.benefits.advanced_treatments">{t('form.benefits.advanced_treatments', currentLang)}</span>
        </li>
        <li class="benefit-item">
          <span class="ck check-icon" aria-hidden="true"></span>
          <span data-i18n="form.benefits.free_transport">{t('form.benefits.free_transport', currentLang)}</span>
        </li>
        <li class="benefit-item">
          <span class="ck check-icon" aria-hidden="true"></span>
          <span data-i18n="form.benefits.multilingual">{t('form.benefits.multilingual', currentLang)}</span>
        </li>
      </ul>

      <div class="cta-button-wrapper">
        <a href="/schedule" class="btn-primary cta-button cta-arrow" aria-label="Agenda tu cita por teléfono">
          <span data-i18n="form.schedule_button">{t('form.schedule_button', currentLang)}</span>
          <svg class="ico cta-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
            <path d="M5 12h12m0 0l-4-4m4 4l-4 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Columna derecha: Formulario -->
    <div class="appt-card form-card">
      <div class="appt-head form-header">
        <h3 class="form-title" data-i18n="form.form_title">{t('form.form_title', currentLang)}</h3>
        <p class="form-subtitle" data-i18n="form.form_subtitle">{t('form.form_subtitle', currentLang)}</p>
        <div class="phone-info">
          <span data-i18n="form.call_label">{t('form.call_label', currentLang)}</span>: 
          <a href={`tel:${phone}`} class="phone-number phone-link">{phone}</a>
        </div>
      </div>

      <div class="appt-body form-body">
        <!-- Formulario -->
        <form
          id="contact-form"
          action="/api/form-webhook"
          method="POST"
          accept-charset="UTF-8"
          autocomplete="on"
          class="lg:flex lg:flex-col lg:h-full"
        >
          <!-- Honeypot anti-spam (oculto) -->
          <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

          <!-- Campos ocultos para tracking -->
          <input type="hidden" name="page" value="Formulario principal" />

          <div class="lg:flex-1 lg:flex lg:flex-col lg:justify-between">
            <div class="lg:space-y-2">
              <label class="field grid gap-1 mb-2">
                <span class="ml-1 text-base" style="color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 600;" data-i18n="form.fields.name">{t('form.fields.name', currentLang)}</span>
                <input type="text" name="name" autocomplete="name" required class="w-full px-4 py-2.5 rounded-lg bg-white text-base outline-none transition-all duration-200 min-h-[2.5rem]" style="border: 1px solid var(--border); color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 400;" />
              </label>

              <label class="field grid gap-1 mb-2">
                <span class="ml-1 text-base" style="color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 600;" data-i18n="form.fields.email">{t('form.fields.email', currentLang)}</span>
                <input type="email" name="email" autocomplete="email" class="w-full px-4 py-2.5 rounded-lg bg-white text-base outline-none transition-all duration-200 min-h-[2.5rem]" style="border: 1px solid var(--border); color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 400;" />
              </label>

              <label class="field grid gap-1 mb-2">
                <span class="ml-1 text-base" style="color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 600;" data-i18n="form.fields.phone">{t('form.fields.phone', currentLang)}</span>
                <input type="tel" name="phone" inputmode="tel" placeholder="+1 (___) ___-____" required class="w-full px-4 py-2.5 rounded-lg bg-white text-base outline-none transition-all duration-200 min-h-[2.5rem]" style="border: 1px solid var(--border); color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 400;" />
              </label>

              <label class="field grid gap-1 mb-2" id="row-discovery">
                <span class="ml-1 text-base" style="color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 600;" data-i18n="form.fields.how_found">{t('form.fields.how_found', currentLang)}</span>
                <select name="discovery_source" id="discovery" required class="w-full px-4 py-2.5 rounded-lg bg-white text-base outline-none transition-all duration-200 min-h-[2.5rem]" style="border: 1px solid var(--border); color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 400;">
                  <option value="">{t('form.fields.select_option', currentLang)}</option>
                  <option value="google_search">{currentLang === 'es' ? 'Google (búsqueda)' : 'Google (search)'}</option>
                  <option value="google_maps">Google Maps</option>
                  <option value="facebook">Facebook</option>
                  <option value="instagram">Instagram</option>
                  <option value="tiktok">TikTok</option>
                  <option value="x_twitter">X (Twitter)</option>
                  <option value="youtube">YouTube</option>
                  <option value="ads">{currentLang === 'es' ? 'Anuncio (Google / Facebook / Instagram)' : 'Ad (Google / Facebook / Instagram)'}</option>
                  <option value="ref_amigo">{currentLang === 'es' ? 'Referido: amigo o familiar' : 'Referral: friend or family'}</option>
                  <option value="ref_abogado">{currentLang === 'es' ? 'Referido: abogado' : 'Referral: lawyer'}</option>
                  <option value="ref_medico">{currentLang === 'es' ? 'Referido: médico / clínica' : 'Referral: doctor / clinic'}</option>
                  <option value="letrero">{currentLang === 'es' ? 'Vine por el letrero / pasé por la clínica' : 'Saw the sign / passed by the clinic'}</option>
                  <option value="evento">{currentLang === 'es' ? 'Evento / comunidad' : 'Event / community'}</option>
                  <option value="radio_tv">{currentLang === 'es' ? 'Radio / TV' : 'Radio / TV'}</option>
                  <option value="otro">{currentLang === 'es' ? 'Otro' : 'Other'}</option>
                </select>
              </label>

              <label class="field grid gap-1 mb-2 is-hidden" id="row-referral" hidden>
                <span class="ml-1 text-base" style="color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 600;" data-i18n="form.fields.who_referred">{t('form.fields.who_referred', currentLang)}</span>
                <input type="text" name="referral_name" id="referral_name" placeholder={t('form.fields.referral_placeholder', currentLang)} class="w-full px-4 py-2.5 rounded-lg bg-white text-base outline-none transition-all duration-200 min-h-[2.5rem]" style="border: 1px solid var(--border); color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 400;"/>
              </label>

              <label class="field grid gap-1 mb-2">
                <span class="ml-1 text-base" style="color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 600;" data-i18n="form.fields.message">{t('form.fields.message', currentLang)}</span>
                <textarea name="message" rows="2" data-i18n="form.fields.message_placeholder" placeholder={t('form.fields.message_placeholder', currentLang)} class="w-full px-4 py-2 rounded-lg bg-white text-sm outline-none resize-none min-h-[3.75rem] transition-all duration-200" style="border: 1px solid var(--border); color: var(--text-primary); font-family: 'Poppins', sans-serif; font-weight: 400;"></textarea>
              </label>

              <div class="form-group form-group-full sms-consent-group">
                <label class="sms-consent-label">
                  <input id="sms-consent" name="sms_consent" type="checkbox" required class="sms-consent-checkbox" />
                  <span id="sms-consent-text" class="sms-consent-text" data-i18n="form.sms_consent">
                    {t('form.sms_consent', currentLang)}
                  </span>
                </label>
              </div>

              <div class="form-group form-group-full recaptcha-group" data-captcha aria-hidden="true">
                <p class="captcha-hint">
                  <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                    <path d="M9 12l2 2 4-4M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span data-i18n="form.captcha_hint">{currentLang === 'es' ? 'Último paso: confirma que no eres un robot' : 'Last step: confirm you are not a robot'}</span>
                </p>
                <div
                  id="recaptcha-widget"
                  class="g-recaptcha"
                  data-sitekey={recaptchaSiteKey}
                  data-theme="light"
                ></div>
                <p id="recaptcha-error" class="recaptcha-error" aria-live="polite"></p>
              </div>
            </div>

            <!-- Botón de envío con icono -->
            <button type="submit" id="form-submit-btn" class="w-full py-3 px-5 rounded-lg text-white text-base transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg active:translate-y-0 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100 flex items-center justify-center gap-3 lg:mt-auto min-h-[3rem]" style="background: var(--c3); font-family: 'Poppins', sans-serif; font-weight: 600; box-shadow: 0 4px 12px rgba(122, 46, 135, 0.25); opacity: 1 !important; visibility: visible !important; display: flex !important; margin-top: 1rem;">
              <span id="form-submit-text">{currentLang === 'es' ? 'Enviar' : 'Send'}</span>
              <span id="loading-text" class="hidden" data-i18n="form.sending">{t('form.sending', currentLang)}</span>
              <svg class="send-icon transition-all duration-300 ease-out" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                <path d="m3 3 3 9-3 9 19-9Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="m6 12 13 0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <!-- Mensaje de confirmación profesional -->
            <div id="success-message" class="hidden w-full py-4 px-6 rounded-lg text-center transition-all duration-500 ease-in-out transform" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; font-family: 'Poppins', sans-serif; font-weight: 600; box-shadow: 0 4px 20px rgba(16, 185, 129, 0.3); margin-top: 2rem;">
              <div class="flex items-center justify-center gap-3">
                <svg class="success-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M9 12l2 2 4-4"/>
                  <circle cx="12" cy="12" r="10"/>
                </svg>
                <span id="success-text" data-i18n="form.success_message">
                  {t('form.success_message', currentLang)}
                </span>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- Modal de agradecimiento -->
<div id="thank-you-modal" class="modal-overlay hidden">
  <div class="modal-content">
    <button class="modal-close" aria-label="Cerrar modal">&times;</button>
    <div class="modal-body">
      <div class="modal-icon">
        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 12l2 2 4-4"/>
          <circle cx="12" cy="12" r="10"/>
        </svg>
      </div>
      <h3 class="modal-title" data-i18n="form.thank_you.title">
        ¡Gracias por contactarnos!
      </h3>
      <p class="modal-message" data-i18n="form.thank_you.message">
        Hemos recibido tu mensaje y nos pondremos en contacto contigo muy pronto.
      </p>
      <button class="modal-button" data-i18n="form.thank_you.close">
        Cerrar
      </button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ WEBHOOK_URL: import.meta.env.PUBLIC_WEBHOOK_URL }}>
  /* === Form: init diferido hasta que la sección esté cerca del viewport === */
  (function(){
    const formSection = document.getElementById('top-rated');
    if (!formSection) return;

    /* Fallback de texto del botón: barato y se queda fuera del init diferido */
    const btnText = document.getElementById('form-submit-text');
    function fixBtn() {
      const lang = (typeof window !== 'undefined' && localStorage.getItem('language')) || 'es';
      if (!btnText) return;
      const val = btnText.textContent || '';
      if (val.includes('.') || val.startsWith('form')) {
        btnText.textContent = lang === 'en' ? 'Send' : 'Enviar';
      }
    }
    document.addEventListener('DOMContentLoaded', fixBtn);
    if (typeof window !== 'undefined') {
      window.addEventListener('languageChange', fixBtn);
      const mo = new MutationObserver(() => fixBtn());
      if (btnText) mo.observe(btnText, { childList: true, subtree: true });
    }

    let initialized = false;
    function initForm() {
      if (initialized) return;
      initialized = true;

      /* Carga diferida de reCAPTCHA — antes era un <script> de página */
      const recaptcha = document.createElement('script');
      recaptcha.src = 'https://www.google.com/recaptcha/api.js';
      recaptcha.async = true;
      recaptcha.defer = true;
      document.head.appendChild(recaptcha);

    const discovery     = document.getElementById('discovery');
    const rowReferral   = document.getElementById('row-referral');
    const referralInput = document.getElementById('referral_name');
    if(!discovery || !rowReferral || !referralInput) return;

    function show(el, on){ el.hidden = !on; el.classList.toggle('is-hidden', !on); }
    function sync(){
      const v = discovery.value;
      const isReferral = ['ref_amigo','ref_abogado','ref_medico'].includes(v);
      show(rowReferral, isReferral);
      referralInput.required = isReferral;
      if(!isReferral) referralInput.value = '';
    }
    discovery.addEventListener('change', sync);
    sync();

    // Modal functionality
    const modal = document.getElementById('thank-you-modal');
    const modalCloseBtn = modal?.querySelector('.modal-close');
    const modalButton = modal?.querySelector('.modal-button');
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('form-submit-btn');
    const smsConsentBlock = document.querySelector('.sms-consent-group');
    const smsConsent = document.getElementById('sms-consent');
    const recaptchaError = document.getElementById('recaptcha-error');

    function showModal() {
      if (modal) {
        modal.classList.remove('hidden');
        setTimeout(() => modal.classList.add('show'), 10);
        document.body.style.overflow = 'hidden';
      }
    }

    function hideModal() {
      if (modal) {
        modal.classList.remove('show');
        setTimeout(() => {
          modal.classList.add('hidden');
          document.body.style.overflow = '';
        }, 300);
      }
    }

    // Close modal events
    modalCloseBtn?.addEventListener('click', hideModal);
    modalButton?.addEventListener('click', hideModal);
    modal?.addEventListener('click', function(e) {
      if (e.target === modal) hideModal();
    });

    // Escape key to close modal
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
        hideModal();
      }
    });

    // Sistema Híbrido: FormSubmit + Make.com con mensaje de éxito
    if (form && submitBtn) {
      const successMessage = document.getElementById('success-message');
      const successText = document.getElementById('success-text');

      const getLang = () => ((typeof window !== 'undefined' && localStorage.getItem('language')) || 'es');

      smsConsent?.addEventListener('change', () => {
        if (smsConsent.checked) {
          smsConsentBlock?.classList.remove('error');
        } else {
          smsConsentBlock?.classList.add('error');
        }
      });

      form.addEventListener('submit', async function(e) {
        e.preventDefault();

        // Limpiar estado visual previo
        smsConsentBlock?.classList.remove('error');
        if (recaptchaError) recaptchaError.textContent = '';

        if (smsConsent && !smsConsent.checked) {
          smsConsentBlock?.classList.add('error');
          return;
        }

        const grecaptchaApi = window.grecaptcha;
        if (typeof grecaptchaApi !== 'undefined') {
          const captchaResponse = grecaptchaApi.getResponse();
          if (!captchaResponse) {
            if (recaptchaError) {
              recaptchaError.textContent = getLang() === 'en'
                ? 'Please confirm you are not a robot.'
                : 'Por favor confirma que no eres un robot.';
            }
            return;
          }
        } else {
          if (recaptchaError) {
            recaptchaError.textContent = getLang() === 'en'
              ? 'Set PUBLIC_RECAPTCHA_SITE_KEY to enable reCAPTCHA.'
              : 'Configura PUBLIC_RECAPTCHA_SITE_KEY para habilitar reCAPTCHA.';
          }
          return;
        }
        
        // Verificar honeypot anti-spam
        const honeypot = form.querySelector('input[name="_honey"]');
        if (honeypot && honeypot.value) {
          return;
        }
        
        // 1. OCULTAR BOTÓN Y MOSTRAR MENSAJE DE ÉXITO
        submitBtn.style.display = 'none';
        if (successMessage) {
          successMessage.classList.remove('hidden');
          if (successText) {
            successText.textContent = getLang() === 'en'
              ? 'Your information was sent successfully.'
              : 'Se mandó correctamente la información.';
          }
          successMessage.style.transform = 'scale(0.95)';
          successMessage.style.opacity = '0';
          setTimeout(() => {
            successMessage.style.transform = 'scale(1)';
            successMessage.style.opacity = '1';
          }, 50);
        }
        
        // Preparar datos del formulario
        const formData = new FormData(form);
        
        
        try {
          const webhookData = Object.fromEntries(formData.entries());
          webhookData.pagina_origen = webhookData.page || 'Formulario principal';
          webhookData.fecha_envio = new Date().toISOString();
          webhookData.lead_source = 'website_form';
          webhookData.form_type = 'contact_form';
          webhookData.priority = 'normal';
          await fetch('/api/form-webhook', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(webhookData)
          });
          
        } catch (error) {
          /* webhook silencioso: el usuario ya vio el mensaje de éxito */
        }

        setTimeout(() => {
          form.reset();
          const grecaptchaApi = window.grecaptcha;
          if (typeof grecaptchaApi !== 'undefined') {
            grecaptchaApi.reset();
          }
          sync();
          if (successMessage) {
            successMessage.classList.add('hidden');
          }
          submitBtn.style.display = 'flex';
        }, 3000);
      });
    }
    } /* fin initForm */

    /* Dispara init cuando el formulario está cerca del viewport (300px antes) */
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            initForm();
            io.disconnect();
            break;
          }
        }
      }, { rootMargin: '300px 0px', threshold: 0 });
      io.observe(formSection);
    } else {
      /* Fallback: navegadores sin IO inician al cargar */
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initForm);
      } else {
        initForm();
      }
    }
  })();
</script>

<style>
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

/* ===== Form local aliases (paleta global desde global.css) ===== */
.form-section {
  --primary-color: var(--c-purple);
  --secondary-color: var(--c-rose);
  --border-radius: var(--radius);
}

/* ===== SECCIÓN PRINCIPAL — mobile-first ===== */
.form-section {
  background: linear-gradient(135deg, var(--surface-2) 0%, #ffffff 100%);
  font-family: 'Poppins', sans-serif;
  padding: 2.5rem 0;
}

/* ===== CONTENEDOR — mobile-first (1 col) ===== */
.form-container {
  max-width: var(--content-max);
  margin: 0 auto;
  padding: 1rem;
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  align-items: start;
}

@media (min-width: 1024px) {
  .form-section { padding: 4rem 0; }
  .form-container {
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    padding: 2rem;
  }
}

/* ===== COLUMNA IZQUIERDA - INFORMACIÓN ===== */
.form-info {
  padding: 2rem 0;
}

.info-header {
  margin-bottom: 2rem;
}

.main-title {
  font-size: 3rem;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
  line-height: 1.2;
}

.sub-title {
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 0.5rem;
}

.accent-title {
  font-size: 1.25rem;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 1.5rem;
}

.description {
  font-size: 1.1rem;
  line-height: 1.6;
  color: var(--text-secondary);
  margin-bottom: 2rem;
}

.highlight {
  color: var(--primary-color);
  font-weight: 600;
}

.benefits-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 2rem 0 1.5rem 0;
}

/* ===== LISTA DE BENEFICIOS ===== */
.benefits-list {
  list-style: none;
  padding: 0;
  margin: 0 0 2rem 0;
}

.benefit-item {
