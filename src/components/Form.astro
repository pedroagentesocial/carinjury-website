<script is:inline>
  // Initialize i18n client for Form component
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof window !== 'undefined' && window.i18nClient) {
      window.i18nClient.updateAllTranslations();
    } else {
      document.addEventListener('i18nReady', function() {
        if (window.i18nClient) {
          window.i18nClient.updateAllTranslations();
        }
      });
    }
  });
</script>

<script>
  /* Captcha condicional: solo aparece cuando los requeridos están completos.
     Animación con Motion. Si Motion falla, fallback a class toggle simple. */
  import { animate } from 'motion';

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    const captcha = document.querySelector<HTMLElement>('[data-captcha]');
    if (!form || !captcha) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const animateAny = animate as unknown as (...args: any[]) => any;

    const requiredFields = ['name', 'phone', 'discovery_source'];
    const consent = document.getElementById('sms-consent') as HTMLInputElement | null;

    const isComplete = () => {
      const allFilled = requiredFields.every((name) => {
        const el = form.querySelector(`[name="${name}"]`) as HTMLInputElement | HTMLSelectElement | null;
        return el && el.value.trim() !== '';
      });
      const consented = !!consent?.checked;
      return allFilled && consented;
    };

    let isShown = false;

    const showCaptcha = () => {
      if (isShown) return;
      isShown = true;
      captcha.classList.add('is-visible');
      captcha.setAttribute('aria-hidden', 'false');
      const target = captcha.scrollHeight;
      if (reducedMotion) {
        captcha.style.height = 'auto';
        captcha.style.opacity = '1';
        return;
      }
      try {
        animateAny(
          captcha,
          { height: ['0px', `${target}px`], opacity: [0, 1], y: [-6, 0] },
          { duration: 0.42, easing: [0.22, 1, 0.36, 1] }
        );
        // Después de la animación dejarlo en height auto para que se adapte a cambios
        window.setTimeout(() => {
          if (isShown) captcha.style.height = 'auto';
        }, 460);
      } catch {
        captcha.style.height = 'auto';
        captcha.style.opacity = '1';
      }
    };

    const hideCaptcha = () => {
      if (!isShown) return;
      isShown = false;
      captcha.classList.remove('is-visible');
      captcha.setAttribute('aria-hidden', 'true');
      const current = captcha.offsetHeight;
      if (reducedMotion) {
        captcha.style.height = '0px';
        captcha.style.opacity = '0';
        return;
      }
      try {
        animateAny(
          captcha,
          { height: [`${current}px`, '0px'], opacity: [1, 0] },
          { duration: 0.28, easing: [0.4, 0, 0.2, 1] }
        );
      } catch {
        captcha.style.height = '0px';
        captcha.style.opacity = '0';
      }
    };

    const check = () => {
      if (isComplete()) showCaptcha();
      else hideCaptcha();
    };

    requiredFields.forEach((name) => {
      const el = form.querySelector(`[name="${name}"]`);
      el?.addEventListener('input', check);
      el?.addEventListener('change', check);
      el?.addEventListener('blur', check);
    });
    consent?.addEventListener('change', check);

    /* Por si el navegador autollena los campos */
    window.setTimeout(check, 600);
  });
</script>
