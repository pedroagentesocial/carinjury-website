  }

  .start-chat-btn:active {
    transform: translateY(0);
  }

  /* Contenedor del botón de reinicio */
  .reset-container {
    padding: 8px 16px 12px;
    display: flex;
    justify-content: center;
    background: #ffffff;
    border-top: 1px solid rgba(122, 46, 135, 0.1);
  }

  .reset-btn {
    width: 32px;
    height: 32px;
    border: 1px solid rgba(122, 46, 135, 0.3);
    border-radius: 50%;
    background: #ffffff;
    color: #7A2E87;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .reset-btn svg {
    width: 16px;
    height: 16px;
  }

  .reset-btn:hover {
    background: #7A2E87;
    color: #ffffff;
    border-color: #7A2E87;
    transform: scale(1.1);
  }

  .reset-btn:active {
    transform: scale(0.95);
  }

  .footer-btn:focus {
    outline: 2px solid var(--color-bot);
    outline-offset: 2px;
  }

  /* Botones de contacto */
  .contact-buttons {
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-top: 1px solid var(--color-border);
    background: rgba(var(--color-cta), 0.05);
  }

  .contact-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--c3);
    color: var(--color-cta-text);
    border: none;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: var(--centerfy-transition);
    text-decoration: none;
    min-height: 44px;
    box-shadow: 0 2px 4px rgba(122, 46, 135, 0.2);
  }

  .contact-btn:hover {
    background: var(--c2);
    transform: translateY(-1px);
    box-shadow: 0 4px 8px rgba(122, 46, 135, 0.4);
  }

  .contact-btn:focus {
    outline: 2px solid var(--c3);
    outline-offset: 2px;
  }

  .contact-btn-icon {
    font-size: 18px;
    flex-shrink: 0;
  }

  .contact-btn-text {
    flex: 1;
    text-align: left;
  }

  .contact-btn-subtitle {
    font-size: 12px;
    opacity: 0.9;
    margin-top: 2px;
  }

  /* Acciones del footer */
  .chat-footer-actions {
    display: flex;
    justify-content: center;
    padding-top: 12px;
    border-top: 1px solid #f1f5f9;
    margin-top: 12px;
  }

  .end-chat-btn {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    color: #64748b;
    padding: 8px 16px;
    border-radius: 16px;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .end-chat-btn:hover {
    background: #fee2e2;
    border-color: #fca5a5;
    color: #dc2626;
  }

  /* Animaciones mejoradas */
  @keyframes pulse {
    0% {
      box-shadow: 0 4px 20px rgba(122, 46, 135, 0.3), 0 0 0 0 rgba(122, 46, 135, 0.7);
    }
    70% {
      box-shadow: 0 4px 20px rgba(122, 46, 135, 0.3), 0 0 0 10px rgba(122, 46, 135, 0);
    }
    100% {
      box-shadow: 0 4px 20px rgba(122, 46, 135, 0.3), 0 0 0 0 rgba(122, 46, 135, 0);
    }
  }

  @keyframes messageSlideIn {
    from {
      opacity: 0;
      transform: translateY(15px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Estados de carga */
  .loading {
    animation: pulse 2s infinite;
  }

  .fade-in {
    animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Soporte para prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    * {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* Responsive design */
  @media (max-width: 768px) {
    .centerfy-chat-widget {
      bottom: 15px;
      right: 15px;
    }

    .chat-button {
      width: 55px;
      height: 55px;
    }

    .chat-icon {
      width: 24px;
      height: 24px;
    }

    .tooltip {
      font-size: 12px;
      padding: 6px 10px;
      right: 65px;
    }

    .chat-window {
      width: calc(100vw - 30px);
      height: 70vh;
      bottom: 75px;
    }

    /* Ajustes para burbujas en móvil */
    .message {
      max-width: 85%;
    }

    .message-content {
      padding: 10px 14px;
      font-size: 13px;
    }

    .bot-message .message-content::before,
    .user-message .message-content::before {
      border-width: 6px;
    }

    .bot-message .message-content::before {
      left: -6px;
    }

    .user-message .message-content::before {
      right: -6px;
    }

    .chat-messages {
      padding: 15px;
      gap: 10px;
    }

    .quick-actions {
      padding: 12px;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 8px;
      max-height: 140px;
    }

    .quick-btn {
      min-height: 50px;
      padding: 8px 6px;
      gap: 6px;
    }

    .quick-btn-icon {
      font-size: 16px;
    }

    .quick-btn-text {
      font-size: 10px;
    }

    .chat-input-area {
      padding: 12px 16px 16px;
    }
  }
</style>

<script define:vars={{ centerfyConfig }}>
  // Asistente Virtual Centerfy.ai - Integración completa
  class CenterfyAI {
    constructor() {
      this.isOpen = false;
      this.isMinimized = false;
      this.isTyping = false;
      this.conversationId = null;
      this.conversationHistory = [];
      this.showingHistory = false;
      
      // Configuración Centerfy.ai (desde el servidor)
      this.config = {
        projectId: centerfyConfig.projectId || 'demo-project',
        hasApiKey: centerfyConfig.hasApiKey || false,
        locale: centerfyConfig.locale || 'es-MX',
        baseUrl: 'https://api.centerfy.ai/v1'
      };
      
      // Knowledge base y respuestas
      this.knowledgeBase = this.initializeKnowledgeBase();
      this.responses = this.initializeResponses();
      
      this.init();
    }

    init() {
      // Elementos del DOM
      this.chatButton = document.getElementById('centerfy-chat-btn');
      this.chatWindow = document.getElementById('centerfy-chat-window');
      this.chatClose = document.getElementById('close-btn');
      this.chatMinimize = document.getElementById('minimize-btn');
      this.historyBtn = document.getElementById('history-btn');
      this.conversationHistory = document.getElementById('conversation-history');
      this.historyList = document.getElementById('history-list');
      this.historyClose = document.getElementById('close-history-btn');
      this.chatMessages = document.getElementById('centerfy-chat-messages');
      this.chatInput = document.getElementById('centerfy-chat-input');
      this.sendButton = document.getElementById('centerfy-send-btn');
      this.quickActions = document.getElementById('centerfy-quick-actions');
      this.typingIndicator = document.getElementById('typing-indicator');
      this.resetBtn = document.getElementById('reset-conversation-btn');
      this.endBtn = document.getElementById('end-conversation-btn');
      
      // Elementos del modal de confirmación
      this.closeModal = document.getElementById('close-confirmation-modal');
      this.modalCancelBtn = document.getElementById('modal-cancel-btn');
      this.modalConfirmBtn = document.getElementById('modal-confirm-btn');

      // Elementos del formulario inicial
      this.initialForm = document.getElementById('initial-form');
      this.userNameInput = document.getElementById('user-name');
      this.userPhoneInput = document.getElementById('user-phone');
      this.startChatBtn = document.getElementById('start-chat-btn');
      this.chatInputArea = document.querySelector('.chat-input-area');
      this.resetContainer = document.getElementById('reset-container');

      this.bindEvents();
      this.updateSendButtonState();
      
      // Cargar historial de conversaciones
      this.conversationHistory = this.loadConversationHistory();
    }

    bindEvents() {
      // Eventos principales del widget
      this.chatButton?.addEventListener('click', () => this.openWidget());
      this.chatClose?.addEventListener('click', () => this.closeChat());
      this.chatMinimize?.addEventListener('click', () => this.minimizeWidget());
      
      // Eventos del modal de confirmación
      this.modalCancelBtn?.addEventListener('click', () => this.hideCloseConfirmation());
      this.modalConfirmBtn?.addEventListener('click', () => this.confirmCloseChat());
      this.closeModal?.addEventListener('click', (e) => {
        if (e.target === this.closeModal) {
          this.hideCloseConfirmation();
        }
      });
      
      // Eventos del historial
      this.historyBtn?.addEventListener('click', () => this.toggleHistory());
      this.historyClose?.addEventListener('click', () => this.hideHistory());
      
      // Eventos de conversación
      this.resetBtn?.addEventListener('click', () => this.resetConversation());
      this.endBtn?.addEventListener('click', () => this.endConversation());
      this.sendButton?.addEventListener('click', () => this.sendMessage());
      
      // Eventos del textarea
      this.chatInput?.addEventListener('input', () => this.updateSendButtonState());
      this.chatInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          this.sendMessage();
        }
      });

      // Eventos del formulario inicial
      this.startChatBtn?.addEventListener('click', () => this.startChat());
      this.userNameInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          this.startChat();
        }
      });

      // FAQ Modal toggle
      const faqModalToggle = document.getElementById('quick-menu-toggle');
      const faqModalOverlay = document.getElementById('faq-modal-overlay');
      const faqModalClose = document.getElementById('faq-modal-close');
      
      // Abrir modal FAQ
      faqModalToggle?.addEventListener('click', () => {
        faqModalOverlay.style.display = 'flex';
        document.body.style.overflow = 'hidden'; // Prevenir scroll del body
      });

      // Cerrar modal FAQ
      const closeFaqModal = () => {
        faqModalOverlay.style.display = 'none';
        document.body.style.overflow = 'auto'; // Restaurar scroll del body
      };

      faqModalClose?.addEventListener('click', closeFaqModal);
      
      // Cerrar modal al hacer clic en el overlay
      faqModalOverlay?.addEventListener('click', (e) => {
        if (e.target === faqModalOverlay) {
          closeFaqModal();
        }
      });

      // FAQ options event delegation
      faqModalOverlay?.addEventListener('click', (e) => {
        const faqBtn = e.target.closest('.faq-option-btn');
        if (faqBtn) {
          const action = faqBtn.dataset.action;
          this.handleQuickAction(action);
          closeFaqModal(); // Cerrar modal después de seleccionar
        }
      });

      // Quick actions event delegation (para botones en el área de entrada)
      this.quickActions?.addEventListener('click', (e) => {
        const quickBtn = e.target.closest('.quick-btn-compact');
        if (quickBtn) {
          const action = quickBtn.dataset.action;
          this.handleQuickAction(action);
        }
      });

      // Navegación por teclado
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.isOpen) {
          if (this.showingHistory) {
            this.hideHistory();
          } else {
            this.minimizeWidget();
          }
        }
      });
      
      // Cerrar al hacer clic fuera (solo si no está mostrando historial)
      document.addEventListener('click', (e) => {
        if (this.isOpen && !this.showingHistory && 
            !this.chatWindow?.contains(e.target) && 
            !this.chatButton?.contains(e.target)) {
          this.minimizeWidget();
        }
      });
    }

    // Funciones principales del widget (API pública)
    openWidget() {
      this.isOpen = true;
      this.isMinimized = false;
      this.chatWindow?.classList.add('open');
      this.chatWindow?.classList.remove('minimized');
      
      // Al abrir, solo mostrar el formulario inicial
      // No mostrar botones rápidos ni área de chat hasta completar el formulario
    }

    minimizeWidget() {
      this.isMinimized = true;
      this.chatWindow?.classList.add('minimized');
      this.hideHistory();
    }

    showCloseConfirmation() {
      this.closeModal?.classList.add('show');
    }

    hideCloseConfirmation() {
      this.closeModal?.classList.remove('show');
    }

    confirmCloseChat() {
      this.hideCloseConfirmation();
      this.resetConversation();
      this.closeChat();
    }

    closeChat() {
      this.isOpen = false;
      this.isMinimized = false;
      this.chatWindow?.classList.remove('open', 'minimized');
      this.hideHistory();
      
      // Resetear el estado del chat al cerrar
      this.resetChatState();
    }

    resetChatState() {
      // Limpiar mensajes
      if (this.chatMessages) {
        this.chatMessages.innerHTML = '<div id="chat-description" class="sr-only" data-i18n="chat.description">Área de mensajes del chat</div>';
        this.chatMessages.style.display = 'none';
      }
      
      // Ocultar elementos del chat
      if (this.chatInputArea) {
        this.chatInputArea.style.display = 'none';
      }
      if (this.quickActions) {
        this.quickActions.style.display = 'none';
      }
      if (this.resetContainer) {
        this.resetContainer.style.display = 'none';
      }
      
      // Mostrar formulario inicial
      if (this.initialForm) {
        this.initialForm.style.display = 'flex';
      }
      
      // Limpiar campos del formulario
      if (this.userNameInput) {
        this.userNameInput.value = '';
      }
      if (this.userPhoneInput) {
        this.userPhoneInput.value = '';
      }
      
      // Resetear variables
      this.userName = '';
      this.userPhone = '';
      this.conversationId = null;
    }

    // Manejo del formulario inicial
    startChat() {
      const userName = this.userNameInput?.value.trim();
      const userPhone = this.userPhoneInput?.value.trim();
      
      if (!userName) {
        this.userNameInput?.focus();
        return;
      }
      
      // Guardar información del usuario
      this.userName = userName;
      this.userPhone = userPhone;
      
      // Ocultar formulario inicial y mostrar chat
      if (this.initialForm) {
        this.initialForm.style.display = 'none';
      }
      if (this.chatMessages) {
        this.chatMessages.style.display = 'block';
      }
      if (this.chatInputArea) {
        this.chatInputArea.style.display = 'flex';
      }
      if (this.quickActions) {
        this.quickActions.style.display = 'flex';
      }
      if (this.resetContainer) {
        this.resetContainer.style.display = 'flex';
      }
      
      // Mostrar mensaje de bienvenida personalizado
      this.addMessage(`¡Hola ${userName}! Soy tu asistente virtual. ¿En qué puedo ayudarte hoy?`, 'bot');
      
      // Enfocar el input de chat
      this.chatInput?.focus();
    }

    // Gestión del historial de conversaciones
    toggleHistory() {
      if (this.showingHistory) {
        this.hideHistory();
      } else {
        this.showHistory();
      }
    }

    showHistory() {
      this.showingHistory = true;
      if (this.conversationHistory) {
        this.conversationHistory.style.display = 'flex';
      }
      this.renderConversationHistory();
    }

    hideHistory() {
      this.showingHistory = false;
      if (this.conversationHistory) {
        this.conversationHistory.style.display = 'none';
      }
    }

    // Gestión de conversaciones con Centerfy.ai
    async startConversation() {
      try {
        // Si ya hay una conversación activa, terminarla primero
        if (this.conversationId) {
          await this.endConversation(false);
        }
        
        // Crear nueva conversación
        this.conversationId = await this.createConversation();
        
        // Limpiar mensajes
        this.chatMessages.innerHTML = '';
        
        // Mensaje de bienvenida
        const welcomeMessage = '¡Hola! Soy tu asistente virtual. Puedo ayudarte con servicios, horarios y cómo empezar. Elige una opción o pregúntame lo que quieras.';
        this.addMessage(welcomeMessage, 'bot');
        
        // Mostrar botones de acción rápida
        this.quickActions.style.display = 'flex';
        
        // Guardar en historial
        this.saveConversationToHistory();
        
      } catch (error) {
        console.error('Error al iniciar conversación:', error);
        this.addMessage('Error al iniciar la conversación. Por favor, inténtalo de nuevo.', 'bot');
      }
    }

    async resetConversation() {
      try {
        // Limpiar mensajes con animación más rápida
        this.clearMessagesWithAnimation();
        
        // Mensaje de reinicio después de la animación
        setTimeout(() => {
          this.addMessage('Conversación reiniciada.', 'bot');
          
          // Mostrar botones de acción rápida
          this.quickActions.style.display = 'flex';
          
          // Focus en el textarea
          this.chatInput?.focus();
        }, 200);
        
        // Limpiar textarea inmediatamente
        if (this.chatInput) {
          this.chatInput.value = '';
          this.updateSendButtonState();
        }
        
        // Resetear ID de conversación para crear una nueva
        this.conversationId = null;
        
      } catch (error) {
        console.error('Error al reiniciar conversación:', error);
        this.clearMessagesWithAnimation();
        setTimeout(() => {
          this.addMessage('Error al reiniciar la conversación. Iniciando una nueva...', 'bot');
          this.startConversation();
        }, 200);
      }
    }

    async endConversation(showConfirm = true) {
      if (showConfirm && !confirm('¿Estás seguro de que quieres terminar la conversación?')) {
        return;
      }
      
      if (!this.conversationId) return;
      
      try {
        // Terminar conversación en Centerfy.ai
        await this.endCenterfyConversation(this.conversationId);
        
        // Mensaje de despedida
        if (showConfirm) {
          const farewellMessage = '¡Gracias por contactarnos! Si necesitas más ayuda, no dudes en escribirnos nuevamente. ¡Que tengas un excelente día! 👋';
          this.addMessage(farewellMessage, 'bot');
        }
        
        // Actualizar historial
        this.updateConversationInHistory('closed');
        
        // Limpiar ID de conversación
        this.conversationId = null;
        
        // Ocultar botones de acción rápida
        this.quickActions.style.display = 'none';
        
        if (showConfirm) {
          // Cerrar widget después de 1.5 segundos y limpiar mensajes
          setTimeout(() => {
            this.clearMessagesWithAnimation();
            this.minimizeWidget();
          }, 1500);
        } else {
          // Si no se muestra confirmación, limpiar inmediatamente
          this.clearMessagesWithAnimation();
        }
        
      } catch (error) {
        console.error('Error al terminar conversación:', error);
        this.conversationId = null;
      }
    }

    async sendMessage() {
      const message = this.chatInput?.value.trim();
      if (!message || this.isTyping) return;

      try {
        // Iniciar conversación si no existe
        if (!this.conversationId) {
          await this.startConversation();
        }

        // Agregar mensaje del usuario
        this.addMessage(message, 'user');
        this.chatInput.value = '';
        this.updateSendButtonState();
        
        // Ocultar botones de acción rápida
        this.quickActions.style.display = 'none';
        
        // Mostrar indicador de escritura
        this.showTyping();
        
        // Enviar mensaje a Centerfy.ai
        if (this.knowledgeBase && typeof this.knowledgeBase.sendMessage === 'function') {
          try {
            // Intentar usar streaming si está disponible
            if (typeof this.knowledgeBase.sendMessageStream === 'function') {
              const stream = this.knowledgeBase.sendMessageStream(this.conversationId, {
                text: message,
                locale: this.config.locale
              });
              
              let botResponse = '';
              let messageElement = null;
              
              for await (const chunk of stream) {
                if (chunk.delta) {
                  botResponse += chunk.delta;
                  
                  // Crear elemento de mensaje si no existe
                  if (!messageElement) {
                    this.hideTyping();
                    messageElement = this.addStreamingMessage('', 'bot');
                  }
                  
                  // Actualizar contenido del mensaje
                  this.updateStreamingMessage(messageElement, botResponse);
                }
              }
              
              // Finalizar streaming
              if (messageElement) {
                this.finalizeStreamingMessage(messageElement);
              }
              
            } else {
              // Fallback a mensaje simple
              const response = await this.knowledgeBase.sendMessage(this.conversationId, {
                text: message,
                locale: this.config.locale
              });
              
              this.hideTyping();
              this.addMessage(response.text || response.message || 'Lo siento, no pude procesar tu mensaje.', 'bot');
            }
            
          } catch (apiError) {
            console.error('Error con Centerfy.ai API:', apiError);
            this.hideTyping();
            
            // Fallback a respuestas locales
            const fallbackResponse = this.generateFallbackResponse(message);
            this.addMessage(fallbackResponse, 'bot');
          }
          
        } else {
          // Fallback si no hay SDK disponible
          await this.delay(1000 + Math.random() * 2000);
          const response = this.generateFallbackResponse(message);
          this.hideTyping();
          this.addMessage(response, 'bot');
        }
        
        // Mostrar botones de acción rápida después de la respuesta
        setTimeout(() => {
          this.showQuickActions();
        }, 1000);
        
      } catch (error) {
        console.error('Error al enviar mensaje:', error);
        this.hideTyping();
        this.addMessage('Lo siento, ocurrió un error. Por favor intenta de nuevo o contacta a nuestro equipo directamente.', 'bot');
        this.showQuickActions();
      }
    }

    async handleQuickAction(action) {
      const quickResponses = {
        'servicios': '¿Qué servicios ofrecen?',
        'horarios': '¿Cuáles son sus horarios de atención?',
        'empezar': '¿Cómo puedo empezar mi caso?',
        'contactar': '¿Cómo los contacto?',
        'humano': 'Quiero hablar con una persona',
        'documentos': '¿Qué documentos necesito?',
        'costos': '¿Cuánto cuesta?',
        'seguros': '¿Aceptan seguros?',
        'nueva': 'Iniciar nueva conversación'
      };
      
      const message = quickResponses[action];
      if (message) {
        // Manejar acción especial de nueva conversación
        if (action === 'nueva') {
          await this.startConversation();
          return;
        }
        
        // Mostrar mensaje del usuario cuando presiona un botón rápido (CORREGIDO)
        this.addMessage(message, 'user');
        
