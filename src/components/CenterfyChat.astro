    showTyping() {
      this.isTyping = true;
      this.typingIndicator.style.display = 'flex';
      this.scrollToBottom();
    }

    hideTyping() {
      this.isTyping = false;
      this.typingIndicator.style.display = 'none';
    }

    scrollToBottom() {
      setTimeout(() => {
        this.chatMessages?.scrollTo({
          top: this.chatMessages.scrollHeight,
          behavior: 'smooth'
        });
      }, 100);
    }

    clearMessagesWithAnimation() {
      const messages = this.chatMessages.querySelectorAll('.message');
      
      // Animar salida de mensajes
      messages.forEach((message, index) => {
        setTimeout(() => {
          message.style.transition = 'all 0.15s ease-out';
          message.style.opacity = '0';
          message.style.transform = 'translateY(-10px) scale(0.95)';
        }, index * 20);
      });
      
      // Limpiar después de la animación
      setTimeout(() => {
        this.chatMessages.innerHTML = '';
      }, messages.length * 20 + 150);
    }

    delay(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

    getTimeBasedGreeting() {
      const currentHour = new Date().getHours();
      if (currentHour < 12) {
        return '¡Buenos días!';
      } else if (currentHour < 18) {
        return '¡Buenas tardes!';
      } else {
        return '¡Buenas noches!';
      }
    }

    // Method to trigger lead capture
    triggerLeadCapture(userMessage, actionType) {
      // Create a simple lead capture form
      const leadForm = document.createElement('div');
      leadForm.className = 'lead-capture-form';
      leadForm.innerHTML = `
        <div class="lead-form-content">
          <h4>¡Perfecto! Déjanos tus datos para contactarte</h4>
          <input type="text" id="lead-name" placeholder="Tu nombre completo" required>
          <input type="email" id="lead-email" placeholder="Tu email" required>
          <input type="tel" id="lead-phone" placeholder="Tu teléfono" required>
          <button id="submit-lead">Enviar información</button>
          <button id="cancel-lead">Cancelar</button>
        </div>
      `;
      
      // Add styles for the form
      const style = document.createElement('style');
      style.textContent = `
        .lead-capture-form {
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background: rgba(0, 0, 0, 0.5);
          display: flex;
          align-items: center;
          justify-content: center;
          z-index: 10000;
        }
        .lead-form-content {
          background: white;
          padding: 30px;
          border-radius: 12px;
          max-width: 400px;
          width: 90%;
        }
        .lead-form-content h4 {
          margin: 0 0 20px 0;
          color: #7A2E87;
        }
        .lead-form-content input {
          width: 100%;
          padding: 12px;
          margin: 8px 0;
          border: 1px solid #e2e8f0;
          border-radius: 6px;
          box-sizing: border-box;
        }
        .lead-form-content button {
          padding: 12px 20px;
          margin: 8px 5px 0 0;
          border: none;
          border-radius: 6px;
          cursor: pointer;
        }
        #submit-lead {
          background: #7A2E87;
          color: white;
        }
        #cancel-lead {
          background: #f1f5f9;
          color: #475569;
        }
      `;
      
      document.head.appendChild(style);
      document.body.appendChild(leadForm);
      
      // Handle form submission
      document.getElementById('submit-lead').addEventListener('click', () => {
        const name = document.getElementById('lead-name').value;
        const email = document.getElementById('lead-email').value;
        const phone = document.getElementById('lead-phone').value;
        
        if (name && email && phone) {
          this.sendToGoHighLevel({
            firstName: name.split(' ')[0],
            lastName: name.split(' ').slice(1).join(' '),
            email: email,
            phone: phone,
            summary: userMessage,
            questions: [userMessage],
            actionType: actionType
          });
          
          document.body.removeChild(leadForm);
          document.head.removeChild(style);
          
          this.addMessage('¡Gracias! Hemos recibido tu información. Nos pondremos en contacto contigo muy pronto.', 'bot');
        } else {
          alert('Por favor completa todos los campos');
        }
      });
      
      // Handle form cancellation
      document.getElementById('cancel-lead').addEventListener('click', () => {
        document.body.removeChild(leadForm);
        document.head.removeChild(style);
      });
    }

    // Method to send conversation data to GoHighLevel
    async sendToGoHighLevel(conversationData) {
      try {
        const response = await fetch(`${this.config.baseUrl}/contacts/`, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${this.config.apiKey}`,
            'Content-Type': 'application/json',
            'Version': '2021-07-28'
          },
          body: JSON.stringify({
            locationId: this.config.locationId,
            firstName: conversationData.firstName || 'Visitante',
            lastName: conversationData.lastName || 'Web',
            email: conversationData.email,
            phone: conversationData.phone,
            source: 'Centerfy Chat Widget',
            tags: ['chat-lead', 'website-visitor'],
            customFields: {
              conversation_summary: conversationData.summary,
              chat_timestamp: new Date().toISOString(),
              user_questions: conversationData.questions
            }
          })
        });
        
        if (response.ok) {
          const result = await response.json();
          console.log('Successfully sent to GoHighLevel:', result);
          return result;
        } else {
          console.error('Failed to send to GoHighLevel:', response.statusText);
        }
      } catch (error) {
        console.error('Error sending to GoHighLevel:', error);
      }
    }

    // Centerfy.ai API Functions
    async createConversation() {
      try {
        if (this.config.hasApiKey && this.centerfySDK) {
          // Use real Centerfy.ai SDK
          const conversation = await this.centerfySDK.startConversation({
            locale: this.config.locale || 'es-MX',
            projectId: this.config.projectId
          });
          this.conversationId = conversation.id;
          console.log('Centerfy conversation created:', this.conversationId);
          return conversation;
        } else {
          // Demo mode - generate mock conversation ID
          this.conversationId = 'demo_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
          console.log('Demo conversation created:', this.conversationId);
          return { id: this.conversationId, status: 'active' };
        }
      } catch (error) {
        console.error('Error creating conversation:', error);
        // Fallback to demo mode
        this.conversationId = 'demo_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
        return { id: this.conversationId, status: 'active' };
      }
    }

    async resetCenterfyConversation() {
      try {
        if (this.conversationId && this.config.hasApiKey && this.centerfySDK) {
          // Use real Centerfy.ai SDK
          await this.centerfySDK.resetConversation(this.conversationId);
          console.log('Centerfy conversation reset:', this.conversationId);
        } else {
          // Demo mode - just clear local state
          console.log('Demo conversation reset:', this.conversationId);
        }
        
        // Clear local conversation state
        this.chatMessages.innerHTML = '';
        this.conversationHistory = [];
        this.addMessage(this.getTimeBasedGreeting() + ' Conversación reiniciada. ¿En qué puedo ayudarte?', 'bot');
        this.showQuickActions();
        
      } catch (error) {
        console.error('Error resetting conversation:', error);
        // Fallback - just clear local state
        this.chatMessages.innerHTML = '';
        this.conversationHistory = [];
        this.addMessage('Conversación reiniciada. ¿En qué puedo ayudarte?', 'bot');
        this.showQuickActions();
      }
    }

    async endConversation(conversationId = null) {
      try {
        const targetId = conversationId || this.conversationId;
        
        if (targetId && this.config.hasApiKey && this.centerfySDK) {
          // Use real Centerfy.ai SDK
          await this.centerfySDK.endConversation(targetId);
          console.log('Centerfy conversation ended:', targetId);
        } else {
          // Demo mode
          console.log('Demo conversation ended:', targetId);
        }
        
        // Update conversation status in history
        if (this.conversationHistory.length > 0) {
          const lastConversation = this.conversationHistory[this.conversationHistory.length - 1];
          if (lastConversation.id === targetId) {
            lastConversation.status = 'closed';
            lastConversation.endTime = new Date().toISOString();
            this.saveConversationHistory();
          }
        }
        
        // Clear current conversation if it's the one being ended
        if (targetId === this.conversationId) {
          this.conversationId = null;
        }
        
      } catch (error) {
        console.error('Error ending conversation:', error);
      }
    }
  }

  // Inicializar cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', () => {
    new CenterfyAI();
  });
</script>