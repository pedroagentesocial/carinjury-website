    // Método para cargar historial de conversaciones
    loadConversationHistory() {
      try {
        const history = localStorage.getItem('centerfy_conversation_history');
        if (history) {
          this.conversationHistory = JSON.parse(history);
          // Mantener solo las últimas 5 conversaciones
          if (this.conversationHistory.length > 5) {
            this.conversationHistory = this.conversationHistory.slice(-5);
            this.saveConversationHistory();
          }
        }
      } catch (error) {
        console.error('Error cargando historial:', error);
        this.conversationHistory = [];
      }
    }
    
    // Método para guardar historial de conversaciones
    saveConversationHistory() {
      try {
        localStorage.setItem('centerfy_conversation_history', JSON.stringify(this.conversationHistory));
      } catch (error) {
        console.error('Error guardando historial:', error);
      }
    }
    
    // Método para agregar conversación al historial
    addToHistory(conversationId, status = 'abierta') {
      const now = new Date();
      const conversation = {
        id: conversationId,
        timestamp: now.toISOString(),
        date: now.toLocaleDateString('es-MX'),
        time: now.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' }),
        status: status
      };
      
      // Remover conversación existente si ya está en el historial
      this.conversationHistory = this.conversationHistory.filter(conv => conv.id !== conversationId);
      
      // Agregar nueva conversación al inicio
      this.conversationHistory.unshift(conversation);
      
      // Mantener solo las últimas 5
      if (this.conversationHistory.length > 5) {
        this.conversationHistory = this.conversationHistory.slice(0, 5);
      }
      
      this.saveConversationHistory();
    }
    
    // Método para actualizar estado de conversación en historial
    updateHistoryStatus(conversationId, status) {
      const conversation = this.conversationHistory.find(conv => conv.id === conversationId);
      if (conversation) {
        conversation.status = status;
        this.saveConversationHistory();
      }
    }

