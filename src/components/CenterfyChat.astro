    generateFallbackResponse(message) {
      const lowerMessage = message.toLowerCase();
      
      // Buscar respuesta exacta
      for (const [key, response] of Object.entries(this.responses.exact)) {
        if (lowerMessage.includes(key)) {
          // Trigger lead capture for contact requests
          if (key === 'consulta' || lowerMessage.includes('contacto') || lowerMessage.includes('llamar')) {
            this.triggerLeadCapture(message, 'contact_request');
          }
          return Array.isArray(response) ? response[Math.floor(Math.random() * response.length)] : response;
        }
      }
      
      // Buscar respuesta por palabras clave
      for (const [keywordString, response] of Object.entries(this.responses.keywords)) {
        const keywords = keywordString.split(',');
        if (keywords.some(keyword => lowerMessage.includes(keyword))) {
          return Array.isArray(response) ? response[Math.floor(Math.random() * response.length)] : response;
        }
      }
      
      // Respuesta por defecto con derivación a humano
      const defaultResponses = [
        '¡Hola! Soy tu asistente virtual. Puedo ayudarte con servicios, horarios y cómo empezar. ¿En qué puedo ayudarte hoy?',
        'Entiendo tu consulta. Para brindarte la mejor atención, ¿podrías ser más específico sobre lo que necesitas? También puedo conectarte con nuestro equipo humano.',
        'Gracias por contactarnos. Estoy aquí para resolver tus dudas sobre nuestros servicios. Si prefieres hablar directamente con una persona, puedo ayudarte con eso también.'
      ];
      return defaultResponses[Math.floor(Math.random() * defaultResponses.length)];
    }

