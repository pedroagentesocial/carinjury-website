    // Método para guardar conversación completa al historial
    saveConversationToHistory(conversationId, messages = []) {
      try {
        const conversationData = {
          id: conversationId,
          messages: messages,
          timestamp: new Date().toISOString(),
          status: 'cerrada'
        };
        
        // Guardar conversación completa en localStorage
        const conversationKey = `centerfy_conversation_${conversationId}`;
        localStorage.setItem(conversationKey, JSON.stringify(conversationData));
        
        // Actualizar historial
        this.updateHistoryStatus(conversationId, 'cerrada');
        
        console.log('Conversación guardada:', conversationId);
      } catch (error) {
        console.error('Error guardando conversación completa:', error);
      }
    }

    // Método para cargar una conversación específica
    loadConversation(conversationId) {
      try {
        const conversationKey = `centerfy_conversation_${conversationId}`;
        const conversationData = localStorage.getItem(conversationKey);
        
        if (conversationData) {
          const conversation = JSON.parse(conversationData);
          
          // Limpiar chat actual
          this.chatMessages.innerHTML = '';
          
          // Cargar mensajes de la conversación
          conversation.messages.forEach(msg => {
            this.addMessage(msg.content, msg.type);
          });
          
          // Establecer como conversación actual si está abierta
          if (conversation.status === 'abierta') {
            this.conversationId = conversationId;
          }
          
          // Cerrar historial
          const historyElement = document.querySelector('.conversation-history');
          if (historyElement) {
            historyElement.remove();
          }
          
          console.log('Conversación cargada:', conversationId);
        }
      } catch (error) {
        console.error('Error cargando conversación:', error);
      }
    }

