---
import { t, getCurrentLanguage } from '../i18n';

const currentLang = getCurrentLanguage();

const PHONE_NUMBER = '+13852428571';
const PHONE_DISPLAY = '+1 (385) 242-8571';
---

<div class="floating-buttons" aria-label="Botones de acción rápida">
  <!-- Botón de llamar -->
  <a 
    href={`tel:${PHONE_NUMBER}`} 
    class="floating-btn phone-btn"
    aria-label={t('floating_buttons.phone.aria_label', currentLang)}
    title={t('floating_buttons.phone.tooltip', currentLang)}
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M22 16.92v2a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 3.8 2 2 0 0 1 4.11 2h2a2 2 0 0 1 2 1.72c.12.9.31 1.78.57 2.63a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.45-1.17a2 2 0 0 1 2.11-.45c.85.26 1.73.45 2.63.57A2 2 0 0 1 22 16.92Z" fill="currentColor"/>
    </svg>
    <span class="btn-tooltip" data-i18n="floating_buttons.phone.tooltip">{t('floating_buttons.phone.tooltip', currentLang)}</span>
  </a>

  <!-- Botón de agendar -->
  <button 
    type="button"
    class="floating-btn schedule-btn"
    data-open-booking-modal
    aria-label={t('floating_buttons.schedule.aria_label', currentLang)}
    title={t('floating_buttons.schedule.tooltip', currentLang)}
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z" fill="currentColor"/>
    </svg>
    <span class="btn-tooltip" data-i18n="floating_buttons.schedule.tooltip">{t('floating_buttons.schedule.tooltip', currentLang)}</span>
  </button>

  <!-- Botón de ayuda -->
  <a 
    href="/faq" 
    class="floating-btn help-btn"
    aria-label={t('floating_buttons.help.aria_label', currentLang)}
    title={t('floating_buttons.help.tooltip', currentLang)}
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z" fill="currentColor"/>
    </svg>
    <span class="btn-tooltip" data-i18n="floating_buttons.help.tooltip">{t('floating_buttons.help.tooltip', currentLang)}</span>
  </a>
  
  <button 
    type="button"
    class="floating-btn booking-btn"
    aria-label={t('floating_buttons.booking.aria_label', currentLang)}
    title={t('floating_buttons.booking.tooltip', currentLang)}
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M7 10h5v5H7zM19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" fill="currentColor"/>
    </svg>
    <span class="btn-tooltip" data-i18n="floating_buttons.booking.tooltip">{t('floating_buttons.booking.tooltip', currentLang)}</span>
  </button>
</div>

<div id="booking-modal" class="booking-modal hidden" aria-hidden="true" role="dialog" aria-labelledby="booking-title">
  <div class="booking-backdrop"></div>
  <div class="booking-dialog">
    <div class="booking-header">
      <h3 id="booking-title" data-i18n="floating_buttons.booking.title">{t('floating_buttons.booking.title', currentLang)}</h3>
      <button class="booking-close" type="button" aria-label={t('floating_buttons.booking.close', currentLang)}>×</button>
    </div>
    <div class="booking-body">
      <iframe
        class="booking-frame"
        src="about:blank"
        data-src="https://api.leadconnectorhq.com/widget/booking/CnL8Bv0AP9Fdqw6xYZji"
        title={t('floating_buttons.booking.iframe_title', currentLang)}
        scrolling="yes"
        id="CnL8Bv0AP9Fdqw6xYZji_1775680792513"
        loading="lazy"
      ></iframe>
    </div>
  </div>
</div>
<script is:inline src="https://link.msgsndr.com/js/form_embed.js" type="text/javascript"></script>

<style>
/* ==========================================================================
   FLOATING BUTTONS — Botones flotantes en el lado izquierdo
   ========================================================================== */

:root {
  --floating-primary: #7A2E87;
  --floating-primary-hover: #8b3494;
  --floating-shadow: rgba(122, 46, 135, 0.3);
  --floating-shadow-hover: rgba(122, 46, 135, 0.5);
}

.floating-buttons {
  position: fixed;
  left: 20px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 12px;
  z-index: 1000;
  pointer-events: none;
}

.floating-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  background:
    radial-gradient(circle at 28% 25%, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0) 45%),
    linear-gradient(145deg, #9e47ab 0%, #7a2e87 48%, #5b1f66 100%);
  color: white;
  border: none;
  border-radius: 50%;
  text-decoration: none;
  box-shadow: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: auto;
  position: relative;
  overflow: visible;
}

.floating-btn:hover {
  background:
    radial-gradient(circle at 28% 25%, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0) 46%),
    linear-gradient(145deg, #b25ac0 0%, #8b3494 50%, #662470 100%);
  transform: scale(1.1);
  box-shadow: none;
}

.floating-btn:active {
  transform: scale(0.95);
}

.floating-btn svg {
  flex-shrink: 0;
  transition: transform 0.3s ease;
}

.floating-btn:hover svg {
  transform: scale(1.1);
}

/* Tooltips */
.btn-tooltip {
  position: absolute;
  left: calc(100% + 12px);
  top: 50%;
  transform: translateY(-50%);
  background: rgba(0, 0, 0, 0.9);
  color: white;
  padding: 8px 12px;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 600;
  white-space: nowrap;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  pointer-events: none;
  z-index: 1001;
}

.btn-tooltip::before {
  content: '';
  position: absolute;
  right: 100%;
  top: 50%;
  transform: translateY(-50%);
  border: 6px solid transparent;
  border-right-color: rgba(0, 0, 0, 0.9);
}

.floating-btn:hover .btn-tooltip {
  opacity: 1;
  visibility: visible;
  transform: translateY(-50%) translateX(4px);
}

/* Animaciones de entrada */
.floating-btn {
  animation: slideInLeft 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.floating-btn:nth-child(1) {
  animation-delay: 0.1s;
}

.floating-btn:nth-child(2) {
  animation-delay: 0.2s;
}

.floating-btn:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-100px) translateY(-50%);
  }
  to {
    opacity: 1;
    transform: translateX(0) translateY(-50%);
  }
}

/* Responsive */
@media (max-width: 768px) {
  .floating-buttons {
    left: 50%;
    top: auto;
    bottom: 30px;
    transform: translateX(-50%);
    flex-direction: row;
    gap: 10px;
    padding: 0 10px;
    max-width: calc(100vw - 20px);
    justify-content: center;
  }
  
  .floating-btn {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }
  
  .floating-btn svg {
    width: 18px;
    height: 18px;
  }
  
  .btn-tooltip {
    font-size: 12px;
    padding: 6px 10px;
    left: 50%;
    transform: translateX(-50%);
    bottom: calc(100% + 8px);
    top: auto;
  }
}

@media (max-width: 480px) {
  .floating-buttons {
    left: 50%;
    bottom: 20px;
    transform: translateX(-50%);
    flex-direction: row;
    gap: 8px;
    padding: 0 8px;
    max-width: calc(100vw - 16px);
    justify-content: center;
  }
  
  .floating-btn {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
  }
  
  .floating-btn svg {
    width: 16px;
    height: 16px;
  }
}

/* Evitar interferencia con otros elementos - Solo para tablets y desktop */
@media (min-width: 769px) and (max-width: 1024px) {
  .floating-buttons {
    left: 15px;
  }
}

/* Accesibilidad */
@media (prefers-reduced-motion: reduce) {
  .floating-btn {
    animation: none;
    transition: none;
  }
  
  .floating-btn:hover {
    transform: none;
  }
  
  .btn-tooltip {
    transition: opacity 0.2s ease;
  }
}

/* Focus states para accesibilidad */
.floating-btn:focus {
  outline: 2px solid #fff;
  outline-offset: 2px;
}

  .floating-btn:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .booking-modal.hidden { display: none; }
  .booking-modal { position: fixed; inset: 0; z-index: 2000; display: grid; place-items: center; }
  .booking-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.55); backdrop-filter: blur(2px); }
  .booking-dialog { position: relative; width: min(940px, 94vw); height: min(760px, calc(100dvh - 24px)); background: #fff; border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,0.35); overflow: hidden; display: grid; grid-template-rows: auto 1fr; }
  .booking-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; background: var(--floating-primary); color: #fff; }
  .booking-header h3 { margin: 0; font-size: 1rem; font-weight: 700; letter-spacing: 0.2px; }
  .booking-close { background: rgba(255,255,255,0.2); color: #fff; border: none; border-radius: 8px; width: 32px; height: 32px; font-size: 20px; line-height: 1; cursor: pointer; transition: background 0.2s ease; }
  .booking-close:hover { background: rgba(255,255,255,0.3); }
  .booking-body { height: 100%; overflow-y: auto; -webkit-overflow-scrolling: touch; }
  .booking-frame { width: 100%; height: 100%; min-height: 640px; border: 0; overflow: auto; }
  @media (max-width: 768px) {
    .booking-modal { place-items: end center; }
    .booking-dialog { width: 100vw; height: 100dvh; max-height: 100dvh; border-radius: 0; }
    .booking-header { position: absolute; inset: 0 auto auto 0; width: 100%; padding: 0; background: transparent; pointer-events: none; z-index: 5; }
    .booking-header h3 { display: none; }
    .booking-close {
      position: absolute;
      top: max(10px, env(safe-area-inset-top));
      right: 10px;
      width: 40px;
      height: 40px;
      border-radius: 999px;
      background: rgba(0,0,0,0.55);
      backdrop-filter: blur(4px);
      pointer-events: auto;
    }
    .booking-body { overflow-y: auto; }
    .booking-frame { min-height: 100dvh; }
  }
  @media (max-width: 420px) {
    .booking-close { width: 38px; height: 38px; }
    .booking-frame { min-height: 100dvh; }
  }
</style>

<script>
// ==========================================================================
// FLOATING BUTTONS JAVASCRIPT — Funcionalidad mejorada
// ==========================================================================

document.addEventListener('DOMContentLoaded', function() {
  const floatingButtons = document.querySelector('.floating-buttons');
  
  if (!floatingButtons) return;
  
  // Mejorar la experiencia en dispositivos táctiles
  const buttons = floatingButtons.querySelectorAll('.floating-btn');
  
  buttons.forEach(button => {
    // Agregar efecto de ripple en dispositivos táctiles
    button.addEventListener('touchstart', function(e) {
      const ripple = document.createElement('div');
      ripple.style.cssText = `
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.3);
        transform: scale(0);
        animation: ripple 0.6s linear;
        pointer-events: none;
      `;
      
      const rect = button.getBoundingClientRect();
      const size = Math.max(rect.width, rect.height);
      ripple.style.width = ripple.style.height = size + 'px';
      ripple.style.left = (e.touches[0].clientX - rect.left - size / 2) + 'px';
      ripple.style.top = (e.touches[0].clientY - rect.top - size / 2) + 'px';
      
      button.appendChild(ripple);
      
      setTimeout(() => {
        ripple.remove();
      }, 600);
    });
    
    // Mejorar tooltips en dispositivos móviles
    let tooltipTimeout;
    
    button.addEventListener('touchstart', function() {
      const tooltip = button.querySelector('.btn-tooltip');
      if (tooltip && window.innerWidth <= 768) {
        clearTimeout(tooltipTimeout);
        tooltip.style.opacity = '1';
        tooltip.style.visibility = 'visible';
        
        tooltipTimeout = setTimeout(() => {
          tooltip.style.opacity = '0';
          tooltip.style.visibility = 'hidden';
        }, 2000);
      }
    });
  });
  
  // Ocultar botones cuando se hace scroll hacia abajo rápidamente (opcional)
  let lastScrollY = window.scrollY;
  let ticking = false;
  
  function updateButtonsVisibility() {
    const currentScrollY = window.scrollY;
    const scrollDifference = Math.abs(currentScrollY - lastScrollY);
    
    // Solo aplicar transform en desktop (no en móviles)
    if (window.innerWidth > 768) {
      // Solo ocultar si el scroll es muy rápido (más de 100px)
      if (scrollDifference > 100) {
        if (currentScrollY > lastScrollY) {
          // Scrolling down - mantener visible (no ocultar)
          floatingButtons.style.transform = 'translateY(-50%)';
        } else {
          // Scrolling up - asegurar que esté visible
          floatingButtons.style.transform = 'translateY(-50%)';
        }
      }
    } else {
      // En móviles, no aplicar ningún transform para mantener posición bottom fija
      floatingButtons.style.transform = '';
    }
    
    lastScrollY = currentScrollY;
    ticking = false;
  }
  
  function requestTick() {
    if (!ticking) {
      requestAnimationFrame(updateButtonsVisibility);
      ticking = true;
    }
  }
  
  window.addEventListener('scroll', requestTick, { passive: true });
});

// Agregar estilos para el efecto ripple
const rippleStyles = document.createElement('style');
rippleStyles.textContent = `
  @keyframes ripple {
    to {
      transform: scale(4);
      opacity: 0;
    }
  }
`;
document.head.appendChild(rippleStyles);
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const openBtn = document.querySelector('.booking-btn');
  const modal = document.getElementById('booking-modal');
  const closeBtn = modal ? modal.querySelector('.booking-close') : null;
  const backdrop = modal ? modal.querySelector('.booking-backdrop') : null;
  const bookingFrame = modal ? modal.querySelector('.booking-frame') : null;
  if (openBtn && modal) {
    function open() {
      if (bookingFrame && bookingFrame.dataset.src && bookingFrame.src === 'about:blank') {
        bookingFrame.src = bookingFrame.dataset.src;
      }
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      modal.classList.add('hidden');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    openBtn.addEventListener('click', open);
    const triggers = document.querySelectorAll('[data-open-booking-modal]');
    triggers.forEach((el) => {
      el.addEventListener('click', function(e) { e.preventDefault(); open(); });
    });
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (backdrop) backdrop.addEventListener('click', close);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });
  }
});
</script>
