---
import { t, getCurrentLanguage } from '../i18n/index.ts';

const currentLang = getCurrentLanguage();

const FEATURES = [
  { key: 'free_consultation', href: '/formulario',                 icon: '/assets/icons/consulta-cero.png' },
  { key: 'free_transport',    href: '/services#transporte-gratis', icon: '/assets/icons/transporte.png' },
  { key: 'same_day',          href: '/schedule',                   icon: '/assets/icons/mismo-dia.png' },
  { key: 'legal_guidance',    href: '/lawyer-approved',            icon: '/assets/icons/legal.png' },
  { key: 'xray',              href: '/services#radiografias',      icon: '/assets/icons/xray.png' },
  { key: 'languages',         href: '/services#bilingue',          icon: '/assets/icons/idiomas.png' },
];
---

<section class="feat" aria-label={t('feature_icons.aria_label', currentLang)} data-feat>
  <div class="feat-inner">
    <header class="feat-head">
      <span class="feat-eyebrow" data-i18n="feature_icons.eyebrow">{t('feature_icons.eyebrow', currentLang)}</span>
      <h2 class="feat-title" data-i18n="feature_icons.title">{t('feature_icons.title', currentLang)}</h2>
    </header>

    <div class="feat-grid" role="list">
      {FEATURES.map((f) => (
        <a
          class="feat-card"
          href={f.href}
          role="listitem"
          data-i18n-aria-label={`feature_icons.items.${f.key}.aria_label`}
          aria-label={t(`feature_icons.items.${f.key}.aria_label`, currentLang)}
        >
          <span class="feat-icon" aria-hidden="true">
            <img src={f.icon} alt="" loading="lazy" decoding="async" />
          </span>
          <span class="feat-text" data-i18n={`feature_icons.items.${f.key}.title`}>
            {t(`feature_icons.items.${f.key}.title`, currentLang)}
          </span>
          <svg class="feat-arrow" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
            <path d="M5 12h14m0 0l-5-5m5 5l-5 5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* ==========================================================================
     FEATURE ICONS — mobile-first | scroll horizontal en mobile | grid en desktop
     ========================================================================== */
  .feat {
    background: var(--c-purple-900);
    padding: clamp(2.5rem, 6vw, 4rem) 0;
    color: #fff;
    position: relative;
  }

  .feat-inner {
    max-width: var(--content-max);
    margin: 0 auto;
  }

  /* === Header === */
  .feat-head {
    text-align: center;
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
    padding: 0 1rem;
  }
  .feat-eyebrow {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-rose);
    margin-bottom: 0.5rem;
  }
  .feat-title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(1.4rem, 4vw, 2rem);
    line-height: 1.2;
    margin: 0;
    color: #fff;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  /* === Grid / Track ===
     Mobile: scroll horizontal con snap (2.4 cards visibles)
     Tablet+ : grid real
  */
  .feat-grid {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 42%;
    gap: 0.75rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.5rem clamp(0.85rem, 4vw, 1.5rem);
  }
  .feat-grid::-webkit-scrollbar { display: none; }

  /* === Card === */
  .feat-card {
    position: relative;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.85rem;
    padding: 1.25rem 0.85rem 1.1rem;
    background: #fff;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    text-decoration: none;
    color: var(--text-primary);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.28s ease, border-color 0.25s ease;
    will-change: transform;
    overflow: hidden;
    min-height: 158px;
  }

  /* Accent superior animado (línea rosa de marca) */
  .feat-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--c-rose);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .feat-card:hover::before,
  .feat-card:focus-visible::before { transform: scaleX(1); }

  .feat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.25);
    border-color: rgba(186, 147, 194, 0.5);
  }

  /* === Icono === */
  .feat-icon {
    flex: 0 0 auto;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--c-purple);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 14px rgba(122, 46, 135, 0.32);
    transition: transform 0.32s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.25s ease;
  }
  .feat-icon img {
    width: 60%;
    height: 60%;
    object-fit: contain;
    filter: brightness(0) invert(1);
    pointer-events: none;
    transition: transform 0.3s ease;
  }
  .feat-card:hover .feat-icon {
    background: var(--c-purple-700);
    transform: scale(1.06) rotate(-4deg);
  }
  .feat-card:hover .feat-icon img { transform: scale(1.05); }

  /* === Texto === */
  .feat-text {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.88rem;
    line-height: 1.3;
    color: var(--text-primary);
    text-wrap: balance;
    flex: 1 1 auto;
    display: flex;
    align-items: center;
  }

  /* === Flecha (visible en hover) === */
  .feat-arrow {
    color: var(--c-purple);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.22s ease, transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .feat-card:hover .feat-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* === Entrance (Motion lo dispara, este es estado inicial) === */
  .feat-card { opacity: 1; }
  .feat[data-feat]:not(.in-view) .feat-card {
    opacity: 0;
    transform: translateY(20px);
  }

  /* ============== BREAKPOINTS ============== */
  @media (min-width: 480px) {
    .feat-grid { grid-auto-columns: 32%; }
  }
  @media (min-width: 640px) {
    .feat-grid {
      grid-auto-flow: row;
      grid-template-columns: repeat(3, 1fr);
      grid-auto-columns: auto;
      overflow: visible;
      padding: 0 1rem;
      gap: 1rem;
    }
    .feat-card { min-height: 170px; }
  }
  @media (min-width: 1024px) {
    .feat-grid {
      grid-template-columns: repeat(6, 1fr);
      gap: 0.85rem;
      padding: 0 1.25rem;
    }
    .feat-card { padding: 1.4rem 0.9rem 1.2rem; min-height: 190px; }
    .feat-icon { width: 60px; height: 60px; }
    .feat-text { font-size: 0.92rem; }
  }
  @media (min-width: 1280px) {
    .feat-grid { gap: 1rem; padding: 0 1.5rem; }
    .feat-card { padding: 1.5rem 1rem 1.25rem; }
    .feat-icon { width: 64px; height: 64px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .feat-card, .feat-icon, .feat-arrow, .feat-card::before {
      transition: none !important;
    }
  }
</style>

<script>
  import { animate, inView, stagger } from 'motion';

  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector<HTMLElement>('[data-feat]');
    if (!section) return;

    const cards = Array.from(section.querySelectorAll<HTMLElement>('.feat-card'));
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const animateAny = animate as unknown as (...args: any[]) => any;

    if (reducedMotion) {
      section.classList.add('in-view');
      return;
    }

    /* Reveal staggered cuando la sección entra al viewport */
    inView(
      section,
      () => {
        section.classList.add('in-view');
        try {
          animateAny(
            cards,
            { opacity: [0, 1], y: [20, 0] },
            { duration: 0.5, delay: stagger(0.07), easing: [0.22, 1, 0.36, 1] }
          );
        } catch {
          cards.forEach((c) => { c.style.opacity = '1'; c.style.transform = 'none'; });
        }
      },
      { amount: 0.15 }
    );
  });
</script>
