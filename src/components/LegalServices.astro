---
/**
 * LegalServices.astro — Rediseño moderno con animaciones y efectos interactivos
 * - Nuevo layout con cards flotantes y efectos de profundidad
 * - Animaciones suaves y transiciones elegantes
 * - Diseño responsivo con grid moderno
 */
import { t, getCurrentLanguage } from '../i18n/index.ts';

const currentLang = getCurrentLanguage();
---

<section class="legal-services-modern" aria-labelledby="ls-title">
  <div class="background-elements" aria-hidden="true">
    <div class="floating-shape shape-1"></div>
    <div class="floating-shape shape-2"></div>
    <div class="floating-shape shape-3"></div>
  </div>

  <div class="container">
    <header class="section-header">
      <div class="badge-wrapper">
        <span class="service-badge" data-i18n="legal_services.badge">{t('legal_services.badge', currentLang)}</span>
      </div>
      <h2 id="ls-title" class="main-title" data-i18n="legal_services.title">{t('legal_services.title', currentLang)}</h2>
      <p class="section-description" data-i18n="legal_services.description">
        {t('legal_services.description', currentLang)}
      </p>
    </header>

    <div class="services-grid">
      <!-- Servicio 1: Reclamo a la aseguradora -->
      <article class="service-card" data-service="insurance">
        <div class="card-glow"></div>
        <div class="card-header">
          <div class="service-number">01</div>
          <h3 class="service-title" data-i18n="legal_services.services.insurance.title">{t('legal_services.services.insurance.title', currentLang)}</h3>
        </div>
        <div class="card-content">
          <p class="service-description" data-i18n="legal_services.services.insurance.description" set:html={t('legal_services.services.insurance.description', currentLang)}>
          </p>
          <ul class="service-features" role="list">
            <li><span class="feature-dot"></span><span data-i18n="legal_services.services.insurance.features.complete_process">{t('legal_services.services.insurance.features.complete_process', currentLang)}</span></li>
            <li><span class="feature-dot"></span><span data-i18n="legal_services.services.insurance.features.evidence_monitoring">{t('legal_services.services.insurance.features.evidence_monitoring', currentLang)}</span></li>
            <li><span class="feature-dot"></span><span data-i18n="legal_services.services.insurance.features.real_time_updates">{t('legal_services.services.insurance.features.real_time_updates', currentLang)}</span></li>
          </ul>
        </div>
        <div class="card-footer">
          <a class="service-cta" href="/schedule" aria-label={t('legal_services.services.insurance.cta_label', currentLang)}>
            <span data-i18n="legal_services.cta_text">{t('legal_services.cta_text', currentLang)}</span>
            <svg class="cta-arrow" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </article>

      <!-- Servicio 2: Asistencia legal integral -->
      <article class="service-card" data-service="legal">
        <div class="card-glow"></div>
        <div class="card-header">
          <div class="service-number">02</div>
          <h3 class="service-title" data-i18n="legal_services.services.legal.title">{t('legal_services.services.legal.title', currentLang)}</h3>
        </div>
        <div class="card-content">
          <p class="service-description" data-i18n="legal_services.services.legal.description" set:html={t('legal_services.services.legal.description', currentLang)}>
          </p>
          <ul class="service-features" role="list">
            <li><span class="feature-dot"></span><span data-i18n="legal_services.services.legal.features.lawyer_catalog">{t('legal_services.services.legal.features.lawyer_catalog', currentLang)}</span></li>
            <li><span class="feature-dot"></span><span data-i18n="legal_services.services.legal.features.direct_communication">{t('legal_services.services.legal.features.direct_communication', currentLang)}</span></li>
            <li><span class="feature-dot"></span><span data-i18n="legal_services.services.legal.features.rights_defense">{t('legal_services.services.legal.features.rights_defense', currentLang)}</span></li>
          </ul>
        </div>
        <div class="card-footer">
          <a class="service-cta" href="/schedule" aria-label={t('legal_services.services.legal.cta_label', currentLang)}>
            <span data-i18n="legal_services.cta_text">{t('legal_services.cta_text', currentLang)}</span>
            <svg class="cta-arrow" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </article>

      <!-- Servicio 3: Acuerdos y representación -->
      <article class="service-card" data-service="representation">
        <div class="card-glow"></div>
        <div class="card-header">
          <div class="service-number">03</div>
          <h3 class="service-title" data-i18n="legal_services.services.representation.title">{t('legal_services.services.representation.title', currentLang)}</h3>
        </div>
        <div class="card-content">
          <p class="service-description" data-i18n="legal_services.services.representation.description" set:html={t('legal_services.services.representation.description', currentLang)}>
          </p>
          <ul class="service-features" role="list">
            <li><span class="feature-dot"></span><span data-i18n="legal_services.services.representation.features.clear_negotiations">{t('legal_services.services.representation.features.clear_negotiations', currentLang)}</span></li>
            <li><span class="feature-dot"></span><span data-i18n="legal_services.services.representation.features.adequate_treatment">{t('legal_services.services.representation.features.adequate_treatment', currentLang)}</span></li>
            <li><span class="feature-dot"></span><span data-i18n="legal_services.services.representation.features.professional_guidance">{t('legal_services.services.representation.features.professional_guidance', currentLang)}</span></li>
          </ul>
        </div>
        <div class="card-footer">
          <a class="service-cta" href="/schedule" aria-label={t('legal_services.services.representation.cta_label', currentLang)}>
            <span data-i18n="legal_services.cta_text">{t('legal_services.cta_text', currentLang)}</span>
            <svg class="cta-arrow" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </article>
    </div>
  </div>

  <style>
    /* Tipografías modernas */
    @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800;900&family=Source+Sans+3:wght@400;500;600;700;800;900&display=swap');

    :root {
      --brand: #BA93C2;
      --brand-700: #7f4b8a;
      --brand-800: #7A2E87;
      --brand-900: #6B2575;
      --ink: #1A1D2A;
      --muted: #6B6F85;
      --surface: #ffffff;
      --surface-2: #F7F2FA;
      --line: rgba(26,29,42,.12);
      --ease: cubic-bezier(0.4, 0, 0.2, 1);
      --ease-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .legal-services-modern {
      position: relative;
      isolation: isolate;
      color: var(--ink);
      padding: 80px 0 100px;
      background: linear-gradient(135deg, #fafbfc 0%, #f8f9fa 100%);
      overflow: hidden;
    }

    /* Elementos de fondo flotantes */
    .background-elements {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .floating-shape {
      position: absolute;
      border-radius: 50%;
      filter: blur(60px);
      opacity: 0.4;
      animation: float 20s ease-in-out infinite;
    }

    .shape-1 {
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, var(--brand) 0%, transparent 70%);
      top: -10%;
      left: -5%;
      animation-delay: 0s;
    }

    .shape-2 {
      width: 250px;
      height: 250px;
      background: radial-gradient(circle, var(--brand-700) 0%, transparent 70%);
      top: 20%;
      right: -8%;
      animation-delay: -7s;
    }

    .shape-3 {
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, var(--brand-800) 0%, transparent 70%);
      bottom: -5%;
      left: 50%;
      animation-delay: -14s;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      33% { transform: translateY(-20px) rotate(120deg); }
      66% { transform: translateY(10px) rotate(240deg); }
    }

    /* Header moderno */
    .section-header {
      position: relative;
      z-index: 1;
      text-align: center;
      margin-bottom: 60px;
      animation: fadeInUp 0.8s var(--ease);
    }

    .badge-wrapper {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 20px;
    }

    .service-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      background: var(--brand-800);
      color: white;
      border-radius: 50px;
      font-family: 'Manrope', system-ui, sans-serif;
      font-weight: 600;
      font-size: 14px;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      box-shadow: 0 4px 12px rgba(122, 46, 135, 0.3);
      transition: all 0.3s var(--ease);
    }

    .service-badge:hover {
      transform: translateY(-2px);
      background: var(--brand-700);
      box-shadow: 0 8px 20px rgba(122, 46, 135, 0.4);
    }

    .main-title {
      font-family: 'Manrope', system-ui, sans-serif;
      font-weight: 800;
      font-size: clamp(32px, 5vw, 48px);
      line-height: 1.1;
      margin: 0 0 16px;
      background: linear-gradient(135deg, var(--ink) 0%, var(--brand-800) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .section-description {
      font-family: 'Source Sans 3', system-ui, sans-serif;
      font-size: 20px;
      line-height: 1.6;
      color: var(--muted);
      margin: 0;
      max-width: 650px;
      margin-inline: auto;
      font-weight: 400;
      text-align: justify;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }


    /* Grid moderno */
    .services-grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 32px;
      margin-top: 40px;
    }

    /* Tarjetas de servicios modernas */
    .service-card {
      position: relative;
      display: flex;
      flex-direction: column;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(186, 147, 194, 0.2);
      border-radius: 24px;
      padding: 32px;
      min-height: 380px;
      overflow: hidden;
      transition: all 0.4s var(--ease);
      animation: slideInUp 0.6s var(--ease) forwards;
      opacity: 0;
      transform: translateY(40px);
    }

    .service-card:nth-child(1) { animation-delay: 0.1s; }
    .service-card:nth-child(2) { animation-delay: 0.2s; }
    .service-card:nth-child(3) { animation-delay: 0.3s; }

    .service-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: var(--brand-800);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.4s var(--ease);
    }

    .service-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(122, 46, 135, 0.15);
      border-color: rgba(186, 147, 194, 0.4);
    }

    .service-card:hover::before {
      transform: scaleX(1);
    }

    .card-glow {
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(186, 147, 194, 0.1) 0%, transparent 70%);
      opacity: 0;
      transition: opacity 0.4s var(--ease);
      pointer-events: none;
    }

    .service-card:hover .card-glow {
      opacity: 1;
    }

    .card-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 20px;
    }

    .service-number {
      display: grid;
      place-items: center;
      width: 72px;
      height: 72px;
      border-radius: 20px;
      background: linear-gradient(135deg, var(--brand-800) 0%, var(--brand-700) 100%);
      color: white;
      font-family: 'Manrope', system-ui, sans-serif;
      font-weight: 800;
      font-size: 24px;
      flex: 0 0 72px;
      transition: all 0.3s var(--ease);
      box-shadow: 0 4px 12px rgba(122, 46, 135, 0.3);
      position: relative;
      overflow: hidden;
    }

    .service-number::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
      transition: left 0.5s var(--ease);
    }

    .service-card:hover .service-number {
      transform: scale(1.05) rotate(5deg);
      box-shadow: 0 8px 20px rgba(122, 46, 135, 0.4);
    }

    .service-card:hover .service-number::before {
      left: 100%;
    }

    .service-title {
      margin: 0;
      font-family: 'Manrope', system-ui, sans-serif;
      font-weight: 800;
      font-size: 22px;
      line-height: 1.3;
      color: var(--ink);
    }

    .card-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .service-description {
      margin: 0;
      color: var(--muted);
      font-family: 'Source Sans 3', system-ui, sans-serif;
      font-weight: 500;
      line-height: 1.6;
      font-size: 16px;
      text-align: justify;
    }

    .service-features {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .service-features li {
      position: relative;
      padding-left: 24px;
      font-family: 'Source Sans 3', system-ui, sans-serif;
      font-weight: 600;
      font-size: 15px;
      line-height: 1.4;
      color: var(--muted);
      text-align: justify;
    }

    .feature-dot {
      position: absolute;
      left: 0;
      top: 8px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--brand-800);
      box-shadow: 0 0 0 3px rgba(186, 147, 194, 0.2);
    }

    .card-footer {
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid rgba(186, 147, 194, 0.1);
    }

    .service-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 20px;
      background: var(--brand-800);
      color: white;
      text-decoration: none;
      border-radius: 12px;
      font-family: 'Manrope', system-ui, sans-serif;
      font-weight: 600;
      font-size: 14px;
      transition: all 0.3s var(--ease);
      box-shadow: 0 4px 12px rgba(122, 46, 135, 0.3);
    }

    .service-cta:hover {
      transform: translateY(-2px);
      background: var(--brand-700);
      box-shadow: 0 8px 20px rgba(122, 46, 135, 0.4);
    }

    .cta-arrow {
      width: 16px;
      height: 16px;
      transition: transform 0.3s var(--ease);
    }

    .service-cta:hover .cta-arrow {
      transform: translateX(4px);
    }

    @keyframes slideInUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Responsive */
    @media (max-width: 768px) {
      .services-grid {
        grid-template-columns: 1fr;
        gap: 24px;
      }
      
      .service-card {
        padding: 24px;
        min-height: auto;
      }
      
      .service-number {
        width: 64px;
        height: 64px;
        font-size: 20px;
      }
      
      .service-title {
        font-size: 20px;
      }
    }
  </style>
</section>
