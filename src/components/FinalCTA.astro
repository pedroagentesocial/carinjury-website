---
import { t, getCurrentLanguage } from '../i18n/index.ts';

const currentLang = getCurrentLanguage();
---

<section class="final-cta-elegant" aria-labelledby="cta-title">
  <!-- Elementos decorativos sutiles -->
  <div class="background-elements">
    <div class="floating-accent floating-accent-1"></div>
    <div class="floating-accent floating-accent-2"></div>
    <div class="floating-accent floating-accent-3"></div>
  </div>
  
  <div class="container">
    <div class="cta-wrapper">
      <div class="content-main">
        <header class="cta-header">
          <h2 id="cta-title" class="cta-title" set:html={t('final_cta.title', currentLang)} data-i18n="final_cta.title">
          </h2>
          <p class="cta-subtitle" data-i18n="final_cta.subtitle">{t('final_cta.subtitle', currentLang)}</p>
        </header>

        <div class="cta-actions">
          <a href="/schedule" class="btn-primary" aria-label={t('final_cta.schedule_label', currentLang)}>
            <span class="btn-content" data-i18n="final_cta.schedule_button">{t('final_cta.schedule_button', currentLang)}</span>
            <div class="btn-shine"></div>
          </a>
          <a href="tel:+13852428571" class="btn-secondary">
            <svg class="phone-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <span class="phone-number" data-i18n="final_cta.phone_number">{t('final_cta.phone_number', currentLang)}</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <style>
    :root {
      --brand: #BA93C2;
      --brand-700: #7f4b8a;
      --brand-800: #6b3d75;
      --brand-light: #d4b8dc;
      --ink: #1A1D2A;
      --white: #ffffff;
      --gray-100: #f8fafc;
      --gray-200: #e2e8f0;
      --gray-800: #1e293b;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .final-cta-elegant {
      position: relative;
      padding: 40px 0;
      overflow: hidden;
      background: #f8fafc;
      min-height: 40vh;
      display: flex;
      align-items: center;
    }

    /* ELEMENTOS DECORATIVOS SUTILES */
    .background-elements {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }

    .floating-accent {
      position: absolute;
      width: 60px;
      height: 60px;
      background: var(--brand);
      border-radius: 50%;
      opacity: 0.1;
      animation: gentleFloat 8s ease-in-out infinite;
    }

    .floating-accent-1 {
      top: 15%;
      right: 10%;
      animation-delay: 0s;
    }

    .floating-accent-2 {
      bottom: 20%;
      left: 8%;
      width: 40px;
      height: 40px;
      animation-delay: 2s;
    }

    .floating-accent-3 {
      top: 60%;
      right: 25%;
      width: 80px;
      height: 80px;
      animation-delay: 4s;
    }

    @keyframes gentleFloat {
      0%, 100% { transform: translateY(0px); opacity: 0.1; }
      50% { transform: translateY(-15px); opacity: 0.2; }
    }

    /* CONTENEDOR PRINCIPAL ELEGANTE */
    .cta-wrapper {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 40px 30px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(186, 147, 194, 0.2);
      box-shadow: 
        0 20px 40px rgba(186, 147, 194, 0.15),
        0 8px 16px rgba(0, 0, 0, 0.1);
      transition: all 0.3s ease;
      z-index: 10;
    }

    .cta-wrapper:hover {
      transform: translateY(-5px);
      box-shadow: 
        0 25px 50px rgba(186, 147, 194, 0.2),
        0 12px 24px rgba(0, 0, 0, 0.15);
    }

    /* CONTENIDO PRINCIPAL */
    .content-main {
      position: relative;
      z-index: 5;
      max-width: 600px;
    }

    /* HEADER DEL CTA */
    .cta-header {
      margin-bottom: 24px;
    }

    /* TÍTULO ELEGANTE */
    .cta-title {
      margin: 0 0 12px;
      font-family: 'Manrope', system-ui, sans-serif;
      font-weight: 800;
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      line-height: 1.2;
      text-align: center;
      color: var(--brand-800);
      animation: subtleGlow 4s ease-in-out infinite;
    }

    @keyframes subtleGlow {
      0%, 100% { opacity: 0.9; }
      50% { opacity: 1; }
    }

    /* SUBTÍTULO ELEGANTE */
    .cta-subtitle {
      margin: 0 0 24px;
      font-family: 'Source Sans 3', system-ui, sans-serif;
      font-weight: 500;
      font-size: clamp(1rem, 2vw, 1.2rem);
      color: var(--gray-800);
      opacity: 0.8;
      line-height: 1.4;
    }

    /* ACCIONES DEL CTA */
    .cta-actions {
      display: flex;
      gap: 16px;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
    }

    /* BOTÓN PRINCIPAL */
    .btn-primary {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 28px;
      border-radius: 10px;
      text-decoration: none;
      font-family: 'Manrope', system-ui, sans-serif;
      font-weight: 700;
      font-size: 1rem;
      color: var(--white);
      background: #7A2E87;
      border: none;
      box-shadow: 
        0 6px 20px rgba(122, 46, 135, 0.3),
        0 3px 6px rgba(0, 0, 0, 0.1);
      transition: all 0.3s ease;
      overflow: hidden;
      cursor: pointer;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      background: #8A3E97;
      box-shadow: 
        0 12px 32px rgba(122, 46, 135, 0.4),
        0 6px 12px rgba(0, 0, 0, 0.15);
    }

    .btn-shine {
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: rgba(255, 255, 255, 0.2);
      transition: left 0.5s ease;
    }

    .btn-primary:hover .btn-shine {
      left: 100%;
    }

    .btn-content {
      position: relative;
      z-index: 2;
    }

    /* BOTÓN SECUNDARIO (TELÉFONO) */
    .btn-secondary {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      border-radius: 10px;
      text-decoration: none;
      font-family: 'Manrope', system-ui, sans-serif;
      font-weight: 600;
      background: var(--white);
      border: 2px solid #7A2E87;
      color: #7A2E87;
      transition: all 0.3s ease;
      overflow: hidden;
    }

    .btn-secondary:hover {
      background: #7A2E87;
      color: var(--white);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(122, 46, 135, 0.3);
    }

    .phone-icon {
      width: 18px;
      height: 18px;
      animation: gentlePulse 3s ease-in-out infinite;
    }

    @keyframes gentlePulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }

    .phone-number {
      font-size: 0.95rem;
      letter-spacing: 0.3px;
    }

    /* RESPONSIVE DESIGN */
    @media (max-width: 768px) {
      .final-cta-elegant {
        padding: 30px 0;
        min-height: 35vh;
      }

      .container {
        padding: 0 16px;
      }

      .cta-wrapper {
        padding: 24px 20px;
      }

      .cta-header {
        margin-bottom: 16px;
      }

      .cta-subtitle {
        font-size: 0.95rem;
        margin-bottom: 20px;
      }

      .cta-actions {
        flex-direction: column;
        gap: 12px;
      }

      .btn-primary,
      .btn-secondary {
        width: 100%;
        justify-content: center;
      }
    }

    @media (max-width: 480px) {
      .final-cta-elegant {
        padding: 24px 0;
      }

      .cta-wrapper {
        padding: 20px 16px;
      }

      .cta-header {
        margin-bottom: 12px;
      }

      .btn-primary {
        padding: 12px 24px;
        font-size: 0.95rem;
      }

      .btn-secondary {
        padding: 10px 20px;
        font-size: 0.9rem;
      }
    }
  </style>
</section>
