---
import { t, getCurrentLanguage } from '../i18n/index.ts';

const currentLang = getCurrentLanguage();
---

<section class="process" aria-labelledby="process-title">
  <div class="bg-decoration" aria-hidden="true">
    <div class="floating-circle circle-1"></div>
    <div class="floating-circle circle-2"></div>
    <div class="floating-circle circle-3"></div>
  </div>
  
  <div class="container">
    <div class="head fade-in-up">
      <div class="title-wrapper">
        <div class="subtitle" aria-label={t('process_steps.section_label', currentLang)} data-i18n="process_steps.subtitle">{t('process_steps.subtitle', currentLang)}</div>
        <h2 id="process-title" data-i18n="process_steps.title">{t('process_steps.title', currentLang)}</h2>
        <div class="title-underline" aria-hidden="true"></div>
      </div>
      <p class="lede" data-i18n="process_steps.description">{t('process_steps.description', currentLang)}</p>
    </div>
    
    <div class="steps-wrapper">
      <div class="progress-line">
        <div class="progress-fill"></div>
      </div>
      
      <ol class="steps" role="list" aria-label={t('process_steps.steps_label', currentLang)}>
        <li class="step step-animate" data-step="1" role="listitem">
          <div class="step-content">
            <div class="badge-wrapper">
              <div class="badge" role="img" aria-label={`${t('process_steps.step_label', currentLang)} 1`}>
                <div class="badge-glow" aria-hidden="true"></div>
                <span class="badge-number" aria-hidden="true">1</span>
              </div>
            </div>
            <div class="body">
              <div class="step-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14,2 14,8 20,8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10,9 9,9 8,9"></polyline>
                </svg>
              </div>
              <h3 data-i18n="process_steps.steps.step1.title">{t('process_steps.steps.step1.title', currentLang)}</h3>
              <p data-i18n="process_steps.steps.step1.description">{t('process_steps.steps.step1.description', currentLang)}</p>
            </div>
            <div class="step-arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <polyline points="9,18 15,12 9,6"></polyline>
              </svg>
            </div>
          </div>
        </li>
        
        <li class="step step-animate" data-step="2" role="listitem">
          <div class="step-content">
            <div class="badge-wrapper">
              <div class="badge" role="img" aria-label={`${t('process_steps.step_label', currentLang)} 2`}>
                <div class="badge-glow" aria-hidden="true"></div>
                <span class="badge-number" aria-hidden="true">2</span>
              </div>
            </div>
            <div class="body">
              <div class="step-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <circle cx="11" cy="11" r="8"></circle>
                  <path d="m21 21-4.35-4.35"></path>
                </svg>
              </div>
              <h3 data-i18n="process_steps.steps.step2.title">{t('process_steps.steps.step2.title', currentLang)}</h3>
              <p data-i18n="process_steps.steps.step2.description">{t('process_steps.steps.step2.description', currentLang)}</p>
            </div>
            <div class="step-arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <polyline points="9,18 15,12 9,6"></polyline>
              </svg>
            </div>
          </div>
        </li>
        
        <li class="step step-animate" data-step="3" role="listitem">
          <div class="step-content">
            <div class="badge-wrapper">
              <div class="badge" role="img" aria-label={`${t('process_steps.step_label', currentLang)} 3`}>
                <div class="badge-glow" aria-hidden="true"></div>
                <span class="badge-number" aria-hidden="true">3</span>
              </div>
            </div>
            <div class="body">
              <div class="step-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                  <path d="m2 17 10 5 10-5"></path>
                  <path d="m2 12 10 5 10-5"></path>
                </svg>
              </div>
              <h3 data-i18n="process_steps.steps.step3.title">{t('process_steps.steps.step3.title', currentLang)}</h3>
              <p data-i18n="process_steps.steps.step3.description">{t('process_steps.steps.step3.description', currentLang)}</p>
            </div>
            <div class="step-arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <polyline points="9,18 15,12 9,6"></polyline>
              </svg>
            </div>
          </div>
        </li>
        
        <li class="step step-animate" data-step="4" role="listitem">
          <div class="step-content">
            <div class="badge-wrapper">
              <div class="badge" role="img" aria-label={`${t('process_steps.step_label', currentLang)} 4`}>
                <div class="badge-glow" aria-hidden="true"></div>
                <span class="badge-number" aria-hidden="true">4</span>
              </div>
            </div>
            <div class="body">
              <div class="step-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M12 2v20m8-10H4"></path>
                </svg>
              </div>
              <h3 data-i18n="process_steps.steps.step4.title">{t('process_steps.steps.step4.title', currentLang)}</h3>
              <p data-i18n="process_steps.steps.step4.description">{t('process_steps.steps.step4.description', currentLang)}</p>
            </div>
          </div>
        </li>
      </ol>
    </div>
  </div>

  <style>
    :root {
      --primary-purple: #7A2E87;
      --secondary-purple: #806AAA;
      --light-purple: #BA93C2;
      --dark-purple: #5A1B63;
      --text-dark: #1A1D2A;
      --text-medium: #4A5568;
      --text-muted: #718096;
      --light-bg: #F7FAFC;
      --white: #ffffff;
      --glass-bg: rgba(255, 255, 255, 0.8);
      --glass-border: rgba(122, 46, 135, 0.1);
      --shadow-light: rgba(0, 0, 0, 0.1);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .process {
      position: relative;
      padding: 100px 0;
      background: linear-gradient(135deg, var(--white) 0%, var(--light-bg) 50%, #F1F5F9 100%);
      overflow: hidden;
      isolation: isolate;
    }

    /* Decorative background elements */
    .bg-decoration {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      pointer-events: none;
      z-index: 0;
    }

    .floating-circle {
      position: absolute;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(122, 46, 135, 0.05) 0%, transparent 70%);
      animation: float 6s ease-in-out infinite;
    }

    .circle-1 {
      width: 200px;
      height: 200px;
      top: 10%;
      left: 5%;
      animation-delay: 0s;
    }

    .circle-2 {
      width: 150px;
      height: 150px;
      top: 60%;
      right: 10%;
      animation-delay: 2s;
    }

    .circle-3 {
      width: 100px;
      height: 100px;
      top: 30%;
      right: 20%;
      animation-delay: 4s;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(180deg); }
    }

    /* Header styles */
    .head {
      text-align: center;
      max-width: 800px;
      margin: 0 auto 80px;
      position: relative;
      z-index: 2;
    }

    .title-wrapper {
      margin-bottom: 20px;
    }

    .subtitle {
      display: inline-block;
      font-family: 'Source Sans 3', system-ui, sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--primary-purple);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 10px;
      opacity: 0;
      animation: fadeInUp 0.8s ease-out 0.2s forwards;
    }

    .head h2 {
      font-family: 'Manrope', system-ui, sans-serif;
      font-weight: 900;
      font-size: 3.2rem;
      color: var(--text-dark);
      margin: 0;
      line-height: 1.1;
      opacity: 0;
      animation: fadeInUp 0.8s ease-out 0.4s forwards;
    }

    .title-underline {
      width: 80px;
      height: 4px;
      background: linear-gradient(90deg, var(--primary-purple), var(--light-purple));
      margin: 20px auto;
      border-radius: 2px;
      opacity: 0;
      animation: scaleIn 0.6s ease-out 0.6s forwards;
    }

    .lede {
      font-family: 'Source Sans 3', system-ui, sans-serif;
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--text-medium);
      margin: 0;
      opacity: 0;
      animation: fadeInUp 0.8s ease-out 0.8s forwards;
    }

    /* Steps wrapper */
    .steps-wrapper {
      position: relative;
      z-index: 2;
    }

    .progress-line {
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      height: 3px;
      background: rgba(122, 46, 135, 0.1);
      border-radius: 2px;
      overflow: hidden;
      z-index: 1;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--primary-purple), var(--light-purple));
      width: 0;
      border-radius: 2px;
      animation: progressFill 3s ease-out 1s forwards;
    }

    @keyframes progressFill {
      to { width: 75%; }
    }

    /* Steps grid */
    .steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 30px;
      padding: 0;
      list-style: none;
      margin: 0;
      position: relative;
      z-index: 2;
    }

    @media (min-width: 1200px) {
      .steps {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    @media (max-width: 768px) {
      .steps {
        grid-template-columns: 1fr;
        gap: 40px;
      }
      .progress-line {
        display: none;
      }
      .head h2 {
        font-size: 2.5rem;
      }
      .lede {
        font-size: 1.1rem;
      }
    }

    @media (max-width: 480px) {
      .head h2 {
        font-size: 2rem;
      }
      .lede {
        font-size: 1rem;
      }
      .body {
        padding: 20px 18px;
      }
      .body h3 {
        font-size: 1.2rem;
      }
      .body p {
        font-size: 0.9rem;
      }
    }

    /* Step items */
    .step {
      opacity: 0;
      transform: translateY(50px);
    }

    .step-animate {
      animation: slideInUp 0.8s ease-out forwards;
    }

    .step[data-step="1"] { animation-delay: 1.2s; }
    .step[data-step="2"] { animation-delay: 1.4s; }
    .step[data-step="3"] { animation-delay: 1.6s; }
    .step[data-step="4"] { animation-delay: 1.8s; }

    .step-content {
      position: relative;
      height: 100%;
      transition: transform 0.3s ease;
    }

    .step-content:hover {
      transform: translateY(-10px);
    }

    /* Badge styles */
    .badge-wrapper {
      display: flex;
      justify-content: center;
      margin-bottom: 20px;
      position: relative;
      z-index: 3;
    }

    .badge {
      position: relative;
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, var(--primary-purple), var(--secondary-purple));
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10px 30px rgba(122, 46, 135, 0.2);
      transition: all 0.3s ease;
      overflow: hidden;
    }

    .badge:hover {
      transform: scale(1.1);
      box-shadow: 0 15px 40px rgba(122, 46, 135, 0.3);
    }

    .badge-number {
      font-family: 'Manrope', system-ui, sans-serif;
      font-weight: 900;
      font-size: 1.5rem;
      color: var(--white);
      position: relative;
      z-index: 2;
    }

    .badge-glow {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
      transform: translate(-50%, -50%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .badge:hover .badge-glow {
      opacity: 1;
    }

    /* Body styles */
    .body {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      padding: 30px 25px;
      height: 100%;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px var(--shadow-light);
    }

    .body:hover {
      background: var(--white);
      border-color: rgba(122, 46, 135, 0.2);
      box-shadow: 0 20px 40px rgba(122, 46, 135, 0.15);
      transform: translateY(-5px);
    }

    .body::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--primary-purple), var(--light-purple));
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .body:hover::before {
      opacity: 1;
    }

    .step-icon {
      width: 48px;
      height: 48px;
      background: rgba(122, 46, 135, 0.1);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
      transition: all 0.3s ease;
    }

    .step-icon svg {
      color: var(--primary-purple);
      transition: all 0.3s ease;
    }

    .body:hover .step-icon {
      background: rgba(122, 46, 135, 0.15);
      transform: scale(1.1);
    }

    .body:hover .step-icon svg {
      color: var(--dark-purple);
    }

    .body h3 {
      font-family: 'Manrope', system-ui, sans-serif;
      font-weight: 800;
      font-size: 1.4rem;
      color: var(--text-dark);
      margin: 0 0 15px 0;
      line-height: 1.3;
      text-align: left;
    }

    .body p {
      font-family: 'Source Sans 3', system-ui, sans-serif;
      font-weight: 500;
      font-size: 1rem;
      color: var(--text-muted);
      line-height: 1.6;
      margin: 0;
      flex-grow: 1;
      text-align: left;
    }

    .step-arrow {
      position: absolute;
      top: 50%;
      right: -15px;
      width: 30px;
      height: 30px;
      background: var(--primary-purple);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transform: translateY(-50%);
      opacity: 0.7;
      transition: all 0.3s ease;
      z-index: 4;
    }

    .step-arrow svg {
      color: var(--white);
      width: 16px;
      height: 16px;
    }

    .step:last-child .step-arrow {
      display: none;
    }

    @media (max-width: 768px) {
      .step-arrow {
        display: none;
      }
    }

    .body:hover .step-arrow {
      opacity: 1;
      transform: translateY(-50%) scale(1.1);
      box-shadow: 0 5px 15px rgba(122, 46, 135, 0.4);
    }

    /* Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideInUp {
      from {
        opacity: 0;
        transform: translateY(50px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes scaleIn {
      from {
        opacity: 0;
        transform: scaleX(0);
      }
      to {
        opacity: 1;
        transform: scaleX(1);
      }
    }

    /* Scroll-triggered animations */
    @media (prefers-reduced-motion: no-preference) {
      .fade-in-up {
        opacity: 0;
        transform: translateY(30px);
        animation: fadeInUp 0.8s ease-out forwards;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</section>
