---
/* Nav.astro — mobile-first, logo protagónico, dropdowns rediseñados, motion */
import { t, getCurrentLanguage } from '../i18n';

const currentLang = getCurrentLanguage();

const SERVICES = [
  { href: '/services#chiropractic',           key: 'nav.services_dropdown.chiropractic' },
  { href: '/services#rehabilitation',         key: 'nav.services_dropdown.rehabilitation' },
  { href: '/services#physical_therapy',       key: 'nav.services_dropdown.physical_therapy' },
  { href: '/services#hot_cold_therapy',       key: 'nav.services_dropdown.hot_cold_therapy' },
  { href: '/services#massage',                key: 'nav.services_dropdown.massage' },
  { href: '/services#ultrasound',             key: 'nav.services_dropdown.ultrasound' },
  { href: '/services#tens',                   key: 'nav.services_dropdown.tens' },
  { href: '/services#second_opinions',        key: 'nav.services_dropdown.second_opinions' },
  { href: '/services#xray',                   key: 'nav.services_dropdown.xray' },
  { href: '/services#mri',                    key: 'nav.services_dropdown.mri' },
  { href: '/services#pain_management',        key: 'nav.services_dropdown.pain_management' },
  { href: '/services#surgical_consultations', key: 'nav.services_dropdown.surgical_consultations' },
  { href: '/services#concussion',             key: 'nav.services_dropdown.concussion' },
  { href: '/services#free_transport',         key: 'nav.services_dropdown.free_transport' },
  { href: '/services#trilingual',             key: 'nav.services_dropdown.trilingual' },
];

const PATIENTS = [
  { href: '/formulario', key: 'nav.form', descKey: 'nav.form_desc' },
  { href: '/faq',        key: 'nav.frequent_questions', descKey: 'nav.frequent_questions_desc' },
];

const LOGO_SRC = '/images/logo.png';
const LOGO_ALT = 'Car Injury Clinic';
const PHONE_DISPLAY = '385-242-8571';
const PHONE_TEL = '+13852428571';
---

<nav id="main-nav" class="nav" aria-label="Navegación principal" data-nav>
  <div class="nav-bar">
    <a class="logo" href="/" aria-label="Car Injury Clinic">
      <img src={LOGO_SRC} alt={LOGO_ALT} class="logo-img" decoding="async" fetchpriority="high" />
    </a>

    <!-- MENÚ DESKTOP -->
    <ul class="nav-menu" role="menubar">
      <li role="none"><a class="nav-link" href="/" data-i18n="nav.home" role="menuitem">{t('nav.home', currentLang)}</a></li>

      <li class="dd" role="none">
        <a class="nav-link nav-link-trigger" href="/services" data-i18n="nav.services" role="menuitem" aria-haspopup="true">
          {t('nav.services', currentLang)}
          <svg class="chev" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <div class="dd-panel dd-panel-wide" role="menu">
          <div class="dd-eyebrow" data-i18n="nav.services">{t('nav.services', currentLang)}</div>
          <ul class="dd-grid">
            {SERVICES.map((s) => (
              <li role="none"><a class="dd-item" href={s.href} role="menuitem" data-i18n={s.key}>{t(s.key, currentLang)}</a></li>
            ))}
          </ul>
        </div>
      </li>

      <li role="none"><a class="nav-link" href="/lawyer-approved" data-i18n="nav.legal_assistance" role="menuitem">{t('nav.legal_assistance', currentLang)}</a></li>

      <li class="dd" role="none">
        <button class="nav-link nav-link-trigger" type="button" data-i18n="nav.patients" role="menuitem" aria-haspopup="true">
          {t('nav.patients', currentLang)}
          <svg class="chev" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="dd-panel" role="menu">
          {PATIENTS.map((p) => (
            <a class="dd-item-rich" href={p.href} role="menuitem">
              <strong data-i18n={p.key}>{t(p.key, currentLang)}</strong>
              <span class="dd-desc" data-i18n={p.descKey}>{t(p.descKey, currentLang)}</span>
            </a>
          ))}
        </div>
      </li>

      <li role="none"><a class="nav-link" href="/aboutus" data-i18n="nav.about" role="menuitem">{t('nav.about', currentLang)}</a></li>
    </ul>

    <!-- ACCIONES DERECHA -->
    <div class="nav-actions">
      <button id="language-toggle" class="btn-lang" aria-label="Cambiar idioma" type="button">
        <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" stroke="currentColor" stroke-width="2" fill="none"/>
        </svg>
        <span id="language-button-text">{currentLang === 'en' ? 'Spanish' : 'Ingles'}</span>
      </button>

      <a class="btn-phone" href={`tel:${PHONE_TEL}`} aria-label={`Llamar al ${PHONE_DISPLAY}`}>
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22 16.92v2a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 3.8 2 2 0 0 1 4.11 2h2a2 2 0 0 1 2 1.72c.12.9.31 1.78.57 2.63a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.45-1.17a2 2 0 0 1 2.11-.45c.85.26 1.73.45 2.63.57A2 2 0 0 1 22 16.92Z" fill="currentColor"/>
        </svg>
        <span class="btn-phone-num">{PHONE_DISPLAY}</span>
      </a>

      <a class="btn-cta" href="/schedule">
        <span data-i18n="nav.schedule">{t('nav.schedule', currentLang)}</span>
      </a>

      <button class="btn-burger" type="button" aria-label="Menú" aria-expanded="false" aria-controls="nav-drawer" data-burger>
        <span class="burger-line"></span>
        <span class="burger-line"></span>
        <span class="burger-line"></span>
      </button>
    </div>
  </div>

  <!-- DRAWER MOBILE -->
  <aside class="drawer" id="nav-drawer" data-drawer aria-hidden="true">
    <ul class="drawer-menu">
      <li><a class="drawer-link" href="/" data-i18n="nav.home">{t('nav.home', currentLang)}</a></li>

      <li class="drawer-dd">
        <button class="drawer-trigger" type="button" aria-expanded="false">
          <span data-i18n="nav.services">{t('nav.services', currentLang)}</span>
          <svg class="chev" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="drawer-sub-wrap">
          <ul class="drawer-sub">
            <li><a class="drawer-sub-link drawer-sub-link-all" href="/services" data-i18n="nav.services">{t('nav.services', currentLang)}</a></li>
            {SERVICES.map((s) => (
              <li><a class="drawer-sub-link" href={s.href} data-i18n={s.key}>{t(s.key, currentLang)}</a></li>
            ))}
          </ul>
        </div>
      </li>

      <li><a class="drawer-link" href="/lawyer-approved" data-i18n="nav.legal_assistance">{t('nav.legal_assistance', currentLang)}</a></li>

      <li class="drawer-dd">
        <button class="drawer-trigger" type="button" aria-expanded="false">
          <span data-i18n="nav.patients">{t('nav.patients', currentLang)}</span>
          <svg class="chev" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="drawer-sub-wrap">
          <ul class="drawer-sub">
            {PATIENTS.map((p) => (
              <li><a class="drawer-sub-link" href={p.href} data-i18n={p.key}>{t(p.key, currentLang)}</a></li>
            ))}
          </ul>
        </div>
      </li>

      <li><a class="drawer-link" href="/aboutus" data-i18n="nav.about">{t('nav.about', currentLang)}</a></li>
    </ul>

    <div class="drawer-footer">
      <a class="btn-cta drawer-cta" href="/schedule">
        <span data-i18n="nav.schedule">{t('nav.schedule', currentLang)}</span>
      </a>
      <a class="drawer-call" href={`tel:${PHONE_TEL}`}>
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22 16.92v2a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 3.8 2 2 0 0 1 4.11 2h2a2 2 0 0 1 2 1.72c.12.9.31 1.78.57 2.63a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.45-1.17a2 2 0 0 1 2.11-.45c.85.26 1.73.45 2.63.57A2 2 0 0 1 22 16.92Z" fill="currentColor"/>
        </svg>
        {PHONE_DISPLAY}
      </a>
    </div>
  </aside>

  <div class="drawer-backdrop" data-drawer-backdrop></div>
</nav>

<style>
  /* ==========================================================================
     NAV — mobile-first | logo protagónico | shrink-on-scroll | motion ready
     ========================================================================== */
  .nav {
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    background: linear-gradient(180deg, var(--c-purple-900), var(--c-purple-800));
    color: #fff;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
    font-family: var(--font-body);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .nav.is-scrolled {
    background: rgba(74, 28, 90, 0.82);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.28);
  }

  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: var(--nav-h);
    padding: 0 max(0.85rem, env(safe-area-inset-left)) 0 max(0.85rem, env(safe-area-inset-right));
    gap: 0.6rem;
    transition: height 0.3s ease;
  }
  .nav.is-scrolled .nav-bar { height: var(--nav-h-scrolled); }

  /* === LOGO PROTAGÓNICO === */
  .logo {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    height: 100%;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .logo:hover { transform: scale(1.05); }
  .logo-img {
    height: var(--logo-h);
    width: auto;
    display: block;
    filter: drop-shadow(0 4px 14px rgba(0, 0, 0, 0.4));
    transition: height 0.3s ease, filter 0.3s ease;
  }
  .logo:hover .logo-img {
    filter: drop-shadow(0 6px 20px rgba(206, 198, 226, 0.55)) brightness(1.06);
  }
  .nav.is-scrolled .logo-img { height: var(--logo-h-scrolled); }

  /* === MENÚ DESKTOP === */
  .nav-menu {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-heading);
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    padding: 0.55rem 0.95rem;
    border-radius: 10px;
    white-space: nowrap;
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: inherit;
    overflow: visible;
    transition: color 0.25s ease;
  }
  /* Pill highlight con scale */
  .nav-link::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.1);
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.25s cubic-bezier(0.22, 1, 0.36, 1), transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: -1;
  }
  .nav-link:hover::before,
  .nav-link:focus-visible::before {
    opacity: 1;
    transform: scale(1);
  }
  /* Underline desde el centro */
  .nav-link::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 6px;
    width: 0;
    height: 2px;
    background: var(--c-lilac);
    border-radius: 2px;
    transform: translateX(-50%);
    transition: width 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-link:hover::after { width: calc(100% - 1.8rem); }
  .nav-link:hover { color: var(--c-lilac); }

  .nav-link-trigger .chev {
    width: 14px; height: 14px;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .dd:hover .chev,
  .dd:focus-within .chev { transform: rotate(180deg); }

  /* === DROPDOWN PANEL (común) === */
  .dd { position: relative; }
  .dd-panel {
    position: absolute;
    left: 0;
    top: calc(100% + 8px);
    min-width: 260px;
    background: #fff;
    color: var(--text-primary);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 0.5rem;
    box-shadow: 0 18px 40px rgba(89, 33, 111, 0.18);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px) scale(0.98);
    transform-origin: top left;
    transition: opacity 0.22s ease, transform 0.22s cubic-bezier(0.22, 1, 0.36, 1), visibility 0.22s ease;
    pointer-events: none;
  }
  .dd-panel::before {
    /* Tip apuntando al trigger */
    content: '';
    position: absolute;
    top: -6px;
    left: 24px;
    width: 12px;
    height: 12px;
    background: #fff;
    border-left: 1px solid rgba(0, 0, 0, 0.06);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    transform: rotate(45deg);
    border-radius: 2px;
  }

  .dd:hover .dd-panel,
  .dd:focus-within .dd-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* Hover bridge */
  .dd::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 0; right: 0;
    height: 14px;
  }

  /* === DROPDOWN ANCHO (Services con grid 2 col) === */
  .dd-panel-wide {
    min-width: 520px;
    padding: 0.85rem;
  }
  .dd-eyebrow {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-purple);
    padding: 0.4rem 0.75rem 0.65rem;
    border-bottom: 1px solid rgba(122, 46, 135, 0.1);
    margin-bottom: 0.45rem;
  }
  .dd-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.15rem 0.35rem;
  }

  .dd-item {
    position: relative;
    display: block;
    padding: 0.65rem 0.85rem 0.65rem 1rem;
    border-radius: 8px;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.22s ease, color 0.22s ease, padding-left 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Accent lateral animado */
  .dd-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55rem;
    bottom: 0.55rem;
    width: 3px;
    background: var(--c-purple);
    border-radius: 0 3px 3px 0;
    transform: scaleY(0);
    transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
    transform-origin: center;
  }
  .dd-item:hover {
    background: rgba(186, 147, 194, 0.16);
    color: var(--c-purple);
    padding-left: 1.25rem;
  }
  .dd-item:hover::before { transform: scaleY(1); }

  /* Item con descripción (Pacientes) */
  .dd-item-rich {
    position: relative;
    display: block;
    padding: 0.75rem 0.85rem 0.75rem 1rem;
    border-radius: 10px;
    color: var(--text-primary);
    text-decoration: none;
    transition: background 0.22s ease, padding-left 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .dd-item-rich::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.65rem;
    bottom: 0.65rem;
    width: 3px;
    background: var(--c-purple);
    border-radius: 0 3px 3px 0;
    transform: scaleY(0);
    transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .dd-item-rich strong {
    display: block;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.95rem;
    color: var(--text-primary);
    margin-bottom: 0.15rem;
    transition: color 0.22s ease;
  }
  .dd-desc {
    display: block;
    font-size: 0.8rem;
    color: var(--muted);
    font-weight: 600;
  }
  .dd-item-rich:hover {
    background: rgba(186, 147, 194, 0.16);
    padding-left: 1.25rem;
  }
  .dd-item-rich:hover::before { transform: scaleY(1); }
  .dd-item-rich:hover strong { color: var(--c-purple); }

  /* === ACCIONES DERECHA === */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex: 0 0 auto;
    font-family: var(--font-heading);
  }

  .btn-lang {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.85rem;
    font-family: inherit;
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease;
  }
  .btn-lang:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.55);
    color: var(--c-lilac);
  }
  .btn-lang span { display: none; }

  .btn-phone {
    display: none;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease;
  }
  .btn-phone:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.55);
    color: var(--c-lilac);
  }

  .btn-cta {
    position: relative;
    display: none;
    padding: 0.6rem 1.15rem;
    background: var(--c-purple);
    color: #fff;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.92rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.2);
    transition: background 0.25s ease, box-shadow 0.3s ease, transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .btn-cta:hover {
    background: #8b3494;
    box-shadow: 0 8px 22px rgba(122, 46, 135, 0.5);
    transform: translateY(-2px);
  }
  .btn-cta:active { transform: translateY(0); }

  /* === BURGER === */
  .btn-burger {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 42px; height: 42px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, border-color 0.25s ease;
  }
  .btn-burger:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.55);
  }
  .btn-burger:hover .burger-line { background: var(--c-lilac); }
  .burger-line {
    width: 20px; height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.2s ease, background 0.25s ease;
    transform-origin: center;
  }
  .btn-burger[aria-expanded="true"] .burger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .btn-burger[aria-expanded="true"] .burger-line:nth-child(2) { opacity: 0; }
  .btn-burger[aria-expanded="true"] .burger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* === DRAWER MÓVIL === */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .drawer-backdrop.is-open { opacity: 1; visibility: visible; }

  .drawer {
    position: fixed;
    top: var(--nav-h);
    right: 0;
    width: min(85vw, 360px);
    height: calc(100dvh - var(--nav-h));
    background: #fff;
    color: var(--text-primary);
    box-shadow: -8px 0 24px rgba(0, 0, 0, 0.18);
    z-index: 999;
    overflow-y: auto;
    transform: translateX(100%);
    visibility: hidden;
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1), visibility 0.32s ease, top 0.3s ease, height 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .nav.is-scrolled .drawer { top: var(--nav-h-scrolled); height: calc(100dvh - var(--nav-h-scrolled)); }
  .drawer.is-open { transform: translateX(0); visibility: visible; }

  .drawer-menu {
    list-style: none;
    margin: 0;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1 1 auto;
  }

  .drawer-link, .drawer-trigger {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    padding: 0.95rem 1rem;
    background: #f8f6fb;
    color: var(--text-primary);
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    text-align: left;
    overflow: hidden;
    transition: background 0.25s ease, color 0.25s ease, transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Accent lateral animado en drawer */
  .drawer-link::before,
  .drawer-trigger::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0; bottom: 0;
    width: 4px;
    background: var(--c-purple);
    border-radius: 0 4px 4px 0;
    transform: scaleY(0);
    transform-origin: center;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .drawer-link:hover, .drawer-trigger:hover,
  .drawer-link:focus-visible, .drawer-trigger:focus-visible {
    background: rgba(186, 147, 194, 0.22);
    color: var(--c-purple);
    transform: translateX(2px);
  }
  .drawer-link:hover::before,
  .drawer-trigger:hover::before,
  .drawer-link:focus-visible::before,
  .drawer-trigger:focus-visible::before {
    transform: scaleY(1);
  }
  .drawer-trigger[aria-expanded="true"] {
    background: rgba(186, 147, 194, 0.22);
    color: var(--c-purple);
  }
  .drawer-trigger[aria-expanded="true"]::before { transform: scaleY(1); }
  .drawer-trigger .chev {
    width: 16px; height: 16px;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }
  .drawer-trigger[aria-expanded="true"] .chev { transform: rotate(180deg); }

  /* Wrap del sub-menu — Motion controla la altura via JS */
  .drawer-sub-wrap {
    overflow: hidden;
    height: 0;
  }
  .drawer-sub {
    list-style: none;
    margin: 0;
    padding: 0.4rem 0 0.2rem;
  }
  .drawer-sub-link {
    position: relative;
    display: block;
    padding: 0.65rem 1rem 0.65rem 1.85rem;
    color: var(--muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    border-radius: 8px;
    transition: background 0.2s ease, color 0.2s ease, padding-left 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .drawer-sub-link::before {
    content: "•";
    position: absolute;
    left: 1rem;
    color: var(--c-rose);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.22s ease, transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .drawer-sub-link:hover {
    background: rgba(122, 46, 135, 0.08);
    color: var(--c-purple);
    padding-left: 2.1rem;
  }
  .drawer-sub-link:hover::before {
    opacity: 1;
    transform: translateX(0);
  }
  .drawer-sub-link-all {
    color: var(--c-purple);
    font-weight: 800;
  }
  .drawer-sub-link-all::before { color: var(--c-purple); }

  .drawer-footer {
    padding: 1rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .drawer-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1rem;
    font-size: 1rem;
  }
  .drawer-call {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 1rem;
    border: 2px solid var(--c-purple);
    color: var(--c-purple);
    background: transparent;
    border-radius: 999px;
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.98rem;
    transition: background 0.25s ease, color 0.25s ease, box-shadow 0.3s ease, transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .drawer-call:hover {
    background: var(--c-purple);
    color: #fff;
    box-shadow: 0 6px 18px rgba(122, 46, 135, 0.35);
    transform: translateY(-1px);
  }

  /* === BREAKPOINTS === */
  @media (min-width: 480px) {
    .btn-lang span { display: inline; }
  }
  @media (min-width: 768px) {
    .btn-phone { display: inline-flex; }
    .btn-lang { padding: 0.5rem 0.85rem; }
  }
  @media (min-width: 1024px) {
    .nav-menu { display: flex; }
    .btn-burger { display: none; }
    .drawer, .drawer-backdrop { display: none !important; }
    .btn-cta { display: inline-block; }
    .nav-bar { padding: 0 1.5rem; gap: 1rem; }
    .nav-link { font-size: 1rem; padding: 0.6rem 0.95rem; }
  }
  @media (min-width: 1280px) {
    .nav-link { font-size: 1.05rem; padding: 0.65rem 1.1rem; }
    .nav-menu { gap: 0.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav, .nav-bar, .logo-img, .drawer, .drawer-sub-wrap, .chev, .burger-line, .dd-panel {
      transition: none !important;
    }
  }
</style>

<script>
  import { animate } from 'motion';

  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.querySelector<HTMLElement>('[data-nav]');
    const burger = document.querySelector<HTMLButtonElement>('[data-burger]');
    const drawer = document.querySelector<HTMLElement>('[data-drawer]');
    const backdrop = document.querySelector<HTMLElement>('[data-drawer-backdrop]');
    if (!nav) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const animateAny = animate as unknown as (...args: any[]) => any;

    /* ===== Motion: entrance del navbar al cargar ===== */
    if (!reducedMotion) {
      try {
        animateAny(nav, { opacity: [0, 1], y: [-12, 0] }, { duration: 0.45, easing: [0.22, 1, 0.36, 1] });
        const items = nav.querySelectorAll('.nav-bar > *');
        animateAny(items, { opacity: [0, 1], y: [-8, 0] }, { duration: 0.4, delay: (i: number) => 0.1 + i * 0.06, easing: [0.22, 1, 0.36, 1] });
      } catch {}
    }

    /* ===== Shrink-on-scroll (glass) ===== */
    let lastScrolled = false;
    const onScroll = () => {
      const isScrolled = window.scrollY > 40;
      if (isScrolled !== lastScrolled) {
        nav.classList.toggle('is-scrolled', isScrolled);
        lastScrolled = isScrolled;
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    /* ===== Hover spring sutil en nav-links (desktop) ===== */
    if (!reducedMotion) {
      nav.querySelectorAll<HTMLElement>('.nav-link').forEach((link) => {
        link.addEventListener('mouseenter', () => {
          try { animate(link, { y: -2 }, { type: 'spring', stiffness: 380, damping: 22 }); } catch {}
        });
        link.addEventListener('mouseleave', () => {
          try { animate(link, { y: 0 }, { type: 'spring', stiffness: 380, damping: 24 }); } catch {}
        });
      });
    }

    /* ===== Drawer toggle ===== */
    const openDrawer = () => {
      drawer?.classList.add('is-open');
      drawer?.setAttribute('aria-hidden', 'false');
      backdrop?.classList.add('is-open');
      burger?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };
    const closeDrawer = () => {
      drawer?.classList.remove('is-open');
      backdrop?.classList.remove('is-open');
      burger?.setAttribute('aria-expanded', 'false');
      drawer?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      drawer?.querySelectorAll<HTMLButtonElement>('.drawer-trigger[aria-expanded="true"]').forEach((t) => {
        collapseSub(t);
      });
    };

    burger?.addEventListener('click', () => {
      const isOpen = drawer?.classList.contains('is-open');
      if (isOpen) closeDrawer(); else openDrawer();
    });
    backdrop?.addEventListener('click', closeDrawer);
    drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeDrawer));

    /* ===== Sub-dropdowns con Motion (animación de altura suave) ===== */
    const expandSub = (trigger: HTMLButtonElement) => {
      trigger.setAttribute('aria-expanded', 'true');
      const wrap = trigger.nextElementSibling as HTMLElement | null;
      if (!wrap) return;
      const inner = wrap.querySelector('ul') as HTMLElement | null;
      if (!inner) return;
      const target = inner.scrollHeight;
      if (reducedMotion) { wrap.style.height = target + 'px'; return; }
      try {
        animateAny(wrap, { height: [`${wrap.offsetHeight}px`, `${target}px`] }, { duration: 0.32, easing: [0.22, 1, 0.36, 1] });
      } catch {
        wrap.style.height = target + 'px';
      }
    };
    const collapseSub = (trigger: HTMLButtonElement) => {
      trigger.setAttribute('aria-expanded', 'false');
      const wrap = trigger.nextElementSibling as HTMLElement | null;
      if (!wrap) return;
      if (reducedMotion) { wrap.style.height = '0px'; return; }
      try {
        animateAny(wrap, { height: [`${wrap.offsetHeight}px`, '0px'] }, { duration: 0.28, easing: [0.4, 0, 0.2, 1] });
      } catch {
        wrap.style.height = '0px';
      }
    };

    drawer?.querySelectorAll<HTMLButtonElement>('.drawer-trigger').forEach((trigger) => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        // Cerrar otros
        drawer.querySelectorAll<HTMLButtonElement>('.drawer-trigger').forEach((t) => {
          if (t !== trigger && t.getAttribute('aria-expanded') === 'true') collapseSub(t);
        });
        if (isOpen) collapseSub(trigger); else expandSub(trigger);
      });
    });

    /* ===== ESC + cambio a desktop cierran ===== */
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer?.classList.contains('is-open')) closeDrawer();
    });
    const mq = window.matchMedia('(min-width: 1024px)');
    mq.addEventListener('change', () => {
      if (mq.matches && drawer?.classList.contains('is-open')) closeDrawer();
    });
  });
</script>
