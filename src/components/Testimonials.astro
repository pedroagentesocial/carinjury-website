---
import localReviews from '../data/google-reviews.loca.json';
import { t, getCurrentLanguage } from '../i18n/index.ts';

const currentLang = getCurrentLanguage();

// Reseñas (5 base + inventadas)
const items = [
  ...localReviews,
  {
    author_name: 'Carlos García',
    rating: 5,
    text: 'Excelente atención, me ayudaron a recuperar la movilidad en mi espalda después de un accidente. ¡Muy recomendados!',
    date: 'Hace 2 meses',
    author_url: '',
    profile_photo_url: '/assets/img/client2.webp',
  },
  {
    author_name: 'María Rodríguez',
    rating: 5,
    text: 'Atención profesional y muy amable. La clínica cuenta con tecnología avanzada y el personal es increíble. ¡Gracias!',
    date: 'Hace 1 mes',
    author_url: '',
    profile_photo_url: '/assets/img/client1.webp',
  },
  {
    author_name: 'José López',
    rating: 5,
    text: 'Tuve un accidente de auto y me trataron con mucho cuidado. El servicio fue rápido y efectivo. ¡Muy satisfecho!',
    date: 'Hace 3 semanas',
    author_url: '',
    profile_photo_url: '/assets/img/client3.webp',
  },
  {
    author_name: 'Laura Jiménez',
    rating: 5,
    text: 'Una atención de primera. Me sentí muy apoyada durante todo el proceso de recuperación. ¡Altamente recomendados!',
    date: 'Hace 1 semana',
    author_url: '',
    profile_photo_url: '/assets/img/client4.jpeg',
  },
  {
    author_name: 'Alejandro García',
    rating: 5,
    text: 'El personal es muy atento y los tratamientos son efectivos. Me ayudaron a recuperarme rápidamente después de mi accidente.',
    date: 'Hace 5 días',
    author_url: '',
    profile_photo_url: '/assets/img/client5.jpg',
  }
];

// Crear grupos de 3 cards para el carrusel
const createGroups = (items: any[], groupSize = 3) => {
  const groups = [];
  for (let i = 0; i < items.length; i += groupSize) {
    groups.push(items.slice(i, i + groupSize));
  }
  return groups;
};

const testimonialGroups = createGroups(items, 3);

// Tomamos 5 para el bloque base (consistencia visual)
const base = items.slice(0, 5);

// Place ID (opcional)
const placeId = import.meta.env.PUBLIC_GOOGLE_PLACE_ID || '';
---

<section class="testimonials" aria-label="Opiniones de Google">
  <div class="decorative-particles">
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
  </div>
  <h2 class="testimonials__title">
    <span class="title-main" data-i18n="testimonials.title.main">{t('testimonials.title.main', currentLang)}</span>
    <span class="title-accent" data-i18n="testimonials.title.accent">{t('testimonials.title.accent', currentLang)}</span>
  </h2>
  <p class="testimonials__subtitle" data-i18n="testimonials.subtitle">{t('testimonials.subtitle', currentLang)}</p>

  <!-- Nuevo carrusel estático con grupos -->
  <div class="carousel-container" aria-live="polite">
    <div class="carousel-wrapper">
      {testimonialGroups.map((group, groupIndex) => (
        <div class={`testimonial-group ${groupIndex === 0 ? 'active' : ''}`} data-group={groupIndex} role="list">
          {group.map((r, i) => (
            <article class="card" role="listitem" aria-label={`Reseña de ${r.author_name}`} key={`group-${groupIndex}-card-${i}`}>
              <img
                class="avatar"
                src={r.profile_photo_url || '/assets/img/avatar-default.png'}
                alt={`Foto de ${r.author_name}`}
                loading="lazy"
                decoding="async"
                onload="this.dataset.loaded=1"
              />
              <blockquote>
                {(r.text || '').length > 200 ? (r.text || '').slice(0, 200) + '…' : (r.text || '')}
              </blockquote>
              <div class="stars" aria-label={`Calificación ${r.rating} de 5`}>
                {Array.from({ length: Number(r.rating) || 0 }).map((_, idx) => (
                  <svg viewBox="0 0 24 24" aria-hidden="true" key={`star-${groupIndex}-${i}-${idx}`}>
                    <path d="M12 17.27l6.18 3.73-1.64-7.03 5.46-4.73-7.19-.61L12 2 9.19 8.63l-7.19.61 5.46 4.73-1.64 7.03z" />
                  </svg>
                ))}
              </div>
              <span class="meta">
                <strong>{r.author_name}</strong>{r.date ? ` · ${r.date}` : ''}
              </span>
            </article>
          ))}
        </div>
      ))}
    </div>
    
    <!-- Indicadores de grupo -->
    <div class="carousel-indicators">
      {testimonialGroups.map((_, index) => (
        <button 
          class={`indicator ${index === 0 ? 'active' : ''}`} 
          data-group={index}
          aria-label={`Ver grupo ${index + 1} de testimonios`}
        ></button>
      ))}
    </div>
  </div>

  <div class="more">
    <a class="btn-secondary"
       href={`https://maps.app.goo.gl/76gxBm8r9supmSYR9`}
       target="_blank" rel="noopener"
       data-i18n="testimonials.view_more">
      {t('testimonials.view_more', currentLang)}
    </a>
  </div>
</section>

<style>
/* ===== Variables globales de fuentes ===== */
:root{
  --font-body: 'Source Sans 3', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  --font-heading: 'Manrope', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  
  --c-lilac: #CEC6E2;
  --c-violet: #806AAA;
  --c-plum: #7A2E87;
  --c-brand: #BA93C2;
}

/* ===== Animaciones Mejoradas ===== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(50px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-100px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(100px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes typewriter {
  from {
    width: 0;
  }
  to {
    width: 100%;
  }
}

@keyframes blink {
  0%, 50% {
    border-color: transparent;
  }
  51%, 100% {
    border-color: var(--c-plum);
  }
}

@keyframes starGlow {
  0%, 100% {
    filter: drop-shadow(0 1px 2px rgba(0,0,0,.18)) brightness(1);
    transform: scale(1);
  }
  50% {
    filter: drop-shadow(0 1px 8px rgba(255,215,0,.8)) brightness(1.3);
    transform: scale(1.1);
  }
}

/* Animaciones dinámicas y rápidas para el carrusel */
@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(100px) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translateX(0) scale(1);
  }
}

@keyframes slideOutLeft {
  from {
    opacity: 1;
    transform: translateX(0) scale(1);
  }
  to {
    opacity: 0;
    transform: translateX(-100px) scale(0.9);
  }
}

@keyframes cardPop {
  0% {
    opacity: 0;
    transform: scale(0.85) translateY(30px) rotateX(10deg);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.02) translateY(-5px) rotateX(0deg);
  }
  100% {
    opacity: 1;
    transform: scale(1) translateY(0) rotateX(0deg);
  }
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.08);
  }
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px) rotate(0deg);
  }
  33% {
    transform: translateY(-10px) rotate(1deg);
  }
  66% {
    transform: translateY(5px) rotate(-1deg);
  }
}

@keyframes particleFloat {
  0%, 100% {
    transform: translateY(0px) translateX(0px) scale(1);
    opacity: 0.3;
  }
  25% {
    transform: translateY(-20px) translateX(10px) scale(1.2);
    opacity: 0.6;
  }
  50% {
    transform: translateY(-10px) translateX(-5px) scale(0.8);
    opacity: 0.4;
  }
  75% {
    transform: translateY(-30px) translateX(15px) scale(1.1);
    opacity: 0.7;
  }
}

@keyframes cardEntrance {
  0% {
    opacity: 0;
    transform: translateY(60px) rotateX(20deg) scale(0.9);
  }
  50% {
    opacity: 0.7;
    transform: translateY(20px) rotateX(10deg) scale(0.95);
  }
  100% {
    opacity: 1;
    transform: translateY(0) rotateX(0deg) scale(1);
  }
}

@keyframes shimmer {
  0% {
    background-position: -200% center;
  }
  100% {
    background-position: 200% center;
  }
}

/* ===== Sección con efectos mejorados ===== */
.testimonials{
  background: var(--c-lilac);
  color: #fff;
  padding: clamp(3rem, 6vw, 5rem) 1rem;
  text-align: center;
  position: relative;
  overflow: hidden;
  font-family: var(--font-body);
  margin-bottom: -2rem;
  animation: slideInLeft 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* Partículas decorativas */
.decorative-particles {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
}

.particle {
  position: absolute;
  width: 8px;
  height: 8px;
  background: var(--c-brand);
  border-radius: 50%;
  animation: particleFloat 6s ease-in-out infinite;
}

.particle:nth-child(1) {
  top: 20%;
  left: 10%;
  animation-delay: 0s;
  background: var(--c-violet);
}

.particle:nth-child(2) {
  top: 60%;
  left: 85%;
  animation-delay: 1.5s;
  background: var(--c-plum);
}

.particle:nth-child(3) {
  top: 30%;
  left: 75%;
  animation-delay: 3s;
  background: var(--c-brand);
}

.particle:nth-child(4) {
  top: 80%;
  left: 20%;
  animation-delay: 4.5s;
  background: var(--c-violet);
}

.particle:nth-child(5) {
  top: 10%;
  left: 50%;
  animation-delay: 2s;
  background: var(--c-plum);
}

/* ===== Títulos Rediseñados ===== */
.testimonials__title{
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: clamp(2.5rem, 5vw, 4rem);
  margin: 0 auto 1rem;
  color: #fff;
  text-transform: uppercase;
  text-shadow: 0 4px 8px rgba(0,0,0,0.4);
  animation: slideInRight 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.3s both;
  position: relative;
  z-index: 2;
  line-height: 1.2;
  letter-spacing: -0.02em;
}

.title-main {
  display: inline-block;
  position: relative;
  overflow: hidden;
  animation: typewriter 2s steps(12) 0.8s both, blink 1s step-end 2.8s infinite;
  border-right: 3px solid var(--c-plum);
  white-space: nowrap;
  margin-right: 0.3em;
}

.title-accent {
  display: inline-block;
  background: linear-gradient(135deg, var(--c-brand), var(--c-violet));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: slideInRight 1s ease-out 2.5s both, shimmer 3s ease-in-out 3.5s infinite;
  background-size: 200% 100%;
  font-weight: 900;
  text-shadow: none;
  position: relative;
}

.title-accent::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--c-brand), var(--c-violet));
  opacity: 0.1;
  border-radius: 8px;
  transform: scale(1.1);
  z-index: -1;
  animation: pulse 2s ease-in-out infinite;
}

.testimonials__title::after{
  content: "";
  display: block;
  width: 120px; 
  height: 4px;
  margin: .75rem auto 0;
  background: var(--c-plum);
  border-radius: 999px;
  animation: fadeInUp 0.6s ease-out 0.4s both;
}
.testimonials__subtitle{
  font-family: var(--font-body);
  font-size: clamp(1rem, 2.5vw, 1.3rem);
  color: var(--c-plum);
  opacity: 0;
  margin: .5rem 0 2.5rem;
  width: 100%;
  max-width: none;
  white-space: nowrap;
  text-align: center;
  animation: fadeInUp 1.2s ease-out 1.5s both;
  position: relative;
  z-index: 2;
  line-height: 1.4;
  font-weight: 500;
  text-shadow: 0 2px 4px rgba(0,0,0,0.2);
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===== Carrusel simplificado y estable ===== */
.carousel{
  --gap: 2rem;
  overflow: hidden;
  max-width: 1100px;
  margin: 3rem auto 2rem;
  position: relative;
  border-radius: 20px;
  padding: 1rem 0;
  background: rgba(255,255,255,0.05);
}

/* Nuevo estilo para el carrusel estático */
.carousel-container {
  position: relative;
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 0;
}

.carousel-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 20px;
  min-height: 400px; /* Altura mínima para evitar saltos */
}

.testimonial-group {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
  gap: 2rem;
  padding: 1rem;
  opacity: 0;
  transform: translateX(100px) scale(0.9);
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: none;
}

.testimonial-group.active {
  opacity: 1;
  transform: translateX(0) scale(1);
  animation: slideInRight 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: auto;
}

.testimonial-group.exiting {
  opacity: 0;
  transform: translateX(-100px) scale(0.9);
  animation: slideOutLeft 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: none;
}

.carousel-indicators {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  margin-top: 2rem;
}

.indicator {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  border: 2px solid rgba(255, 255, 255, 0.5);
  background: transparent;
  cursor: pointer;
  transition: all 0.3s ease;
}

.indicator.active {
  background: white;
  border-color: white;
  transform: scale(1.2);
}

/* ===== Card (diseño sólido moderno) ===== */
.card{
  position: relative;
  flex: 0 0 340px;
  padding: 2rem 1.5rem 1.75rem;
  border-radius: 20px;
  text-align: left;
  font-weight: 700;
  display: flex; 
  flex-direction: column; 
  align-items: center;
  gap: .75rem;
  background: #ffffff;
  color: #3e2c4a;
  font-family: var(--font-body);
  border: 2px solid var(--c-brand);
  box-shadow: 0 8px 25px rgba(122,46,135,.12);
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  animation: cardEntrance 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) calc(0.8s + var(--delay, 0s)) both;
  transform-origin: center bottom;
  transform-style: preserve-3d;
  will-change: transform, opacity;
}

.testimonial-group.active .card:nth-child(1) {
  animation: cardPop 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55) 0.05s both;
}

.testimonial-group.active .card:nth-child(2) {
  animation: cardPop 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55) 0.1s both;
}

.testimonial-group.active .card:nth-child(3) {
  animation: cardPop 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55) 0.15s both;
}

@keyframes cardPop {
      0% {
        opacity: 0;
        transform: scale(0.8) translateY(30px) rotateX(15deg);
      }
      60% {
        opacity: 0.8;
        transform: scale(1.05) translateY(-5px) rotateX(-5deg);
      }
      100% {
        opacity: 1;
        transform: scale(1) translateY(0) rotateX(0deg);
      }
    }

.card {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
  will-change: transform, opacity;
}

.testimonial-group {
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.testimonial-group.exiting {
  opacity: 0;
  transform: translateX(-20px) scale(0.95);
}

/* Franja superior sólida */
.card::before{
  content: "";
  position: absolute; 
  top: 0; 
  left: 0; 
  right: 0;
  height: 8px;
  border-top-left-radius: 20px;
  border-top-right-radius: 20px;
  background: linear-gradient(135deg, var(--c-brand) 0%, var(--c-violet) 50%, var(--c-plum) 100%);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  opacity: 1;
  transform: scale(1);
}

/* Variantes de colores sólidos */
.card:nth-child(5n+1)::before{
  background: var(--c-plum);
}
.card:nth-child(5n+2)::before{
  background: var(--c-violet);
}
.card:nth-child(5n+3)::before{
  background: var(--c-brand);
}
.card:nth-child(5n+4)::before{
  background: var(--c-lilac);
}
.card:nth-child(5n+5)::before{
  background: var(--c-plum);
}

/* Sombra inferior mejorada */
.card::after{
  content: "";
  position: absolute; 
  left: 12px; 
  right: 12px; 
  bottom: 8px;
  height: 8px;
  border-radius: 999px;
  background: rgba(122,46,135,.15);
  filter: blur(6px);
  opacity: .4;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

/* Hover simplificado con pausa del carrusel */
.card:hover{
  transform: translateY(-8px);
  box-shadow: 0 15px 40px rgba(122,46,135,.2);
  border-color: var(--c-violet);
}

.card:hover {
  animation-play-state: paused;
}

.track:has(.card:hover) {
  animation-play-state: paused;
}

.card:hover::after{
  opacity: .6;
}

.card:hover::before{
  background: var(--c-violet) !important;
}

.card:hover .avatar{
  transform: scale(1.05);
  box-shadow: 0 8px 20px rgba(122, 46, 135, 0.3);
}

/* Avatar simplificado */
.avatar{
  width: 86px; 
  height: 86px;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid var(--c-brand);
  box-shadow: 0 4px 12px rgba(122,46,135,.15);
  transition: all 0.3s ease;
}

/* Texto mejorado */
blockquote{
  font-style: italic;
  font-size: 1rem;
  line-height: 1.6;
  margin: .1rem 0 .5rem;
  text-align: left;
  color: var(--c-plum);
  font-family: var(--font-body);
  transition: color 0.3s ease;
}

.card:hover blockquote{
  color: var(--c-violet);
}

/* Estrellas simplificadas */
.stars{
  display: flex; 
  gap: 4px;
  color: #FFD700;
  margin-bottom: .15rem;
}

.stars svg{
  width: 20px; 
  height: 20px;
  fill: currentColor;
  transition: transform 0.2s ease;
}

.card:hover .stars svg{
  transform: scale(1.1);
}

.card .meta{
  align-self: stretch;
  text-align: left;
  font-weight: 800;
  color: var(--c-violet);
  opacity: .95;
  transition: color 0.3s ease;
}

.card:hover .meta{
  color: var(--c-plum);
}

/* ===== Botón sólido moderno ===== */
.more{ 
  margin-top: 1.5rem;
  animation: fadeInUp 0.6s ease-out 1.2s both;
}

.btn-secondary{
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1.25rem 2.5rem;
  border-radius: 60px;
  background: var(--c-plum);
  color: #fff;
  text-decoration: none;
  font-weight: 700;
  letter-spacing: 0.5px;
  font-size: 1.15rem;
  box-shadow: 0 8px 25px rgba(122, 46, 135, 0.3);
  transition: all 0.3s ease;
  font-family: var(--font-heading);
  border: 2px solid var(--c-plum);
  text-transform: uppercase;
  z-index: 2;
}

.btn-secondary:hover{
  background: var(--c-violet);
  border-color: var(--c-violet);
  transform: translateY(-3px);
  box-shadow: 0 12px 35px rgba(122, 46, 135, 0.4);
}

.btn-secondary:active{
  transform: translateY(-1px);
  box-shadow: 0 6px 15px rgba(122,46,135,.3);
}

/* ===== Responsive ===== */
@media (max-width: 1100px){
  .testimonial-group {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .card { 
    flex-basis: 320px; 
  }
}

@media (max-width: 768px){
  .testimonial-group {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    padding: 0.5rem;
  }
  
  .card { 
    flex-basis: 300px; 
  }
  
  blockquote{ 
    font-size: .95rem; 
  }
  
  .testimonials__subtitle{
    font-size: clamp(0.9rem, 2.2vw, 1.1rem);
    padding: 0 0.5rem;
  }
  
  .carousel-container {
    padding: 1rem 0;
  }
}

@media (max-width: 480px){
  .testimonial-group {
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 0.5rem;
  }
  
  .card {
    flex-basis: 100%;
    max-width: 100%;
  }
  
  .testimonials__subtitle{
    font-size: clamp(0.8rem, 2vw, 1rem);
    white-space: normal;
    line-height: 1.3;
    padding: 0 1rem;
  }
  
  .carousel-indicators {
    margin-top: 1rem;
  }
  
  .indicator {
    width: 10px;
    height: 10px;
  }
}

</style>

<script>
// Carrusel estático con cambio automático cada 5 segundos
(function () {
  const section = document.querySelector('.testimonials');
  const carouselContainer = section?.querySelector('.carousel-container');
  if (!section || !carouselContainer) return;

  const groups = carouselContainer.querySelectorAll('.testimonial-group');
  const indicators = carouselContainer.querySelectorAll('.indicator');
  
  if (!groups.length || !indicators.length) return;

  let currentIndex = 0;
  let intervalId: number | undefined = undefined;
  let isPaused = false;

  // Función para mostrar un grupo específico con animación mejorada
  const showGroup = (index: number) => {
    const currentGroup = groups[currentIndex];
    const nextGroup = groups[index];
    
    // Agregar clase de salida al grupo actual
    if (currentGroup && currentIndex !== index) {
      currentGroup.classList.add('exiting');
      setTimeout(() => {
        currentGroup.classList.remove('active', 'exiting');
      }, 150);
    }
    
    // Actualizar indicadores
    setTimeout(() => {
      indicators.forEach((indicator, i) => {
        indicator.classList.toggle('active', i === index);
      });
    }, 75);
    
    // Mostrar el nuevo grupo después de un breve delay
    setTimeout(() => {
      nextGroup.classList.add('active');
    }, currentIndex !== index ? 150 : 0);
    
    currentIndex = index;
  };

  // Función para avanzar al siguiente grupo
  const nextGroup = () => {
    const nextIndex = (currentIndex + 1) % groups.length;
    showGroup(nextIndex);
  };

  // Iniciar el carrusel automático
  const startCarousel = () => {
    if (intervalId) clearInterval(intervalId);
    intervalId = setInterval(() => {
      if (!isPaused) {
        nextGroup();
      }
    }, 3000); // 3 segundos - más dinámico
  };

  // Pausar el carrusel
  const pauseCarousel = () => {
    isPaused = true;
  };

  // Reanudar el carrusel
  const resumeCarousel = () => {
    isPaused = false;
  };

  // Event listeners para los indicadores
  indicators.forEach((indicator, index) => {
    indicator.addEventListener('click', () => {
      showGroup(index);
      // Reiniciar el timer después de la interacción manual
      startCarousel();
    });
  });

  // Pausar en hover
  carouselContainer.addEventListener('mouseenter', pauseCarousel);
  carouselContainer.addEventListener('mouseleave', resumeCarousel);

  // Pausar cuando el elemento tiene foco
  section.addEventListener('focusin', pauseCarousel);
  section.addEventListener('focusout', resumeCarousel);

  // Respeto por prefers-reduced-motion
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  
  // Inicializar
  showGroup(0);
  
  if (!prefersReducedMotion) {
    startCarousel();
  }

  // Limpiar al descargar la página
  window.addEventListener('beforeunload', () => {
    if (intervalId) clearInterval(intervalId);
  });
})();
</script>
