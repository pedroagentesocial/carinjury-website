---
import { t, getCurrentLanguage } from '../i18n/index.ts';

const currentLang = getCurrentLanguage();
---

<section class="hs" data-hs>
  <!-- Capa de fondo: aurora + grid + vignette -->
  <div class="hs-bg" aria-hidden="true">
    <span class="hs-orb hs-orb-1"></span>
    <span class="hs-orb hs-orb-2"></span>
    <span class="hs-orb hs-orb-3"></span>
    <span class="hs-grid"></span>
    <span class="hs-vignette"></span>
  </div>

  <div class="hs-content">
    <span class="hs-badge">
      <span class="hs-dot" aria-hidden="true"></span>
      <span data-i18n="hero_services.badge">{t('hero_services.badge', currentLang)}</span>
    </span>

    <h1 class="hs-title" data-i18n="hero_services.title">{t('hero_services.title', currentLang)}</h1>

    <p class="hs-subtitle" data-i18n="hero_services.subtitle">{t('hero_services.subtitle', currentLang)}</p>

    <span class="hs-scroll" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="14" height="14">
        <path d="M12 5v14m0 0l-7-7m7 7l7-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>

  <!-- Fade hacia la siguiente sección -->
  <span class="hs-fade" aria-hidden="true"></span>
</section>

<script>
  /* Pausa las animaciones del hero cuando ya no está visible: ahorra CPU/GPU */
  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.querySelector<HTMLElement>('[data-hs]');
    if (!hero) return;
    const animated = hero.querySelectorAll<HTMLElement>('.hs-orb, .hs-dot');
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        animated.forEach((el) => {
          el.style.animationPlayState = e.isIntersecting ? 'running' : 'paused';
        });
      });
    }, { threshold: 0 });
    io.observe(hero);
  });
</script>

<style>
  /* ====== TOKENS LOCALES ====== */
  .hs {
    --hs-purple-deep: #1f0d2a;
    --hs-purple-base: #3a1547;
    --hs-purple-mid:  #5d2167;
    --hs-purple-warm: #7A2E87;
    --hs-rose:        #BA93C2;
    --hs-lilac:       #CEC6E2;

    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: #fff;
    font-family: 'Manrope', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;

    /* Fondo base con gradient sutil (la aurora va encima) */
    background:
      radial-gradient(ellipse 90% 70% at 50% 0%, var(--hs-purple-warm) 0%, var(--hs-purple-base) 40%, var(--hs-purple-deep) 100%);

    min-height: clamp(440px, 60vh, 640px);
    display: grid;
    place-items: center;
    padding: clamp(3rem, 8vw, 5rem) clamp(1rem, 4vw, 2rem) clamp(4rem, 9vw, 6rem);

    /* Aísla todo el repaint del hero del resto del documento */
    contain: layout paint;
  }

  /* ====== AURORA: 3 orbes que flotan, MUY lento, sólo transform ====== */
  .hs-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hs-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(72px);
    opacity: 0.55;
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }
  .hs-orb-1 {
    width: clamp(320px, 48vw, 600px);
    height: clamp(320px, 48vw, 600px);
    top: -8%;
    left: -10%;
    background: radial-gradient(circle, var(--hs-rose) 0%, transparent 65%);
    animation: orb1 38s ease-in-out infinite alternate;
  }
  .hs-orb-2 {
    width: clamp(360px, 52vw, 680px);
    height: clamp(360px, 52vw, 680px);
    top: 15%;
    right: -14%;
    background: radial-gradient(circle, var(--hs-purple-warm) 0%, transparent 65%);
    opacity: 0.45;
    animation: orb2 46s ease-in-out infinite alternate;
  }
  .hs-orb-3 {
    width: clamp(280px, 42vw, 520px);
    height: clamp(280px, 42vw, 520px);
    bottom: -18%;
    left: 32%;
    background: radial-gradient(circle, var(--hs-lilac) 0%, transparent 65%);
    opacity: 0.32;
    animation: orb3 52s ease-in-out infinite alternate;
  }
  @keyframes orb1 {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to   { transform: translate3d(40px, 30px, 0) scale(1.1); }
  }
  @keyframes orb2 {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to   { transform: translate3d(-50px, 36px, 0) scale(0.95); }
  }
  @keyframes orb3 {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to   { transform: translate3d(20px, -40px, 0) scale(1.08); }
  }

  /* ====== GRID PATTERN (líneas sutiles), con mask radial para que se desvanezca ====== */
  .hs-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
    background-size: 60px 60px;
    background-position: -1px -1px;
    -webkit-mask-image: radial-gradient(ellipse 70% 65% at 50% 45%, #000 0%, transparent 75%);
    mask-image: radial-gradient(ellipse 70% 65% at 50% 45%, #000 0%, transparent 75%);
    opacity: 0.85;
  }

  /* Vignette suave para enfocar el centro */
  .hs-vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 100% 80% at 50% 50%, transparent 35%, rgba(31, 13, 42, 0.55) 100%);
  }

  /* ====== CONTENIDO ====== */
  .hs-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.85rem, 1.5vw, 1.25rem);
  }

  /* Badge glassy con dot pulsante */
  .hs-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 1rem 0.5rem 0.85rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: rgba(255, 255, 255, 0.92);
    font-weight: 800;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    animation: rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hs-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--hs-rose);
    box-shadow: 0 0 0 0 rgba(186, 147, 194, 0.65);
    animation: dotPulse 2.4s ease-in-out infinite;
    will-change: box-shadow;
  }
  @keyframes dotPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(186, 147, 194, 0.55); }
    50%      { box-shadow: 0 0 0 9px rgba(186, 147, 194, 0); }
  }

  /* Título: gradient text suave white→lilac→white, tracking ajustado */
  .hs-title {
    font-weight: 900;
    font-size: clamp(2.2rem, 5.4vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0;
    text-wrap: balance;
    background: linear-gradient(135deg, #ffffff 0%, #efe2f4 50%, #ffffff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    animation: rise 0.85s cubic-bezier(0.22, 1, 0.36, 1) 0.08s both;
  }

  /* Subtítulo: peso 500-600, opacity contenida, max-width legible */
  .hs-subtitle {
    font-family: 'Source Sans 3', system-ui, sans-serif;
    font-weight: 500;
    font-size: clamp(1.02rem, 1.8vw, 1.2rem);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.78);
    max-width: 56ch;
    margin: 0;
    text-wrap: pretty;
    animation: rise 0.85s cubic-bezier(0.22, 1, 0.36, 1) 0.16s both;
  }

  /* Indicador de scroll: bouncing chevron en círculo glassy */
  .hs-scroll {
    margin-top: clamp(1.25rem, 3vw, 2rem);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    animation: rise 0.85s cubic-bezier(0.22, 1, 0.36, 1) 0.28s both,
               scrollBounce 2.4s ease-in-out 1.2s infinite;
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50%      { transform: translateY(5px); opacity: 1; }
  }

  /* Entrance compartido para badge/title/subtitle/scroll */
  @keyframes rise {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Fade inferior — empalma suave con la siguiente sección */
  .hs-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 80px;
    background: linear-gradient(180deg, transparent 0%, rgba(31, 13, 42, 0.6) 70%, rgba(31, 13, 42, 0.85) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* ====== Reduced motion ====== */
  @media (prefers-reduced-motion: reduce) {
    .hs-orb, .hs-dot, .hs-scroll { animation: none !important; }
    .hs-badge, .hs-title, .hs-subtitle { animation: none !important; opacity: 1; transform: none; }
  }
</style>
