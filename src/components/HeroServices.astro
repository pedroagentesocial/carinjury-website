---
import { t, getCurrentLanguage } from '../i18n/index.ts';

// HeroServices.astro - Hero específico para la página de servicios
const currentLang = getCurrentLanguage();
---

<section class="hero-services">
  <div class="hero-services-content">
    <div class="hero-services-text">
      <span class="hero-services-badge" data-i18n="hero_services.badge">{t('hero_services.badge', currentLang)}</span>
      <h1 class="hero-services-title" data-i18n="hero_services.title">{t('hero_services.title', currentLang)}</h1>
      <p class="hero-services-subtitle" data-i18n="hero_services.subtitle">{t('hero_services.subtitle', currentLang)}</p>

    </div>
  </div>
  <div class="hero-services-overlay"></div>
</section>

<style>
  /* Importar fuentes */
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@700;800;900&family=Source+Sans+3:wght@400;600;700;800&display=swap');

  :root {
    /* Paleta de colores del sitio */
    --c-lilac: #CEC6E2;
    --c-plum: #806AAA;
    --c-purple: #7A2E87;
    --c-rose: #BA93C2;
    --ink: #1A1D2A;
    
    /* Fuentes */
    --font-heading: 'Manrope', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    --font-body: 'Source Sans 3', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  }

  .hero-services {
    position: relative;
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    
    /* Imagen de fondo */
    background: url('/assets/img/fondoNuevoHero.jpeg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: scroll;
    
    /* Fallback si no carga la imagen */
    background-color: var(--c-purple);
  }

  .hero-services-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(122, 46, 135, 0.5) 0%,
      rgba(97, 30, 108, 0.4) 50%,
      rgba(0, 0, 0, 0.3) 100%
    );
    z-index: 1;
  }

  .hero-services-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(1.5rem, 3vw, 2.5rem) 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    animation: heroFadeInUp 1s ease-out;
  }

  .hero-services-text {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-services-badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(10px);
    margin: 0 auto 1.5rem auto;
    text-align: center;
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }

  .hero-services-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    color: #fff;
    margin: 0 auto 1.5rem auto;
    text-align: center;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.3);
    animation: heroTitleSlide 1.2s ease-out 0.2s both;
  }

  .hero-services-subtitle {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(1.1rem, 2.2vw, 1.4rem);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.95);
    margin: 0 auto;
    text-align: center;
    text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.2);
    animation: heroSubtitleFade 1s ease-out 0.4s both;
  }



  /* Animaciones */
  @keyframes heroFadeInUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroTitleSlide {
    from {
      opacity: 0;
      transform: translateY(50px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes heroSubtitleFade {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }



  /* Responsive */
  @media (max-width: 768px) {
    .hero-services {
      min-height: 60vh;
      background-attachment: scroll;
    }


  }

  @media (max-width: 480px) {
    .hero-services-content {
      padding: 2rem 1rem;
    }

    .hero-services-badge {
      font-size: 0.8rem;
      padding: 0.4rem 0.8rem;
    }
  }
</style>