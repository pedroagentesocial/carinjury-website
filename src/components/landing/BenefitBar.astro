---
interface Props { items: string[] }
const { items } = Astro.props as Props;
---
<div class="w-full bg-gradient-to-r from-violet-800 to-purple-700 text-white">
  <div class="max-w-6xl mx-auto px-4 py-2 flex flex-wrap items-center justify-center gap-2">
    {items.map((label) => (
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 backdrop-blur text-sm font-semibold">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {label}
      </span>
    ))}
  </div>
</div>

