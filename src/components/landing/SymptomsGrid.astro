---
interface Props { symptoms: string[] }
const { symptoms } = Astro.props as Props;
---
<section class="max-w-6xl mx-auto px-4 py-12">
  <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900">Síntomas comunes tras un accidente</h2>
  <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-4">
    {symptoms.map((s) => (
      <div class="rounded-2xl border border-slate-200 p-4 text-center shadow-sm bg-white">
        <div class="mx-auto w-14 h-14 rounded-full bg-purple-100 text-purple-700 flex items-center justify-center">
          <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/></svg>
        </div>
        <p class="mt-3 font-semibold">{s}</p>
      </div>
    ))}
  </div>
</section>

