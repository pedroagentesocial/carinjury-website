---
interface QA { q: string; a: string }
interface Props { items?: QA[]; title?: string }
const { items = [], title = 'Preguntas frecuentes' } = Astro.props as Props;
---
<section class="bg-slate-50">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900">{title}</h2>
    <div class="mt-6 space-y-3">
      {items.map((it) => (
        <details class="rounded-xl bg-white p-4 border border-slate-200 shadow-sm">
          <summary class="cursor-pointer font-semibold">{it.q}</summary>
          <p class="mt-2 text-slate-700">{it.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
