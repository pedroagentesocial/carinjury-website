---
interface Props { title?: string }
const { title = 'Lo que dicen nuestros pacientes' } = Astro.props as Props;
---
<section class="max-w-6xl mx-auto px-4 py-12">
  <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900">{title}</h2>
  <div class="mt-6 grid md:grid-cols-3 gap-6">
    {[1,2,3].map(() => (
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex items-center gap-1 text-yellow-500">
          {Array.from({ length: 5 }).map(() => (<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>))}
        </div>
        <p class="mt-3 text-slate-700">“Excelente atención, me ayudaron desde el primer día. Recomiendo 100%.”</p>
        <p class="mt-2 text-slate-500 text-sm">Paciente verificado</p>
      </div>
    ))}
  </div>
</section>
