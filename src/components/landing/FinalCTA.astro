---
interface Props { phoneNumber: string; title?: string; subtext?: string; scheduleLabel?: string; callLabel?: string }
const { phoneNumber, title = 'Da el siguiente paso hoy mismo', subtext = 'Agenda tu cita y comienza tu recuperación', scheduleLabel = 'Agendar tu cita', callLabel = 'Llamar ahora' } = Astro.props as Props;
const telHref = `tel:${phoneNumber}`;
---
<section class="max-w-6xl mx-auto px-4 py-12">
  <div class="rounded-2xl bg-gradient-to-r from-purple-700 to-violet-800 p-8 md:p-12 text-center text-white">
    <h2 class="text-2xl md:text-3xl font-extrabold">{title}</h2>
    <p class="mt-2 text-white/90">{subtext}</p>
    <div class="mt-6 flex flex-col md:flex-row gap-3 justify-center">
      <a href="#lead-form" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-white text-purple-800 font-bold hover:bg-white/90 transition">
        {scheduleLabel}
      </a>
      <a href={telHref} class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border-2 border-white text-white font-bold hover:bg-white/10 transition" data-event="phone_call">
        {callLabel}
      </a>
    </div>
  </div>
</section>
