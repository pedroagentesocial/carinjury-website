---
import Layout from '../layouts/Layout.astro';
import { t, getServerLanguage } from '../i18n/index.ts';
---

<Layout>
  <section class="thanks">
    <div class="thanks__card">
      <h1 data-i18n="gracias_page.title">¡Gracias!</h1> 🎉
      <p data-i18n="gracias_page.message">Hemos recibido tu mensaje y nos pondremos en contacto contigo pronto.</p>
      <div class="thanks__cta">
        <a href="/" data-i18n="gracias_page.back_home">Volver al inicio</a>
        <a href="tel:+13852428571" data-i18n="gracias_page.call_now">Llamar ahora</a>
      </div>
    </div>
  </section>

  <style>
    .thanks{
      min-height: calc(100vh - 140px);
      display: grid; place-items: center;
      padding: 2rem 1rem;
      background: linear-gradient(180deg, var(--brand-700, #5E226A), var(--brand-500, #7A2E87));
      color: #fff;
    }
    .thanks__card{
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.16);
      border-radius: 14px;
      padding: 1.75rem;
      text-align: center;
      box-shadow: 0 12px 28px rgba(0,0,0,.25);
      backdrop-filter: blur(6px) saturate(120%);
      max-width: 560px;
    }
    .thanks__card h1{
      font-family: 'Oswald', sans-serif;
      font-size: 2rem;
      margin-bottom: .5rem;
    }
    .thanks__card p{
      opacity: .95;
      margin-bottom: 1rem;
    }
    .thanks__cta{
      display: grid; grid-auto-flow: column; gap: .75rem; justify-content: center;
    }
    .thanks__cta a{
      display: inline-block;
      padding: .7rem 1.1rem;
      border-radius: 10px;
      text-decoration: none;
      font-weight: 800;
      border: 2px solid #fff;
      color: #fff;
      transition: background .15s, color .15s, transform .15s, box-shadow .15s;
    }
    .thanks__cta a:hover{
      background: #fff; color: #000;
      transform: translateY(-1px);
      box-shadow: 0 8px 18px rgba(0,0,0,.28);
    }
  </style>
</Layout>

<script>
  // Inicialización del cliente i18n para gracias.astro
  document.addEventListener('DOMContentLoaded', () => {
    console.log('Gracias: DOMContentLoaded');
    
    // Esperar a que i18n esté listo o inicializarlo
    const initializeI18n = async () => {
      if (window.i18nClient) {
        console.log('Gracias: i18nClient already available');
        window.i18nClient.updateAllTranslations();
      } else {
        console.log('Gracias: Waiting for i18nReady event');
        window.addEventListener('i18nReady', () => {
          console.log('Gracias: i18nReady event received');
          if (window.i18nClient) {
            window.i18nClient.updateAllTranslations();
          }
        });
      }
    };
    
    initializeI18n();
  });
</script>
