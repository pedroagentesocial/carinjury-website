<script>
  // Inicialización del cliente i18n para aboutus.astro
  document.addEventListener('DOMContentLoaded', () => {
    console.log('AboutUs: DOMContentLoaded');
    
    // Esperar a que i18n esté listo o inicializarlo
    const initializeI18n = async () => {
      if (window.i18nClient) {
        console.log('AboutUs: i18nClient already available');
        window.i18nClient.updateAllTranslations();
      } else {
        console.log('AboutUs: Waiting for i18nReady event');
        window.addEventListener('i18nReady', () => {
          console.log('AboutUs: i18nReady event received');
          if (window.i18nClient) {
            window.i18nClient.updateAllTranslations();
          }
        });
      }
    };
    
    initializeI18n();
  });
</script>
