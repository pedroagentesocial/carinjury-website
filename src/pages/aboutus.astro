---
// src/pages/aboutus.astro - Página de Perfiles de Quiroprácticos
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import MapContact from '../components/MapContact.astro';

// Imagen del hero
const HERO_IMG = '/assets/img/fondoNuevoHero.jpeg';
---

<Layout>
  <main class="about page">
    <!-- ===== Hero Section - Quiroprácticos Especializados ===== -->
    <header class="hero-chiro">
      <div class="hero-chiro__bg" aria-hidden="true">
        <img src={HERO_IMG} alt="" loading="lazy" decoding="async" />
        <div class="veil" aria-hidden="true"></div>
      </div>
      <div class="container hero-chiro__content">
        <div class="hero-badge">
          <span class="badge-icon">●</span>
          <span data-i18n="aboutus.hero.badge">Nuestro Equipo</span>
        </div>
        <h1 data-i18n="aboutus.hero.title">Conoce a Nuestros Especialistas</h1>
        <p data-i18n="aboutus.hero.subtitle">Doctores certificados con años de experiencia en el tratamiento de lesiones por accidentes automovilísticos</p>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-number">15+</span>
            <span class="stat-label" data-i18n="aboutus.hero.stats.experience">Años de Experiencia</span>
          </div>
          <div class="stat">
            <span class="stat-number">2,500+</span>
            <span class="stat-label" data-i18n="aboutus.hero.stats.patients">Pacientes Tratados</span>
          </div>
          <div class="stat">
            <span class="stat-number">95%</span>
            <span class="stat-label" data-i18n="aboutus.hero.stats.recovery">Tasa de Recuperación</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Especialistas en Lesiones por Accidente -->
    <section class="team-intro">
      <div class="intro-content">
        <div class="eyebrow">★ <span data-i18n="aboutus.team.badge">Especialistas Certificados</span></div>
        <h2 data-i18n="aboutus.team.title">Nuestro Equipo de Especialistas</h2>
        <p class="lede" data-i18n="aboutus.team.subtitle">Profesionales dedicados a tu recuperación completa</p>
      </div>
    </section>

    <!-- ===== Perfiles de Quiroprácticos ===== -->
    <section class="team-profiles" aria-labelledby="team-title">
      <div class="container">
        <div class="profiles-grid">
          <!-- Perfil 1: Dr. Johnny Wong -->
          <article class="profile-card" itemscope itemtype="https://schema.org/Physician">
            <div class="card-header">
              <div class="profile-image">
                <img
                  src="/assets/img/chiro1.jpeg"
                  alt="Dr. Johnny Wong, Chiropractor"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
            <div class="profile-info">
              <h3 class="name" itemprop="name" data-i18n="aboutus.doctors.johnny.name">Dr. Johnny Wong</h3>
              <p class="title" data-i18n="aboutus.doctors.johnny.title">Doctor Quiropráctico</p>
              <p class="specialty" data-i18n="aboutus.doctors.johnny.specialty">Especialista en Manejo del Dolor y Quiropráctica</p>
            </div>
            <div class="card-body">
              <p class="bio" data-i18n="aboutus.doctors.johnny.bio">
                Especialista en manejo del dolor crónico y terapias avanzadas para víctimas de accidentes automovilísticos. Con más de 10 años de experiencia, se enfoca en técnicas de quiropráctica avanzada y terapias complementarias para el alivio del dolor.
              </p>
              <div class="specialties">
                <h4 data-i18n="aboutus.doctors.johnny.specialties.title">Especialidades Clínicas:</h4>
                <ul>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.johnny.specialties.items.0">Terapia Quiropráctica</span>
                  </li>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.johnny.specialties.items.1">Manejo del Dolor</span>
                  </li>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.johnny.specialties.items.2">Terapia de Masaje</span>
                  </li>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.johnny.specialties.items.3">Terapia Frio-Calor</span>
                  </li>
                </ul>
              </div>
              <div class="credentials">
                <span class="credential">
                  <svg class="doctor-credential-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                    <path d="M12 3L1 9L12 15L21 12.09V17H23V9M5 13.18V17.18L12 21L19 17.18V13.18L12 17L5 13.18Z"/>
                  </svg>
                  <span data-i18n="aboutus.doctors.johnny.credentials.0">Doctor en Quiropráctica (DC)</span>
                </span>
                <span class="credential">
                  <svg class="doctor-credential-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                    <path d="M6.5 2C5.67 2 5 2.67 5 3.5S5.67 5 6.5 5 8 4.33 8 3.5 7.33 2 6.5 2M9 7H4C3.45 7 3 7.45 3 8V14H5V22H8V14H10V22H13V14H15V8C15 7.45 14.55 7 14 7H9Z"/>
                  </svg>
                  <span data-i18n="aboutus.doctors.johnny.credentials.1">Diplomado en Manejo del Dolor</span>
                </span>
                <span class="credential">
                  <svg class="doctor-credential-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                    <path d="M5 3C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3H5M7 7H17V9H7V7M7 11H17V13H7V11M7 15H14V17H7V15Z"/>
                  </svg>
                  <span data-i18n="aboutus.doctors.johnny.credentials.2">Certificado en Terapia de Masaje</span>
                </span>
              </div>
              <div class="experience-info">
                <span class="experience-years" data-i18n="aboutus.doctors.johnny.experience">10 años de experiencia</span>
                <span class="cases-treated" data-i18n="aboutus.doctors.johnny.cases">Especialista en casos de dolor complejo</span>
              </div>
            </div>
            <div class="card-footer">
              <a class="btn-schedule" href="/schedule" aria-label="Agendar con el Dr. Wong">
                <span data-i18n="common.schedule_consultation">Agendar Consulta</span>
                <svg class="arrow" viewBox="0 0 24 24" width="18" height="18">
                  <path d="M5 12h12m0 0l-4-4m4 4l-4 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>

          <!-- Perfil 2: Dr. Darwin Lee -->
          <article class="profile-card" itemscope itemtype="https://schema.org/Physician">
            <div class="card-header">
              <div class="profile-image">
                <img
                  src="/assets/img/chiro2.jpeg"
                  alt="Dr. Darwin Lee, Chiropractor"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
            <div class="profile-info">
              <h3 class="name" itemprop="name" data-i18n="aboutus.doctors.darwin.name">Dr. Darwin Lee</h3>
              <p class="title" data-i18n="aboutus.doctors.darwin.title">Doctor Quiropráctico</p>
              <p class="specialty" data-i18n="aboutus.doctors.darwin.specialty">Especialista en Terapia Física y Manejo del Dolor</p>
            </div>
            <div class="card-body">
              <p class="bio" data-i18n="aboutus.doctors.darwin.bio">
                Especialista en rehabilitación funcional y terapia física para víctimas de accidentes automovilísticos. Con más de 8 años de experiencia, se enfoca en técnicas de rehabilitación avanzada y manejo integral del dolor para una recuperación completa.
              </p>
              <div class="specialties">
                <h4 data-i18n="aboutus.doctors.darwin.specialties.title">Especialidades Clínicas:</h4>
                <ul>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.darwin.specialties.items.0">Terapia Física</span>
                  </li>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.darwin.specialties.items.1">Rehabilitación de Lesiones</span>
                  </li>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.darwin.specialties.items.2">Manejo del Dolor</span>
                  </li>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.darwin.specialties.items.3">Terapia TENS</span>
                  </li>
                </ul>
              </div>
              <div class="credentials">
                <span class="credential">
                  <svg class="doctor-credential-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                    <path d="M12 3L1 9L12 15L21 12.09V17H23V9M5 13.18V17.18L12 21L19 17.18V13.18L12 17L5 13.18Z"/>
                  </svg>
                  <span data-i18n="aboutus.doctors.darwin.credentials.0">Doctor en Quiropráctica (DC)</span>
                </span>
                <span class="credential">
                  <svg class="doctor-credential-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                    <path d="M16 6L18.29 8.29L13.41 13.17L9.41 9.17L2 16.59L3.41 18L9.41 12L13.41 16L20.71 8.71L23 11V6H16Z"/>
                  </svg>
                  <span data-i18n="aboutus.doctors.darwin.credentials.1">Certificado en Rehabilitación Funcional</span>
                </span>
                <span class="credential">
                  <svg class="doctor-credential-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                    <path d="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3M9 17H7V10H9V17M13 17H11V7H13V17M17 17H15V13H17V17Z"/>
                  </svg>
                  <span data-i18n="aboutus.doctors.darwin.credentials.2">Especialista en Terapia Física</span>
                </span>
              </div>
              <div class="experience-info">
                <span class="experience-years" data-i18n="aboutus.doctors.darwin.experience">8 años de experiencia</span>
                <span class="cases-treated" data-i18n="aboutus.doctors.darwin.cases">Especialista en casos de lesiones laborales</span>
              </div>
            </div>
            <div class="card-footer">
              <a class="btn-schedule" href="/schedule" aria-label="Agendar con el Dr. Lee">
                <span data-i18n="common.schedule_consultation">Agendar Consulta</span>
                <svg class="arrow" viewBox="0 0 24 24" width="18" height="18">
                  <path d="M5 12h12m0 0l-4-4m4 4l-4 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>

          <!-- Perfil 3: Dra. Ana Ramírez -->
          <article class="profile-card" itemscope itemtype="https://schema.org/Physician">
            <div class="card-header">
              <div class="profile-image">
                <img
                  src="/assets/img/chiro3.jpeg"
                  alt="Dra. Ana Ramírez, Chiropractor"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
            <div class="profile-info">
              <h3 class="name" itemprop="name" data-i18n="aboutus.doctors.ana.name">Dra. Ana Ramírez</h3>
              <p class="title" data-i18n="aboutus.doctors.ana.title">Doctora Quiropráctica</p>
              <p class="specialty" data-i18n="aboutus.doctors.ana.specialty">Especialista en Manejo del Dolor y Quiropráctica</p>
            </div>
            <div class="card-body">
              <p class="bio" data-i18n="aboutus.doctors.ana.bio">
                Especialista en el tratamiento de lesiones cervicales y latigazo cervical causadas por accidentes automovilísticos. Con más de 12 años de experiencia, se enfoca en técnicas de quiropráctica avanzada y manejo integral del dolor cervical.
              </p>
              <div class="specialties">
                <h4 data-i18n="aboutus.doctors.ana.specialties.title">Especialidades Clínicas:</h4>
                <ul>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.ana.specialties.items.0">Terapia Quiropráctica</span>
                  </li>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.ana.specialties.items.1">Manejo del Dolor</span>
                  </li>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.ana.specialties.items.2">Terapia de Ultrasonido</span>
                  </li>
                  <li>
                    <svg class="specialty-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                      <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                    </svg>
                    <span data-i18n="aboutus.doctors.ana.specialties.items.3">Rehabilitación de Lesiones</span>
                  </li>
                </ul>
              </div>
              <div class="credentials">
                <span class="credential">
                  <svg class="doctor-credential-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                    <path d="M12 3L1 9L12 15L21 12.09V17H23V9M5 13.18V17.18L12 21L19 17.18V13.18L12 17L5 13.18Z"/>
                  </svg>
                  <span data-i18n="aboutus.doctors.ana.credentials.0">Doctora en Quiropráctica (DC)</span>
                </span>
                <span class="credential">
                  <svg class="doctor-credential-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                    <path d="M14 2H6C4.9 2 4 2.9 4 4V20C4 21.1 4.9 22 6 22H18C19.1 22 20 21.1 20 20V8L14 2M18 20H6V4H13V9H18V20Z"/>
                  </svg>
                  <span data-i18n="aboutus.doctors.ana.credentials.1">Certificada en Trauma Vehicular</span>
                </span>
                <span class="credential">
                  <svg class="doctor-credential-icon" viewBox="0 0 24 24" width="16" height="16" fill="#7A2E87">
                    <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z"/>
                  </svg>
                  <span data-i18n="aboutus.doctors.ana.credentials.2">Especialista en Lesiones Cervicales</span>
                </span>
              </div>
              <div class="experience-info">
                <span class="experience-years" data-i18n="aboutus.doctors.ana.experience">12 años de experiencia</span>
                <span class="cases-treated" data-i18n="aboutus.doctors.ana.cases">Más de 2,500 casos de accidentes tratados</span>
              </div>
            </div>
            <div class="card-footer">
              <a class="btn-schedule" href="/schedule" aria-label="Agendar con la Dra. Ramírez">
                <span data-i18n="common.schedule_consultation">Agendar Consulta</span>
                <svg class="arrow" viewBox="0 0 24 24" width="18" height="18">
                  <path d="M5 12h12m0 0l-4-4m4 4l-4 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>


        </div>
      </div>
    </section>

    <!-- Sección de Credenciales -->
    <section class="credentials-section" data-animate="fade-up" data-delay="100">
      <div class="container">
        <div class="credentials-content">
          <div class="credentials-header">
            <span class="eyebrow">✓ <span data-i18n="aboutus.credentials.badge">Certificaciones</span></span>
            <h2 data-i18n="aboutus.credentials.title">Nuestras Credenciales Profesionales</h2>
            <p class="lede" data-i18n="aboutus.credentials.subtitle">
              Nuestro equipo mantiene las más altas certificaciones y está comprometido con la educación continua para brindar la mejor atención quiropráctica.
            </p>
          </div>
          
          <div class="credentials-grid">
            <div class="credential-item" data-animate="fade-up" data-delay="200">
              <div class="credential-icon">
                <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#7A2E87" stroke-width="1.5">
                  <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                  <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                </svg>
              </div>
              <h3 data-i18n="aboutus.credentials.items.education.title">Educación Doctoral</h3>
              <p data-i18n="aboutus.credentials.items.education.description">Todos nuestros doctores poseen títulos de Doctor en Quiropráctica (DC) de universidades acreditadas reconocidas nacionalmente.</p>
            </div>
            
            <div class="credential-item" data-animate="fade-up" data-delay="300">
              <div class="credential-icon">
                <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#7A2E87" stroke-width="1.5">
                  <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                  <circle cx="12" cy="16" r="1"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </div>
              <h3 data-i18n="aboutus.credentials.items.licenses.title">Licencias Estatales</h3>
              <p data-i18n="aboutus.credentials.items.licenses.description">Licenciados y certificados por el estado para ejercer la quiropráctica con los más altos estándares de seguridad y ética.</p>
            </div>
            
            <div class="credential-item" data-animate="fade-up" data-delay="400">
              <div class="credential-icon">
                <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#7A2E87" stroke-width="1.5">
                  <polygon points="12,2 15.09,8.26 22,9 17,14 18.18,21 12,17.77 5.82,21 7,14 2,9 8.91,8.26"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              </div>
              <h3 data-i18n="aboutus.credentials.items.specialties.title">Especialidades Avanzadas</h3>
              <p data-i18n="aboutus.credentials.items.specialties.description">Certificaciones especializadas en rehabilitación, medicina deportiva, manejo del dolor y técnicas de vanguardia.</p>
            </div>
            
            <div class="credential-item" data-animate="fade-up" data-delay="500">
              <div class="credential-icon">
                <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#7A2E87" stroke-width="1.5">
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                </svg>
              </div>
              <h3 data-i18n="aboutus.credentials.items.education_continuous.title">Educación Continua</h3>
              <p data-i18n="aboutus.credentials.items.education_continuous.description">Participación regular en seminarios, conferencias y cursos para mantenerse al día con las últimas técnicas y tratamientos.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action Final -->
    <section class="final-cta-section" data-animate="fade-up" data-delay="100">
      <div class="container">
        <div class="cta-content">
          <div class="cta-header">
            <h2 data-i18n="aboutus.cta.title">¿Listo para Comenzar tu Recuperación?</h2>
            <p class="cta-subtitle" data-i18n="aboutus.cta.subtitle">
              Nuestro equipo de expertos quiroprácticos está aquí para ayudarte a recuperar tu bienestar y volver a las actividades que amas.
            </p>
          </div>
          
          <div class="cta-features">
            <div class="cta-feature" data-animate="fade-up" data-delay="200">
              <div class="feature-icon">▲</div>
              <span data-i18n="aboutus.cta.features.0">Consulta inicial gratuita</span>
            </div>
            <div class="cta-feature" data-animate="fade-up" data-delay="300">
              <div class="feature-icon">♦</div>
              <span data-i18n="aboutus.cta.features.1">Citas disponibles hoy</span>
            </div>
            <div class="cta-feature" data-animate="fade-up" data-delay="400">
              <div class="feature-icon">★</div>
              <span data-i18n="aboutus.cta.features.2">Planes de tratamiento personalizados</span>
            </div>
          </div>
          
          <div class="cta-actions" data-animate="fade-up" data-delay="500">
            <a href="/schedule" class="btn-primary-cta">
              <span data-i18n="aboutus.cta.buttons.schedule">Agendar Consulta Gratuita</span>
