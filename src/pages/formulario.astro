---
// src/pages/formulario.astro
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { t, getServerLanguage } from '../i18n/index.ts';
import esTranslations from '../i18n/es.json';
import enTranslations from '../i18n/en.json';

const currentLang = 'es'; // Forzar español por defecto
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '';

// Teléfono (para el botón auxiliar)
const PHONE_DISPLAY = '385-242-8571';

---

<Layout>
  <main class="ref page">
    <!-- ===== Encabezado ===== -->
    <header class="hero-min">
      <div class="hero-min__bg" aria-hidden="true"></div>
      <div class="container hero-min__content">
        <h1 data-i18n="formulario_page.hero.title">{t('formulario_page.hero.title', currentLang)}</h1>
        <p class="w-full text-nowrap" data-i18n="formulario_page.hero.subtitle">{t('formulario_page.hero.subtitle', currentLang)}</p>
      </div>
    </header>

    <!-- ===== Formulario ===== -->
    <section class="wrap">
      <form
        id="referral-form"
        class="card"
        action="/api/form-webhook"
        method="POST"
        accept-charset="UTF-8"
        autocomplete="on"
        enctype="multipart/form-data"
        novalidate
      >
        <!-- ===== Ocultos técnicos ===== -->
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
        <input type="hidden" name="page" value="Formulario de referencia" />

        <!-- ===== Barra de progreso (sticky en mobile) ===== -->
        <div class="form-progress" data-progress aria-live="polite">
          <div class="form-progress-row">
            <span class="form-progress-label" data-i18n="formulario_page.progress.label">{t('formulario_page.progress.label', currentLang)}</span>
            <span class="form-progress-stat">
              <span data-progress-done>0</span>
              <span data-i18n="formulario_page.progress.of">{t('formulario_page.progress.of', currentLang)}</span>
              <span data-progress-total>0</span>
              <span data-i18n="formulario_page.progress.fields_required">{t('formulario_page.progress.fields_required', currentLang)}</span>
              <span class="form-progress-pct"><span data-progress-pct>0</span>%</span>
            </span>
          </div>
          <div class="form-progress-bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
            <span class="form-progress-fill" data-progress-fill></span>
          </div>
        </div>


        <!-- ===== Información del Paciente (Simplificada) ===== -->
        <fieldset>
          <legend data-i18n="formulario_page.patient_info.title">{t('formulario_page.patient_info.title', currentLang)}</legend>
          <p class="fieldset-hint" data-i18n="formulario_page.section_hints.patient_info">{t('formulario_page.section_hints.patient_info', currentLang)}</p>

          <div class="form-row">
            <div class="form-group">
              <label for="first_name" data-i18n="formulario_page.patient_info.first_name">{t('formulario_page.patient_info.first_name', currentLang)}</label>
              <input type="text" id="first_name" name="first_name" required />
            </div>
            <div class="form-group">
              <label for="middle_name" data-i18n="formulario_page.patient_info.middle_name">{t('formulario_page.patient_info.middle_name', currentLang)}</label>
              <input type="text" id="middle_name" name="middle_name" />
            </div>
            <div class="form-group">
              <label for="last_name" data-i18n="formulario_page.patient_info.last_name">{t('formulario_page.patient_info.last_name', currentLang)}</label>
              <input type="text" id="last_name" name="last_name" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="date_of_birth" data-i18n="formulario_page.patient_info.date_of_birth">{t('formulario_page.patient_info.date_of_birth', currentLang)}</label>
              <input type="date" id="date_of_birth" name="date_of_birth" required />
            </div>
            <div class="form-group">
              <label for="gender" data-i18n="formulario_page.patient_info.gender">{t('formulario_page.patient_info.gender', currentLang)}</label>
              <select id="gender" name="gender" required>
                <option value="" data-i18n="formulario_page.patient_info.gender_select">{t('formulario_page.patient_info.gender_select', currentLang)}</option>
                <option value="male" data-i18n="formulario_page.patient_info.gender_male">{t('formulario_page.patient_info.gender_male', currentLang)}</option>
                <option value="female" data-i18n="formulario_page.patient_info.gender_female">{t('formulario_page.patient_info.gender_female', currentLang)}</option>
                <option value="other" data-i18n="formulario_page.patient_info.gender_other">{t('formulario_page.patient_info.gender_other', currentLang)}</option>
              </select>
            </div>
            <div class="form-group">
              <label for="age" data-i18n="formulario_page.patient_info.age">{t('formulario_page.patient_info.age', currentLang)}</label>
              <input type="number" id="age" name="age" min="1" max="120" required />
            </div>
          </div>
        </fieldset>


        <!-- ===== Dirección (Simplificada) ===== -->
        <fieldset>
          <legend data-i18n="formulario_page.address.title">{t('formulario_page.address.title', currentLang)}</legend>
          <p class="fieldset-hint" data-i18n="formulario_page.section_hints.address">{t('formulario_page.section_hints.address', currentLang)}</p>

          <div class="form-group">
            <label for="address" data-i18n="formulario_page.address.address">{t('formulario_page.address.address', currentLang)}</label>
            <input type="text" id="address" name="address" required />
          </div>

          <div class="form-group">
            <label for="address2" data-i18n="formulario_page.address.address2">{t('formulario_page.address.address2', currentLang)}</label>
            <input type="text" id="address2" name="address2" />
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="city" data-i18n="formulario_page.address.city">{t('formulario_page.address.city', currentLang)}</label>
              <input type="text" id="city" name="city" required />
            </div>
            <div class="form-group">
              <label for="state" data-i18n="formulario_page.address.state">{t('formulario_page.address.state', currentLang)}</label>
              <input type="text" id="state" name="state" required />
            </div>
            <div class="form-group">
              <label for="zip" data-i18n="formulario_page.address.zip">{t('formulario_page.address.zip', currentLang)}</label>
              <input type="text" id="zip" name="zip" required inputmode="numeric" maxlength="5" pattern="[0-9]{5}" aria-describedby="zip_hint" />
              <small id="zip_hint" class="field-hint" data-i18n="formulario_page.field_hints.zip">{t('formulario_page.field_hints.zip', currentLang)}</small>
            </div>
          </div>
        </fieldset>

        <!-- ===== Información de Contacto del Paciente (Nueva sección) ===== -->
        <fieldset>
          <legend data-i18n="formulario_page.patient_contact.title">{t('formulario_page.patient_contact.title', currentLang)}</legend>
          <p class="fieldset-hint" data-i18n="formulario_page.section_hints.patient_contact">{t('formulario_page.section_hints.patient_contact', currentLang)}</p>

          <div class="form-row">
            <div class="form-group">
              <label for="home_phone" data-i18n="formulario_page.patient_contact.home_phone">{t('formulario_page.patient_contact.home_phone', currentLang)}</label>
              <input type="tel" id="home_phone" name="home_phone" inputmode="tel" autocomplete="tel-national" />
            </div>
            <div class="form-group">
              <label for="cell_phone" data-i18n="formulario_page.patient_contact.cell_phone">{t('formulario_page.patient_contact.cell_phone', currentLang)}</label>
              <input type="tel" id="cell_phone" name="cell_phone" required inputmode="tel" autocomplete="tel" aria-describedby="cell_phone_hint" />
              <small id="cell_phone_hint" class="field-hint" data-i18n="formulario_page.field_hints.cell_phone">{t('formulario_page.field_hints.cell_phone', currentLang)}</small>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="work_phone" data-i18n="formulario_page.patient_contact.work_phone">{t('formulario_page.patient_contact.work_phone', currentLang)}</label>
              <input type="tel" id="work_phone" name="work_phone" inputmode="tel" />
            </div>
            <div class="form-group">
              <label for="email" data-i18n="formulario_page.patient_contact.email">{t('formulario_page.patient_contact.email', currentLang)}</label>
              <input type="email" id="email" name="email" required autocomplete="email" aria-describedby="email_hint" />
              <small id="email_hint" class="field-hint" data-i18n="formulario_page.field_hints.email">{t('formulario_page.field_hints.email', currentLang)}</small>
            </div>
          </div>
        </fieldset>

        <!-- ===== Información del Incidente (Nueva sección) ===== -->
        <fieldset>
          <legend data-i18n="formulario_page.incident_info.title">{t('formulario_page.incident_info.title', currentLang)}</legend>
          <p class="fieldset-hint" data-i18n="formulario_page.section_hints.incident_info">{t('formulario_page.section_hints.incident_info', currentLang)}</p>

          <div class="form-group">
            <label data-i18n="formulario_page.incident_info.accident_type">{t('formulario_page.incident_info.accident_type', currentLang)}</label>
            <div class="radio-group">
              <label class="radio-option">
                <input type="radio" name="accident_type" value="car" required />
                <span data-i18n="formulario_page.incident_info.type_car">{t('formulario_page.incident_info.type_car', currentLang)}</span>
              </label>
              <label class="radio-option">
                <input type="radio" name="accident_type" value="bicycle" required />
                <span data-i18n="formulario_page.incident_info.type_bicycle">{t('formulario_page.incident_info.type_bicycle', currentLang)}</span>
              </label>
              <label class="radio-option">
                <input type="radio" name="accident_type" value="motorcycle" required />
                <span data-i18n="formulario_page.incident_info.type_motorcycle">{t('formulario_page.incident_info.type_motorcycle', currentLang)}</span>
              </label>
              <label class="radio-option">
                <input type="radio" name="accident_type" value="pedestrian" required />
                <span data-i18n="formulario_page.incident_info.type_pedestrian">{t('formulario_page.incident_info.type_pedestrian', currentLang)}</span>
              </label>
              <label class="radio-option">
                <input type="radio" name="accident_type" value="other" required />
                <span data-i18n="formulario_page.incident_info.type_other">{t('formulario_page.incident_info.type_other', currentLang)}</span>
              </label>
            </div>
          </div>

          <div class="form-group" id="other_accident_type" style="display: none;">
            <label for="other_accident_specify" data-i18n="formulario_page.incident_info.other_specify">{t('formulario_page.incident_info.other_specify', currentLang)}</label>
            <input type="text" id="other_accident_specify" name="other_accident_specify" />
          </div>

          <div class="form-group">
            <label data-i18n="formulario_page.incident_info.legal_representation">{t('formulario_page.incident_info.legal_representation', currentLang)}</label>
            <div class="radio-group">
              <label class="radio-option">
                <input type="radio" name="has_legal_representation" value="no" required />
                <span data-i18n="formulario_page.incident_info.legal_no">{t('formulario_page.incident_info.legal_no', currentLang)}</span>
              </label>
              <label class="radio-option">
                <input type="radio" name="has_legal_representation" value="yes" required />
                <span data-i18n="formulario_page.incident_info.legal_yes">{t('formulario_page.incident_info.legal_yes', currentLang)}</span>
              </label>
            </div>
          </div>

          <div class="form-group" id="legal_representation_details" style="display: none;">
            <label for="lawyer_firm_name" data-i18n="formulario_page.incident_info.lawyer_firm_name">{t('formulario_page.incident_info.lawyer_firm_name', currentLang)}</label>
            <input type="text" id="lawyer_firm_name" name="lawyer_firm_name" />
          </div>

          <div class="form-row" id="legal_representation_more" style="display: none;">
            <div class="form-group">
              <label for="lawyer_phone" data-i18n="formulario_page.incident_info.lawyer_phone">{t('formulario_page.incident_info.lawyer_phone', currentLang)}</label>
              <input type="tel" id="lawyer_phone" name="lawyer_phone" />
            </div>
            <div class="form-group">
              <label for="paralegal_name" data-i18n="formulario_page.incident_info.paralegal_name">{t('formulario_page.incident_info.paralegal_name', currentLang)}</label>
              <input type="text" id="paralegal_name" name="paralegal_name" />
            </div>
          </div>

          <div class="form-row" id="legal_representation_contacts" style="display: none;">
            <div class="form-group">
              <label for="paralegal_phone" data-i18n="formulario_page.incident_info.paralegal_phone">{t('formulario_page.incident_info.paralegal_phone', currentLang)}</label>
              <input type="tel" id="paralegal_phone" name="paralegal_phone" />
            </div>
            <div class="form-group">
              <label for="paralegal_email" data-i18n="formulario_page.incident_info.paralegal_email">{t('formulario_page.incident_info.paralegal_email', currentLang)}</label>
              <input type="email" id="paralegal_email" name="paralegal_email" />
            </div>
          </div>

          <div class="form-group">
            <label for="accident_date" data-i18n="formulario_page.incident_info.accident_date">{t('formulario_page.incident_info.accident_date', currentLang)}</label>
            <input type="date" id="accident_date" name="accident_date" required aria-describedby="accident_date_hint" />
            <small id="accident_date_hint" class="field-hint" data-i18n="formulario_page.field_hints.accident_date">{t('formulario_page.field_hints.accident_date', currentLang)}</small>
          </div>

          <div class="form-group">
            <label for="additional_notes" data-i18n="formulario_page.incident_info.additional_notes">{t('formulario_page.incident_info.additional_notes', currentLang)}</label>
            <textarea id="additional_notes" name="additional_notes" rows="4" aria-describedby="additional_notes_hint"></textarea>
            <small id="additional_notes_hint" class="field-hint" data-i18n="formulario_page.field_hints.additional_notes">{t('formulario_page.field_hints.additional_notes', currentLang)}</small>
          </div>
        </fieldset>

        <fieldset>
          <legend data-i18n="formulario_page.insurance_info.title">{t('formulario_page.insurance_info.title', currentLang)}</legend>
          <p class="fieldset-hint" data-i18n="formulario_page.section_hints.insurance_info">{t('formulario_page.section_hints.insurance_info', currentLang)}</p>
          <div class="form-group">
            <label for="insurance_name" data-i18n="formulario_page.insurance_info.insurance_name">{t('formulario_page.insurance_info.insurance_name', currentLang)}</label>
            <input type="text" id="insurance_name" name="insurance_name" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="insurance_policy_number" data-i18n="formulario_page.insurance_info.policy_number">{t('formulario_page.insurance_info.policy_number', currentLang)}</label>
              <input type="text" id="insurance_policy_number" name="insurance_policy_number" />
            </div>
            <div class="form-group">
              <label for="insurance_phone" data-i18n="formulario_page.insurance_info.insurance_phone">{t('formulario_page.insurance_info.insurance_phone', currentLang)}</label>
              <input type="tel" id="insurance_phone" name="insurance_phone" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="adjuster_name" data-i18n="formulario_page.insurance_info.adjuster_name">{t('formulario_page.insurance_info.adjuster_name', currentLang)}</label>
              <input type="text" id="adjuster_name" name="adjuster_name" />
            </div>
            <div class="form-group">
              <label for="adjuster_phone" data-i18n="formulario_page.insurance_info.adjuster_phone">{t('formulario_page.insurance_info.adjuster_phone', currentLang)}</label>
              <input type="tel" id="adjuster_phone" name="adjuster_phone" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="adjuster_email" data-i18n="formulario_page.insurance_info.adjuster_email">{t('formulario_page.insurance_info.adjuster_email', currentLang)}</label>
              <input type="email" id="adjuster_email" name="adjuster_email" />
            </div>
            <div class="form-group">
              <label for="claim_number" data-i18n="formulario_page.insurance_info.claim_number">{t('formulario_page.insurance_info.claim_number', currentLang)}</label>
              <input type="text" id="claim_number" name="claim_number" />
            </div>
          </div>
        </fieldset>

        <!-- ===== Información del Referido (Simplificada) ===== -->
        <fieldset>
          <legend data-i18n="formulario_page.referral_info.title">{t('formulario_page.referral_info.title', currentLang)}</legend>
          <p class="fieldset-hint" data-i18n="formulario_page.section_hints.referral_info">{t('formulario_page.section_hints.referral_info', currentLang)}</p>

          <div class="form-row">
            <div class="form-group">
              <label for="referral_first_name" data-i18n="formulario_page.referral_info.first_name">{t('formulario_page.referral_info.first_name', currentLang)}</label>
              <input type="text" id="referral_first_name" name="referral_first_name" required />
            </div>
            <div class="form-group">
              <label for="referral_last_name" data-i18n="formulario_page.referral_info.last_name">{t('formulario_page.referral_info.last_name', currentLang)}</label>
              <input type="text" id="referral_last_name" name="referral_last_name" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="referral_cell_phone" data-i18n="formulario_page.referral_info.cell_phone">{t('formulario_page.referral_info.cell_phone', currentLang)}</label>
              <input type="tel" id="referral_cell_phone" name="referral_cell_phone" required inputmode="tel" aria-describedby="referral_phone_hint" />
              <small id="referral_phone_hint" class="field-hint" data-i18n="formulario_page.field_hints.referral_phone">{t('formulario_page.field_hints.referral_phone', currentLang)}</small>
            </div>
            <div class="form-group">
              <label for="referral_email" data-i18n="formulario_page.referral_info.email">{t('formulario_page.referral_info.email', currentLang)}</label>
              <input type="email" id="referral_email" name="referral_email" required />
            </div>
          </div>
        </fieldset>

        <!-- ===== Declaración de Autenticidad con Firma ===== -->
        <fieldset>
          <legend data-i18n="formulario_page.authenticity.title">{t('formulario_page.authenticity.title', currentLang)}</legend>
          <p class="fieldset-hint" data-i18n="formulario_page.section_hints.authenticity">{t('formulario_page.section_hints.authenticity', currentLang)}</p>

          <!-- Texto de Declaración de Autenticidad -->
          <div class="form-group">
            <p class="authenticity-text" data-i18n="formulario_page.authenticity.statement">{t('formulario_page.authenticity.statement', currentLang)}</p>
          </div>

          <!-- Canvas de Firma -->
          <div class="form-group">
            <label data-i18n="formulario_page.signature.signature_canvas">{t('formulario_page.signature.signature_canvas', currentLang)}</label>
            <div class="signature-container">
              <canvas id="signature-canvas" width="400" height="200"></canvas>
              <div class="signature-placeholder" data-i18n="formulario_page.signature.signature_placeholder">{t('formulario_page.signature.signature_placeholder', currentLang)}</div>
              <div class="signature-buttons">
                <button type="button" id="clear-signature" class="btn btn-secondary" data-i18n="formulario_page.signature.clear">{t('formulario_page.signature.clear', currentLang)}</button>
              </div>
              <div class="signature-error" id="signature-error" style="display: none;" data-i18n="formulario_page.signature.signature_required">{t('formulario_page.signature.signature_required', currentLang)}</div>
            </div>
            <input type="hidden" id="signature_data" name="signature_data" />
          </div>

          <!-- Checkbox de Consentimiento -->
          <div class="form-group">
            <div class="checkbox-group compact">
              <input type="checkbox" id="privacy_consent" name="privacy_consent" required />
              <label for="privacy_consent">
                <span data-i18n="formulario_page.authenticity.consent_checkbox_new">{t('formulario_page.authenticity.consent_checkbox_new', currentLang)}</span>
                <a href="/privacy" target="_blank" data-i18n="formulario_page.authenticity.privacy_policy">{t('formulario_page.authenticity.privacy_policy', currentLang)}</a>
              </label>
            </div>
          </div>
        </fieldset>

        <p id="required-legend" class="required-legend" data-i18n="formulario.required_legend">{t('formulario.required_legend', currentLang)}</p>

        <!-- ===== Estado final: incompleto / listo (captcha + envío) ===== -->
        <div class="form-end" data-form-end>
          <!-- Estado incompleto -->
          <div class="form-end-incomplete" data-form-end-incomplete>
            <span class="form-end-ico" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="20" height="20">
                <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"/>
                <path d="M12 8v4M12 16h.01" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </span>
            <div class="form-end-text">
              <strong data-i18n="formulario_page.form_end.incomplete_title">{t('formulario_page.form_end.incomplete_title', currentLang)}</strong>
              <span data-i18n="formulario_page.form_end.incomplete_sub">{t('formulario_page.form_end.incomplete_sub', currentLang)}</span>
            </div>
          </div>

          <!-- Estado listo: captcha + submit -->
          <div class="form-end-ready" data-form-end-ready>
            <div class="form-end-header">
              <span class="form-end-ico form-end-ico-ok" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20">
                  <path d="M5 13l4 4L19 7" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <div class="form-end-text">
                <strong data-i18n="formulario_page.form_end.ready_title">{t('formulario_page.form_end.ready_title', currentLang)}</strong>
                <span data-i18n="formulario_page.form_end.ready_sub">{t('formulario_page.form_end.ready_sub', currentLang)}</span>
              </div>
            </div>

            <div class="form-group recaptcha-group">
              <div class="g-recaptcha" data-sitekey={recaptchaSiteKey} data-theme="light"></div>
              <p id="recaptcha-error" class="recaptcha-error" aria-live="polite"></p>
            </div>

            <div class="form-actions">
              <button id="ref-submit" type="submit" class="btn btn-primary">{t('formulario.submit', currentLang)}</button>
            </div>
          </div>
        </div>

        <!-- ===== Mensajes de Estado ===== -->
        <div id="form-messages" style="display: none;">
          <div class="success-message" data-i18n="formulario_page.submit.success">{t('formulario_page.submit.success', currentLang)}</div>
          <div class="error-message" data-i18n="formulario_page.submit.error">{t('formulario_page.submit.error', currentLang)}</div>
        </div>
      </form>
    </section>


  </main>

  <!-- Footer reducido -->
  <div class="footer-compact">
    <Footer />
