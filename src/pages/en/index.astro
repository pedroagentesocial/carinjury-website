---
// English version of the homepage
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import FeatureIcons from '../../components/FeatureIcons.astro';
import AboutVideo from '../../components/AboutVideo.astro';
import Services from '../../components/Services.astro';
import Testimonials from '../../components/Testimonials.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import MapContact from '../../components/MapContact.astro';
import Footer from '../../components/Footer.astro';
import { setLanguage } from '../../i18n/index.ts';

// Set language to English for this page
setLanguage('en');
---

<Layout>
  <main>
    <Hero />
    <FeatureIcons />
    <AboutVideo />
    <Services />
    <Testimonials />
    <FinalCTA />
    <MapContact />
  </main>
  <Footer />
</Layout>

<script>
  // Set language on client side
  if (typeof window !== 'undefined') {
    localStorage.setItem('language', 'en');
    if (window.i18nClient) {
      window.i18nClient.currentLang = 'en';
      window.i18nClient.updateAllTranslations();
    }
  }
</script>