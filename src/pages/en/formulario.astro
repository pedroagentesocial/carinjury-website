---
// English version of formulario page
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { t, setLanguage } from '../../i18n/index.ts';

// Set language to English for this page
setLanguage('en');
const currentLang = 'en';

// Load translations for client-side use
const esTranslations = await import('../../i18n/es.json');
const enTranslations = await import('../../i18n/en.json');
---

<Layout>
  <main class="form-page">
    <!-- Hero Section -->
    <section class="hero-form">
      <div class="container">
        <h1 data-i18n="formulario_page.hero.title">{t('formulario_page.hero.title', currentLang)}</h1>
        <p data-i18n="formulario_page.hero.subtitle">{t('formulario_page.hero.subtitle', currentLang)}</p>
      </div>
    </section>

    <!-- Form Section -->
    <section class="form-section">
      <div class="container">
        <form id="contact-form" class="contact-form">
          <!-- Personal Information -->
          <div class="form-group">
            <label for="first_name" data-i18n="form.fields.first_name">{t('form.fields.first_name', currentLang)}</label>
            <input type="text" id="first_name" name="first_name" required>
          </div>

          <div class="form-group">
            <label for="last_name" data-i18n="form.fields.last_name">{t('form.fields.last_name', currentLang)}</label>
            <input type="text" id="last_name" name="last_name" required>
          </div>

          <div class="form-group">
            <label for="phone" data-i18n="form.fields.phone">{t('form.fields.phone', currentLang)}</label>
            <input type="tel" id="phone" name="phone" required>
          </div>

          <div class="form-group">
            <label for="email" data-i18n="form.fields.email">{t('form.fields.email', currentLang)}</label>
            <input type="email" id="email" name="email" required>
          </div>

          <!-- Accident Information -->
          <div class="form-group">
            <label data-i18n="form.fields.accident_type">{t('form.fields.accident_type', currentLang)}</label>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="accident_type" value="car" required>
                <span data-i18n="form.fields.accident_types.car">{t('form.fields.accident_types.car', currentLang)}</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="accident_type" value="motorcycle" required>
                <span data-i18n="form.fields.accident_types.motorcycle">{t('form.fields.accident_types.motorcycle', currentLang)}</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="accident_type" value="truck" required>
                <span data-i18n="form.fields.accident_types.truck">{t('form.fields.accident_types.truck', currentLang)}</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="accident_type" value="pedestrian" required>
                <span data-i18n="form.fields.accident_types.pedestrian">{t('form.fields.accident_types.pedestrian', currentLang)}</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="accident_type" value="bicycle" required>
                <span data-i18n="form.fields.accident_types.bicycle">{t('form.fields.accident_types.bicycle', currentLang)}</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="accident_type" value="other" required>
                <span data-i18n="form.fields.accident_types.other">{t('form.fields.accident_types.other', currentLang)}</span>
              </label>
            </div>
          </div>

          <div class="form-group">
            <label for="accident_date" data-i18n="form.fields.accident_date">{t('form.fields.accident_date', currentLang)}</label>
            <input type="date" id="accident_date" name="accident_date" required>
          </div>

          <div class="form-group">
            <label for="description" data-i18n="form.fields.description">{t('form.fields.description', currentLang)}</label>
            <textarea id="description" name="description" rows="4" data-i18n="form.fields.description_placeholder" placeholder="{t('form.fields.description_placeholder', currentLang)}"></textarea>
          </div>

          <!-- Discovery Source -->
          <div class="form-group">
            <label for="discovery" data-i18n="form.fields.discovery_source">{t('form.fields.discovery_source', currentLang)}</label>
            <select name="discovery_source" id="discovery" required>
              <option value="" data-i18n="form.fields.select_option">{t('form.fields.select_option', currentLang)}</option>
              <option value="google_search">Google (search)</option>
              <option value="google_maps">Google Maps</option>
              <option value="facebook">Facebook</option>
              <option value="instagram">Instagram</option>
              <option value="tiktok">TikTok</option>
              <option value="x_twitter">X (Twitter)</option>
              <option value="youtube">YouTube</option>
              <option value="ads">Ad (Google / Facebook / Instagram)</option>
              <option value="ref_amigo">Referral: friend or family</option>
              <option value="ref_abogado">Referral: lawyer</option>
              <option value="ref_medico">Referral: doctor / clinic</option>
              <option value="letrero">Saw the sign / passed by the clinic</option>
              <option value="evento">Event / community</option>
              <option value="radio_tv">Radio / TV</option>
              <option value="otro">Other</option>
            </select>
          </div>

          <!-- Submit Button -->
          <button type="submit" id="submit-btn" class="submit-btn">
            <span id="submit-text" data-i18n="form.submit_button">{t('form.submit_button', currentLang)}</span>
            <span id="loading-text" style="display: none;" data-i18n="form.sending">{t('form.sending', currentLang)}</span>
          </button>

          <!-- Messages -->
          <div id="form-messages" style="display: none;">
            <div class="success-message" data-i18n="formulario_page.submit.success">{t('formulario_page.submit.success', currentLang)}</div>
            <div class="error-message" data-i18n="formulario_page.submit.error">{t('formulario_page.submit.error', currentLang)}</div>
          </div>
        </form>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <div class="footer-compact">
    <Footer />
  </div>

  <!-- Script para internacionalización dinámica -->
  <script define:vars={{ esTranslations, enTranslations }}>
    // Embebemos las traducciones en el cliente
    window.translations = {
      es: esTranslations,
      en: enTranslations
    };
  </script>
  
  <script src="/src/utils/i18n-client.js"></script>
  <script>
    // Set language on client side and initialize
    document.addEventListener('DOMContentLoaded', function() {
      // Set language to English
      localStorage.setItem('language', 'en');
      
      // Initialize i18n client
      if (window.i18nClient) {
        window.i18nClient.currentLang = 'en';
        window.i18nClient.init();
      }
    });
  </script>
</Layout>

<style>
  .form-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }
  
  .hero-form {
    padding: 6rem 0 4rem;
    text-align: center;
    color: white;
  }
  
  .hero-form h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  
  .hero-form p {
    font-size: 1.2rem;
    opacity: 0.9;
  }
  
  .form-section {
    padding: 2rem 0 4rem;
  }
  
  .container {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  
  .contact-form {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }
  
  .form-group {
    margin-bottom: 1.5rem;
  }
  
  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: #374151;
  }
  
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }
  
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  }
  
  .radio-group {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.5rem;
  }
  
  .radio-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 6px;
    transition: background-color 0.3s ease;
  }
  
  .radio-label:hover {
    background: #f3f4f6;
  }
  
  .radio-label input[type="radio"] {
    width: auto;
    margin: 0;
  }
  
  .submit-btn {
    width: 100%;
    padding: 1rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
  }
  
  .success-message {
    color: #059669;
    background: #d1fae5;
    padding: 1rem;
    border-radius: 8px;
    margin-top: 1rem;
  }
  
  .error-message {
    color: #dc2626;
    background: #fee2e2;
    padding: 1rem;
    border-radius: 8px;
    margin-top: 1rem;
  }
  
  .footer-compact {
    margin-top: -2rem;
  }
</style>