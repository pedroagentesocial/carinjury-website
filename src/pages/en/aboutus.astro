---
// English version of aboutus page
import Layout from '../../layouts/Layout.astro';
import AboutVideo from '../../components/AboutVideo.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import MapContact from '../../components/MapContact.astro';
import Footer from '../../components/Footer.astro';
import { setLanguage, t } from '../../i18n/index.ts';

// Set language to English for this page
setLanguage('en');
const currentLang = 'en';

// Imagen del hero
const HERO_IMG = '/assets/img/NewHero.jpeg';
---

<Layout>
  <main class="about page">
    <!-- ===== Hero Section - Quiroprácticos Especializados ===== -->
    <header class="hero-chiro">
      <div class="hero-chiro__bg" aria-hidden="true">
        <img src={HERO_IMG} alt="" loading="lazy" decoding="async" />
        <div class="veil" aria-hidden="true"></div>
      </div>
      <div class="container hero-chiro__content">
        <div class="hero-badge">
          <span class="badge-icon">●</span>
          <span data-i18n="aboutus.hero.badge">{t('aboutus.hero.badge', currentLang)}</span>
        </div>
        <h1 data-i18n="aboutus.hero.title">{t('aboutus.hero.title', currentLang)}</h1>
        <p data-i18n="aboutus.hero.subtitle">{t('aboutus.hero.subtitle', currentLang)}</p>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-number">15+</span>
            <span class="stat-label" data-i18n="aboutus.hero.stats.experience">{t('aboutus.hero.stats.experience', currentLang)}</span>
          </div>
          <div class="stat">
            <span class="stat-number">2,500+</span>
            <span class="stat-label" data-i18n="aboutus.hero.stats.patients">{t('aboutus.hero.stats.patients', currentLang)}</span>
          </div>
        </div>
      </div>
    </header>
    
    <AboutVideo />
    <FinalCTA />
    <MapContact />
  </main>
  <Footer />
</Layout>

<script>
  // Set language to English on client side
  if (typeof window !== 'undefined') {
    localStorage.setItem('language', 'en');
    if ((window as any).i18nClient) {
      (window as any).i18nClient.currentLang = 'en';
      (window as any).i18nClient.updateAllTranslations();
    }
  }
</script>