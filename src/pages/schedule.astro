<script is:inline src="https://www.google.com/recaptcha/api.js" async defer></script>
<script is:inline>
  (function() {
    // Smooth scroll para enlaces internos
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });

    // Manejo del formulario
    const form = document.getElementById('schedule-form');
    const msg = document.getElementById('form-msg');
    const submit = document.getElementById('submit-btn');
    const dialog = document.getElementById('success-dialog');
    const recaptchaError = document.getElementById('recaptcha-error');
    const getLang = () => ((typeof window !== 'undefined' && localStorage.getItem('language')) || 'es');
    const tr = (key, fallback) => {
      const lang = getLang();
      const value = window.i18nClient?.t?.(key, lang);
      return (typeof value === 'string' && !value.includes('.')) ? value : fallback;
    };
    const smsConsent = document.getElementById('sms-consent');
    const smsConsentBlock = form ? form.querySelector('.sms-consent-group') : null;

    async function handleSubmit(ev) {
      if (smsConsentBlock) smsConsentBlock.classList.remove('error');
      if (smsConsent && !smsConsent.checked) {
        ev.preventDefault();
        if (smsConsentBlock) smsConsentBlock.classList.add('error');
        msg.textContent = tr('schedule_page.form.sms_consent_required', 'Debes aceptar el consentimiento SMS para continuar.');
        msg.className = 'form-message error';
        msg.style.display = 'block';
        return;
      }
      if (recaptchaError) recaptchaError.textContent = '';

      const grecaptchaApi = window.grecaptcha;
      if (typeof grecaptchaApi !== 'undefined') {
        const captchaResponse = grecaptchaApi.getResponse();
        if (!captchaResponse) {
          if (recaptchaError) {
            recaptchaError.textContent = tr('schedule_page.form.captcha_required', 'Por favor confirma que no eres un robot.');
          }
          return;
        }
      } else {
        if (recaptchaError) {
          recaptchaError.textContent = tr('schedule_page.form.captcha_missing_key', 'Configura PUBLIC_RECAPTCHA_SITE_KEY para habilitar reCAPTCHA.');
        }
        return;
      }
      ev.preventDefault();
      if (!form.reportValidity()) return;

      // Verificar honeypot
      const hp = form.querySelector('input[name="company"]');
      if (hp && hp.value.trim()) return;

      // Mostrar estado de carga
      msg.textContent = tr('schedule_page.form.sending_message', 'Enviando mensaje...');
      msg.className = 'form-message';
      msg.style.display = 'block';
      submit.disabled = true;
      submit.innerHTML = `
        <svg class="btn-icon animate-spin" viewBox="0 0 24 24" width="20" height="20">
          <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2" opacity="0.3"/>
          <path d="M12 2a10 10 0 0 1 10 10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        ${tr('schedule_page.form.sending', 'Enviando...')}
      `;

      try {
        const formData = new FormData(form);
        if (window.grecaptcha && !formData.get('g-recaptcha-response')) {
          formData.append('g-recaptcha-response', window.grecaptcha.getResponse());
        }
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          // Éxito
          msg.textContent = tr('schedule_page.form.success_message_inline', 'Se mandó correctamente la información.');
          msg.className = 'form-message success';
          form.reset();
          if (window.grecaptcha) window.grecaptcha.reset();
          
          // Mostrar modal después de un breve delay
          setTimeout(() => {
            dialog.showModal();
          }, 500);
        } else {
          throw new Error('Error en el envío');
        }
      } catch (error) {
        // Error
        msg.textContent = tr('schedule_page.form.error_message_inline', 'Error al enviar el mensaje. Por favor, intenta de nuevo.');
        msg.className = 'form-message error';
      } finally {
        // Restaurar botón
        submit.disabled = false;
        submit.innerHTML = `
          <svg class="btn-icon" viewBox="0 0 24 24" width="20" height="20">
            <path d="M22 2L11 13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M22 2L15 22L11 13L2 9L22 2Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          ${tr('schedule_page.form.submit', 'Enviar Solicitud')}
        `;
      }
    }

    if (form) {
      form.addEventListener('submit', handleSubmit);
    }

    // Animación de carga para el botón de envío
    const style = document.createElement('style');
    style.textContent = `
      @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      .animate-spin {
        animation: spin 1s linear infinite;
      }
    `;
    document.head.appendChild(style);
  })();
</script>
