</Layout>

<script>
  // Inicialización del cliente i18n para faq.astro
  document.addEventListener('DOMContentLoaded', () => {
    console.log('FAQ: DOMContentLoaded');
    
    // Esperar a que i18n esté listo o inicializarlo
    const initializeI18n = async () => {
      if (window.i18nClient) {
        console.log('FAQ: i18nClient already available');
        window.i18nClient.updateAllTranslations();
      } else {
        console.log('FAQ: Waiting for i18nReady event');
        window.addEventListener('i18nReady', () => {
          console.log('FAQ: i18nReady event received');
          if (window.i18nClient) {
            window.i18nClient.updateAllTranslations();
          }
        });
      }
    };
    
    initializeI18n();
  });
</script>

<style>
  /* ===== Variables / paleta del proyecto ===== */
  :root{
    --c1:#CEC6E2;  /* luz */
    --c2:#806AAA;  /* medio */
    --c3:#7A2E87;  /* oscuro */
    --c4:#BA93C2;  /* brand */

    --ink:#1A1D2A;
    --muted:#6B6F85;
    --surface:#ffffff;
    --line: rgba(26,29,42,.12);
    
    --hero-bg: linear-gradient(135deg, var(--c3) 0%, var(--c4) 100%);
    --card-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    --card-shadow-hover: 0 16px 48px rgba(0, 0, 0, 0.18);
    --animation-duration: 0.6s;
    --animation-ease: cubic-bezier(0.4, 0, 0.2, 1);
  }
  .container{ max-width:1200px; margin:0 auto; padding:0 16px; }

  /* ===== HERO MIN ===== */
   .hero-min{ position:relative; color:#fff; isolation:isolate; overflow:hidden; }
   .hero-min__bg{ position:absolute; inset:0; z-index:0; background: var(--c3); }
   .hero-min__content{ position:relative; z-index:1; padding: 120px 0 36px; text-align:center; opacity: 0; animation: fadeInUp 1s ease-out 0.3s forwards; }
   .hero-min__content h1{
     font-family:'Manrope',system-ui,sans-serif; font-weight:900;
     font-size: clamp(2.5rem, 5vw, 4rem); margin:0; text-align: center;
     line-height: 1.1;
   }
   .hero-min__content p{
     font-family:'Source Sans 3',system-ui,sans-serif; font-weight:700; margin:0; opacity:.96; text-align: center !important;
     width: 100%;
     display: block;
     max-width: none !important;
     margin-left: 0 !important;
     margin-right: 0 !important;
   }

  /* ===== INTRO SECTION ===== */
   .intro-section {
     padding: clamp(24px, 3vw, 40px) 0;
     background: linear-gradient(180deg, #faf8fc 0%, #ffffff 100%);
     text-align: center;
   }

   .intro-content {
     max-width: 800px;
     margin: 0 auto;
     opacity: 0;
     animation: fadeInUp 0.8s ease-out 0.6s forwards;
   }

   .section-title {
     font-family: 'Manrope', system-ui, sans-serif;
     font-weight: 900;
     font-size: clamp(1.8rem, 4vw, 2.5rem);
     color: var(--c3);
     margin: 0 0 1rem;
     line-height: 1.2;
     text-align: center;
   }

   .section-description {
     font-family: 'Source Sans 3', system-ui, sans-serif;
     font-size: 1.1rem;
     line-height: 1.6;
     color: var(--muted);
     margin: 0;
     text-align: center;
   }

  /* ===== FAQ SECTION ===== */
  .faq-section {
    padding: clamp(48px, 6vw, 80px) 0;
    background: var(--surface);
  }

  .faq-wrapper {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background: white;
    border-radius: 16px;
    border: 1px solid var(--line);
    overflow: hidden;
    transition: all 0.3s var(--animation-ease);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .faq-item:hover {
    box-shadow: var(--card-shadow);
    transform: translateY(-2px);
  }

  .faq-details {
    border: none;
    outline: none;
  }

  .faq-details[open] .faq-item {
    border-color: var(--c3);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    cursor: pointer;
    list-style: none;
    background: transparent;
    border: none;
    width: 100%;
    text-align: center;
    transition: all 0.3s var(--animation-ease);
    position: relative;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question:hover {
    background: rgba(122, 46, 135, 0.02);
  }

  .question-text {
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--ink);
    line-height: 1.4;
    text-align: center;
    margin: 0;
    flex: 1;
    padding-right: 1rem;
  }

  .question-icon {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--c3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s var(--animation-ease);
    flex-shrink: 0;
    position: relative;
  }

  .question-icon::before,
  .question-icon::after {
    content: '';
    position: absolute;
    background: white;
    transition: all 0.3s var(--animation-ease);
  }

  .question-icon::before {
    width: 12px;
    height: 2px;
  }

  .question-icon::after {
    width: 2px;
    height: 12px;
  }

  .faq-details[open] .question-icon {
    background: var(--c4);
    transform: rotate(45deg);
  }

  .faq-details[open] .question-icon::after {
    opacity: 0;
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: all 0.4s var(--animation-ease);
    opacity: 0;
  }

  .faq-details[open] .faq-answer {
    max-height: 500px;
    opacity: 1;
  }

  .answer-content {
    padding: 0 2rem 1.5rem;
    border-top: 1px solid var(--line);
    margin-top: 0;
  }

  .answer-content p {
    font-family: 'Source Sans 3', system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 1rem 0 0;
    text-align: center;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .hero-min__content {
      padding: 80px 0 24px;
    }

    .hero-min__content h1 {
      font-size: 1.8rem;
    }

    .intro-section,
    .faq-section {
      padding: 32px 0;
    }

    .faq-question {
      padding: 1.25rem 1.5rem;
    }

    .question-text {
      font-size: 1rem;
    }

    .answer-content {
      padding: 0 1.5rem 1.25rem;
    }

    .question-icon {
      width: 20px;
      height: 20px;
    }

    .question-icon::before {
      width: 10px;
    }

    .question-icon::after {
      height: 10px;
    }
  }

  @media (max-width: 480px) {
    .faq-question {
      padding: 1rem 1.25rem;
    }

    .answer-content {
      padding: 0 1.25rem 1rem;
    }

    .question-text {
      font-size: 0.95rem;
      margin-right: 0.75rem;
    }
  }

  /* ===== ANIMACIONES DE ENTRADA ===== */
   @keyframes fadeInUp {
     from {
       opacity: 0;
       transform: translateY(30px);
     }
     to {
       opacity: 1;
       transform: translateY(0);
     }
   }

   @keyframes slideInLeft {
     from {
       opacity: 0;
       transform: translateX(-50px);
     }
     to {
       opacity: 1;
       transform: translateX(0);
     }
   }

   @keyframes scaleIn {
     from {
       opacity: 0;
       transform: scale(0.9);
     }
     to {
       opacity: 1;
       transform: scale(1);
     }
   }

  .faq-item {
     animation: fadeInUp 0.6s var(--animation-ease) forwards;
     opacity: 0;
   }

   .faq-item:nth-child(1) { animation-delay: 0.9s; }
   .faq-item:nth-child(2) { animation-delay: 1.0s; }
   .faq-item:nth-child(3) { animation-delay: 1.1s; }
   .faq-item:nth-child(4) { animation-delay: 1.2s; }
   .faq-item:nth-child(5) { animation-delay: 1.3s; }
   .faq-item:nth-child(6) { animation-delay: 1.4s; }
   .faq-item:nth-child(7) { animation-delay: 1.5s; }
   .faq-item:nth-child(8) { animation-delay: 1.6s; }
   .faq-item:nth-child(9) { animation-delay: 1.7s; }
</style>
