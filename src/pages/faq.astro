---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import FinalCTA from '../components/FinalCTA.astro';
import MapContact from '../components/MapContact.astro';
import { t, getCurrentLanguage } from '../i18n/index.ts';

const currentLang = getCurrentLanguage();

const mapSrc =
  'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3026.909828347032!2d-111.96001532440677!3d40.6621170713987!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x87528477e6ebc9c9%3A0x7c5f3a11eda255ad!2s2997%20W%204700%20S%2C%20Taylorsville%2C%20UT%2084129!5e0!3m2!1sen!2sus!4v1699999999999';
---

<Layout title={t('faq_page.meta_title', currentLang)}>
  <!-- Hero section -->
  <header class="hero-min">
    <div class="hero-min__bg" aria-hidden="true">
      <img src="/assets/img/NewHero.jpeg" alt="" loading="lazy" decoding="async" style="object-position: center top;" />
      <div class="veil" aria-hidden="true"></div>
    </div>
    <div class="container hero-min__content">
      <h1 data-i18n="faq_page.hero.title">{t('faq_page.hero.title', currentLang)}</h1>
      <p data-i18n="faq_page.hero.subtitle">{t('faq_page.hero.subtitle', currentLang)}</p>
    </div>
  </header>

  <!-- Sección de introducción -->
  <section class="intro-section">
    <div class="container">
      <div class="intro-content">
        <h2 class="section-title" data-i18n="faq_page.intro.title">{t('faq_page.intro.title', currentLang)}</h2>
        <p class="section-description" data-i18n="faq_page.intro.description">{t('faq_page.intro.description', currentLang)}</p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="container">
      <div class="faq-wrapper">
        <div class="faq-item">
          <details class="faq-details">
            <summary class="faq-question">
              <span class="question-text" data-i18n="faq_page.questions.q1.question">{t('faq_page.questions.q1.question', currentLang)}</span>
              <span class="question-icon"></span>
            </summary>
            <div class="faq-answer">
              <div class="answer-content">
                <p data-i18n="faq_page.questions.q1.answer">{t('faq_page.questions.q1.answer', currentLang)}</p>
              </div>
            </div>
          </details>
        </div>

        <div class="faq-item">
          <details class="faq-details">
            <summary class="faq-question">
              <span class="question-text" data-i18n="faq_page.questions.q2.question">{t('faq_page.questions.q2.question', currentLang)}</span>
              <span class="question-icon"></span>
            </summary>
            <div class="faq-answer">
              <div class="answer-content">
                <p data-i18n="faq_page.questions.q2.answer">{t('faq_page.questions.q2.answer', currentLang)}</p>
              </div>
            </div>
          </details>
        </div>

        <div class="faq-item">
          <details class="faq-details">
            <summary class="faq-question">
              <span class="question-text" data-i18n="faq_page.questions.q3.question">{t('faq_page.questions.q3.question', currentLang)}</span>
              <span class="question-icon"></span>
            </summary>
            <div class="faq-answer">
              <div class="answer-content">
                <p data-i18n="faq_page.questions.q3.answer">{t('faq_page.questions.q3.answer', currentLang)}</p>
              </div>
            </div>
          </details>
        </div>

        <div class="faq-item">
          <details class="faq-details">
            <summary class="faq-question">
              <span class="question-text" data-i18n="faq_page.questions.q4.question">{t('faq_page.questions.q4.question', currentLang)}</span>
              <span class="question-icon"></span>
            </summary>
            <div class="faq-answer">
              <div class="answer-content">
                <p data-i18n="faq_page.questions.q4.answer">{t('faq_page.questions.q4.answer', currentLang)}</p>
              </div>
            </div>
          </details>
        </div>

        <div class="faq-item">
          <details class="faq-details">
            <summary class="faq-question">
              <span class="question-text" data-i18n="faq_page.questions.q5.question">{t('faq_page.questions.q5.question', currentLang)}</span>
              <span class="question-icon"></span>
            </summary>
            <div class="faq-answer">
              <div class="answer-content">
                <p data-i18n="faq_page.questions.q5.answer">{t('faq_page.questions.q5.answer', currentLang)}</p>
              </div>
            </div>
          </details>
        </div>

        <div class="faq-item">
          <details class="faq-details">
            <summary class="faq-question">
              <span class="question-text" data-i18n="faq_page.questions.q6.question">{t('faq_page.questions.q6.question', currentLang)}</span>
              <span class="question-icon"></span>
            </summary>
            <div class="faq-answer">
              <div class="answer-content">
                <p data-i18n="faq_page.questions.q6.answer">{t('faq_page.questions.q6.answer', currentLang)}</p>
              </div>
            </div>
          </details>
        </div>

        <div class="faq-item">
          <details class="faq-details">
            <summary class="faq-question">
              <span class="question-text" data-i18n="faq_page.questions.q7.question">{t('faq_page.questions.q7.question', currentLang)}</span>
              <span class="question-icon"></span>
            </summary>
            <div class="faq-answer">
              <div class="answer-content">
                <p data-i18n="faq_page.questions.q7.answer">{t('faq_page.questions.q7.answer', currentLang)}</p>
              </div>
            </div>
          </details>
        </div>

        <div class="faq-item">
          <details class="faq-details">
            <summary class="faq-question">
              <span class="question-text" data-i18n="faq_page.questions.q8.question">{t('faq_page.questions.q8.question', currentLang)}</span>
              <span class="question-icon"></span>
            </summary>
            <div class="faq-answer">
              <div class="answer-content">
                <p data-i18n="faq_page.questions.q8.answer">{t('faq_page.questions.q8.answer', currentLang)}</p>
              </div>
            </div>
          </details>
        </div>

        <div class="faq-item">
          <details class="faq-details">
            <summary class="faq-question">
              <span class="question-text" data-i18n="faq_page.questions.q9.question">{t('faq_page.questions.q9.question', currentLang)}</span>
              <span class="question-icon"></span>
            </summary>
            <div class="faq-answer">
              <div class="answer-content">
                <p data-i18n="faq_page.questions.q9.answer">{t('faq_page.questions.q9.answer', currentLang)}</p>
              </div>
            </div>
          </details>
        </div>
      </div>
    </div>
  </section>

  <FinalCTA />
  
  <div style="margin-top: -2rem;">
    <MapContact />
  </div>

  <Footer />

  <script>
    // Configuración de animaciones escalonadas
    document.addEventListener('DOMContentLoaded', function() {
      // Animaciones de entrada escalonadas para FAQ items
      const faqItems = document.querySelectorAll('.faq-item');
      
      // Configurar observer para animaciones de entrada
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry, index) => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              entry.target.classList.add('aos-animate');
            }, index * 150); // Delay escalonado de 150ms
          }
        });
      }, observerOptions);
      
      // Observar todos los elementos FAQ
      faqItems.forEach(item => {
        observer.observe(item);
      });
      
      // Animaciones para secciones principales
      const sections = document.querySelectorAll('.intro-section, .faq-section');
      sections.forEach((section, index) => {
        setTimeout(() => {
          section.style.opacity = '1';
          section.style.transform = 'translateY(0)';
        }, 300 + (index * 200));
      });
      
      // Mejorar interacción de FAQ con animaciones suaves
      const details = document.querySelectorAll('.faq-details');
      
      details.forEach(detail => {
        const summary = detail.querySelector('.faq-question');
        const content = detail.querySelector('.faq-answer');
        
        summary.addEventListener('click', function(e) {
          e.preventDefault();
          
          // Cerrar otros detalles abiertos con animación
          details.forEach(otherDetail => {
            if (otherDetail !== detail && otherDetail.hasAttribute('open')) {
              const otherContent = otherDetail.querySelector('.faq-answer');
              otherContent.style.maxHeight = '0px';
              setTimeout(() => {
                otherDetail.removeAttribute('open');
              }, 300);
            }
          });
          
          // Toggle el detalle actual con animación suave
          if (detail.hasAttribute('open')) {
            content.style.maxHeight = '0px';
            setTimeout(() => {
              detail.removeAttribute('open');
            }, 400);
          } else {
            detail.setAttribute('open', '');
            // Calcular altura real del contenido
            const contentHeight = content.scrollHeight;
            content.style.maxHeight = contentHeight + 'px';
            
            // Scroll suave hacia el elemento abierto
            setTimeout(() => {
              detail.scrollIntoView({
                behavior: 'smooth',
                block: 'nearest'
              });
            }, 200);
          }
        });
      });
      
      // Animación de parallax sutil para el hero
      const hero = document.querySelector('.hero-section');
      if (hero) {
        window.addEventListener('scroll', () => {
          const scrolled = window.pageYOffset;
          const rate = scrolled * -0.5;
          hero.style.transform = `translateY(${rate}px)`;
        });
      }
    });
  </script>

  <style>
    /* ===== Fuentes ===== */
    @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap');
    
    /* ===== Reset y Variables ===== */
    *, *::before, *::after { box-sizing: border-box; }
    
    :root {
      --page-bg: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
      --p1: #301449;
      --p2: #6b46c1;
      --p3: #8b5cf6;
      --p4: #a78bfa;
      --text-dark: #2a2440;
      --text-light: #6b7280;
      --white: #ffffff;
      --shadow-light: rgba(10, 14, 30, 0.08);
      --shadow-medium: rgba(10, 14, 30, 0.12);
      --shadow-heavy: rgba(10, 14, 30, 0.16);
    }
    
    body {
      margin: 0;
      font-family: 'Manrope', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      line-height: 1.6;
      color: var(--text-dark);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1rem;
    }

    /* ===== Hero Section ===== */
    .hero-min { 
      position: relative;
      color: #fff;
      isolation: isolate;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 300px;
      animation: fadeIn 0.8s ease-out;
    }
    
    .hero-min__bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    
    .hero-min__bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.35;
    }
    
    .hero-min__bg .veil {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(122, 46, 135, 0.3) 0%, rgba(97, 30, 108, 0.2) 50%, rgba(0, 0, 0, 0.1) 100%);
    }
    
    .hero-min__content { 
      position: relative;
      z-index: 1;
      padding: 60px 0;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      animation: slideUp 0.8s ease-out 0.2s both;
    }
    
    .hero-min__content h1 {
      font-weight: 900;
      font-size: 2.2rem;
      margin: 0 0 0.2rem;
    }
    
    .hero-min__content p {
      font-weight: 700;
      margin: 0;
      opacity: 0.96;
    }

    /* ===== Intro Section ===== */
     .intro-section {
       padding: 5rem 0;
       background: var(--white);
       position: relative;
       opacity: 0;
       transform: translateY(30px);
       transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
     }

     .intro-section::before {
       content: '';
       position: absolute;
       top: 0;
       left: 0;
       right: 0;
       height: 1px;
       background: linear-gradient(90deg, transparent, var(--p3), transparent);
     }

     .intro-section::after {
       content: '';
       position: absolute;
       bottom: 0;
       left: 50%;
       transform: translateX(-50%);
       width: 100px;
       height: 2px;
       background: linear-gradient(90deg, var(--p2), var(--p4));
       border-radius: 1px;
     }

    .intro-content {
      text-align: center;
      max-width: 700px;
      margin: 0 auto;
    }

    .section-title {
      font-size: 2.4rem;
      font-weight: 800;
      margin: 0 0 1.5rem;
      color: var(--p1);
      position: relative;
    }

    .section-description {
      font-size: 1.2rem;
      font-weight: 500;
      color: var(--text-light);
      margin: 0;
      line-height: 1.7;
    }

    /* ===== FAQ Section ===== */
     .faq-section {
       padding: 5rem 0;
       background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
       min-height: 100vh;
       opacity: 0;
       transform: translateY(30px);
       transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
       position: relative;
     }



    .faq-wrapper {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      gap: 1.5rem;
    }

    .faq-item {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .faq-item.aos-animate {
      opacity: 1;
      transform: translateY(0);
    }

    .faq-details {
      background: var(--white);
      border-radius: 20px;
      box-shadow: 0 10px 40px var(--shadow-light);
      overflow: hidden;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      border: 1px solid rgba(139, 92, 246, 0.1);
      position: relative;
    }

    .faq-details::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--p2), var(--p3), var(--p4));
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .faq-details:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 60px var(--shadow-medium);
    }

    .faq-details:hover::before {
      opacity: 1;
    }

    .faq-details[open] {
      box-shadow: 0 15px 50px var(--shadow-medium);
    }

    .faq-details[open]::before {
      opacity: 1;
    }

    .faq-question {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 2rem;
      cursor: pointer;
      list-style: none;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--text-dark);
      transition: all 0.3s ease;
      position: relative;
      background: linear-gradient(135deg, 
        rgba(139, 92, 246, 0.02) 0%, 
        rgba(107, 70, 193, 0.02) 100%);
    }

    .faq-question::-webkit-details-marker {
      display: none;
    }

    .faq-question:hover {
      background: linear-gradient(135deg, 
        rgba(139, 92, 246, 0.05) 0%, 
        rgba(107, 70, 193, 0.05) 100%);
    }

    .question-text {
      flex: 1;
      margin-right: 1rem;
      line-height: 1.5;
    }

    .question-icon {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--p2), var(--p3));
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--white);
      font-weight: 900;
      font-size: 1.2rem;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
    }

    .question-icon::before {
      content: '+';
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .faq-details[open] .question-icon {
      background: linear-gradient(135deg, var(--p3), var(--p4));
      transform: rotate(45deg);
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .answer-content {
      padding: 0 2rem 2rem;
      color: var(--text-light);
      font-weight: 500;
      line-height: 1.7;
      border-top: 1px solid rgba(139, 92, 246, 0.1);
    }

    .answer-content p {
      margin: 1.5rem 0 0;
      font-size: 1rem;
    }

    /* ===== Animaciones ===== */
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    
    @keyframes slideUp {
      from { 
        opacity: 0;
        transform: translateY(30px);
      }
      to { 
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ===== Responsividad ===== */
    @media (max-width: 768px) {
      .hero-min {
        min-height: 250px;
      }

      .hero-min__content {
        padding: 40px 0;
      }

      .intro-section {
        padding: 3rem 0;
      }

      .faq-section {
        padding: 3rem 0;
      }

      .faq-question {
        padding: 1.5rem;
        font-size: 1rem;
      }

      .answer-content {
        padding: 0 1.5rem 1.5rem;
      }

      .question-icon {
        width: 28px;
        height: 28px;
        font-size: 1rem;
      }
    }

    @media (max-width: 480px) {
      .faq-question {
        padding: 1.2rem;
      }

      .answer-content {
        padding: 0 1.2rem 1.2rem;
      }

      .question-text {
        margin-right: 0.8rem;
      }
    }


  </style>
</Layout>

<script>
  // Inicialización del cliente i18n para faq.astro
  document.addEventListener('DOMContentLoaded', () => {
    console.log('FAQ: DOMContentLoaded');
    
    // Esperar a que i18n esté listo o inicializarlo
    const initializeI18n = async () => {
      if (window.i18nClient) {
        console.log('FAQ: i18nClient already available');
        window.i18nClient.updateAllTranslations();
      } else {
        console.log('FAQ: Waiting for i18nReady event');
        window.addEventListener('i18nReady', () => {
          console.log('FAQ: i18nReady event received');
          if (window.i18nClient) {
            window.i18nClient.updateAllTranslations();
          }
        });
      }
    };
    
    initializeI18n();
  });
</script>
