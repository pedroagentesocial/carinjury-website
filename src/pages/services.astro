---

<Layout>
  <!-- Hero Section -->
  <HeroServices />
  
  <section class="services-page">

    <div class="services-list">
      {items.map((s, i) => (
        <article id={s.id} class={`service-row ${i % 2 ? 'is-alt' : ''}`}>
          <div class="service-img">
            <img src={s.img} alt={s.title} loading="lazy" decoding="async" />
          </div>
          <div class="service-content">
            <span class="chip" data-i18n="services_page.service_label">{t('services_page.service_label', currentLang)}</span>
            <h2 data-i18n={`services_page.items.${s.id}.title`}>{s.title}</h2>
            <p data-i18n={`services_page.items.${s.id}.description`}>{s.copy}</p>
            <a href={`/schedule?service=${encodeURIComponent(s.title)}`} class="svc-cta" data-i18n="services_page.schedule_evaluation">{t('services_page.schedule_evaluation', currentLang)}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <MapContact />
  <Footer />

</Layout>

<script>
  // Intersection Observer para animaciones al hacer scroll
  document.addEventListener('DOMContentLoaded', function() {
    const serviceRows = document.querySelectorAll('.service-row');
    
    // Configuración del observer
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate');
          // Una vez animado, no necesitamos seguir observando
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);
    
    // Observar todas las cards de servicios
    serviceRows.forEach(row => {
      observer.observe(row);
    });
    
    // Animación adicional para el primer elemento (inmediata)
    if (serviceRows.length > 0) {
      setTimeout(() => {
        serviceRows[0].classList.add('animate');
      }, 100);
    }
  });

  // Inicialización del cliente i18n para cambio dinámico de idioma
  if (typeof window !== 'undefined') {
    import('../utils/i18n-client.js').then((module) => {
      const i18nClient = module.default;
      
      // Inicializar el cliente i18n
      i18nClient.init();
      
      // Escuchar cambios de idioma
      window.addEventListener('languageChange', () => {
        i18nClient.updateAllTranslations();
      });
    });
  }
</script>

<style>
  /* ========= Fuentes + Paleta local ========= */
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@700;800;900&family=Source+Sans+3:wght@400;600;700;800&display=swap');

  :root{
    /* Tipos */
    --font-heading: 'Manrope', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    --font-body: 'Source Sans 3', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;

    /* Paleta que nos pasaste */
    --c-lilac: #CEC6E2; /* claro */
    --c-plum:  #806AAA; /* medio */
    --c-purple:#7A2E87; /* acento oscuro */
    --c-rose:  #BA93C2; /* marca */

    /* Derivados útiles */
    --ink: #1A1D2A;
    --bg: color-mix(in oklab, var(--c-lilac) 40%, #fff);
    --card-bg: #fff;
    --line: rgba(26,29,42,.10);

    --brand-100: color-mix(in oklab, var(--c-lilac) 70%, #fff);
    --brand-300: color-mix(in oklab, var(--c-rose) 65%, #fff);
    --brand-500: var(--c-rose);
    --brand-600: var(--c-plum);
    --brand-700: var(--c-purple);
  }

  /* ========= Página ========= */
  .services-page{
    min-height: 100vh;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    color: var(--ink);
    font-family: var(--font-body);
    margin-bottom: -2rem;
    padding-top: 2rem;
  }

  /* Justificación de textos y márgenes amplios */
  .services-page p,
  .services-page .service-content p,
  .services-page .service-description {
    text-align: justify;
    max-width: 800px;
    margin: 0 auto 1.5rem;
    padding: 0 2rem;
    line-height: 1.7;
  }

  .services-list{
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem 3rem;
    display: grid;
    gap: 1.75rem;
    margin-top: 2rem;
  }

  /* Animaciones para las cards */
  .service-row {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .service-row:nth-child(1) { animation-delay: 0.1s; }
  .service-row:nth-child(2) { animation-delay: 0.2s; }
  .service-row:nth-child(3) { animation-delay: 0.3s; }
  .service-row:nth-child(4) { animation-delay: 0.4s; }
  .service-row:nth-child(5) { animation-delay: 0.5s; }
  .service-row:nth-child(6) { animation-delay: 0.6s; }
  .service-row:nth-child(7) { animation-delay: 0.7s; }
  .service-row:nth-child(8) { animation-delay: 0.8s; }
  .service-row:nth-child(9) { animation-delay: 0.9s; }
  .service-row:nth-child(10) { animation-delay: 1.0s; }
  .service-row:nth-child(11) { animation-delay: 1.1s; }
  .service-row:nth-child(12) { animation-delay: 1.2s; }
  .service-row:nth-child(13) { animation-delay: 1.3s; }
  .service-row:nth-child(14) { animation-delay: 1.4s; }
  .service-row:nth-child(15) { animation-delay: 1.5s; }
  .service-row:nth-child(16) { animation-delay: 1.6s; }

  /* ========= Card con borde sólido y layout alternado ========= */
  .service-row{
    --pad: 2.5rem;
    display: grid;
    grid-template-columns: 480px 1fr;
    gap: 3rem;
    align-items: stretch;
    margin-bottom: 4rem;

    /* Fondo sólido con borde sutil */
    background: #fff;
    border: 1px solid color-mix(in oklab, var(--c-lilac) 60%, #fff);
    border-radius: 16px;
    overflow: clip;
    box-shadow: 0 14px 34px rgba(10,14,30,.10);
    transition: all 0.3s ease;

    scroll-margin-top: 120px;
  }
  .service-row.is-alt{
    grid-template-columns: 1fr 480px;
  }

  /* Imagen con máscara y overlay */
  .service-img{
    position: relative;
    min-height: 260px;
    isolation: isolate;
  }
  .service-row:not(.is-alt) .service-img{ order: 0; }
  .service-row.is-alt .service-img{ order: 1; }

  .service-img img{
    display:block; width:100%; height:100%; object-fit: cover;
    filter: saturate(1.02) contrast(1.02);
    transform: scale(1.02);
  }
  .service-img::after{
    content:"";
    position:absolute; inset:0; z-index:1;
    background: linear-gradient(180deg, rgba(0,0,0,.00), rgba(0,0,0,.12));
    mix-blend-mode: multiply;
  }

  /* Contenido */
  .service-content{
    padding: calc(var(--pad) + 1rem) calc(var(--pad) + .25rem);
    display:flex; flex-direction:column; justify-content:center;
    gap: .65rem;
  }
  .chip{
    align-self:flex-start;
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: .8rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: .28rem .6rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--c-lilac) 70%, #fff);
    color: var(--brand-700);
    border: 1px solid color-mix(in oklab, var(--c-purple) 22%, #fff);
  }
  .service-content h2{
    font-family: var(--font-heading);
    font-size: 1.45rem;
    font-weight: 900;
    color: var(--brand-700);
    margin: .15rem 0 .15rem;
    text-align: justify;
    max-width: 100%;
    padding: 0 1rem;
  }
  .service-content p{
    color:#2b2b2b;
    line-height:1.7;
    font-weight:600;
    max-width: 100%;
    font-size: 1.1rem;
    text-align: justify;
    padding: 0 1rem;
  }

  /* CTA por servicio con fondo sólido */
  .svc-cta{
    align-self:flex-start;
    margin-top: .35rem;
    display:inline-block;
    text-decoration:none;
    white-space:nowrap;

    /* Fondo sólido usando el color púrpura principal */
    background: var(--c-purple);
    color: #fff;

    padding:.66rem 1.05rem;
    border-radius:12px;
    font-family: var(--font-heading);
    font-weight:900;
    letter-spacing:.03em;
    font-size: 1rem;

    border: 1px solid rgba(0,0,0,.05);
    box-shadow: 0 8px 18px rgba(0,0,0,.12);

    position: relative;
    overflow: hidden;
    transition: transform .18s ease, box-shadow .18s ease, background .28s ease;
  }
  .svc-cta::before{
    content:"";
    position:absolute; top:0; left:-70%;
    width:55%; height:100%;
    background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,.55) 50%, transparent 100%);
    transform: skewX(-22deg);
    pointer-events:none;
  }
  .svc-cta:hover{
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(0,0,0,.18);
    background: var(--c-plum);
  }
  .svc-cta:hover::before{ animation: ctaShine .9s forwards; }
  .svc-cta:focus-visible{
    outline: none;
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--c-lilac) 50%, #fff), 0 0 0 6px color-mix(in oklab, var(--c-rose) 45%, transparent);
  }
  @keyframes ctaShine{ to{ left: 125%; } }

  /* Animación fadeInUp para las cards */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Animación para scroll reveal */
  @media (prefers-reduced-motion: no-preference) {
    .service-row {
      animation-play-state: paused;
    }
    
    .service-row.animate {
      animation-play-state: running;
    }
  }

  /* Para usuarios que prefieren menos movimiento */
  @media (prefers-reduced-motion: reduce) {
    .service-row {
      opacity: 1;
      transform: none;
      animation: none;
    }
    
    .service-row:hover {
      transform: none;
    }
    
    .service-img img,
    .chip {
      transition: none;
    }
  }

  /* Hover global: eleva y colorea sutil el borde */
  .service-row:hover{
    transform: translateY(-5px);
    box-shadow: 0 20px 45px rgba(0,0,0,.18);
    border-color: var(--c-rose);
    background: #fff;
  }

  /* Animaciones adicionales para elementos internos */
  .service-img img {
    transition: transform 0.3s ease;
  }

  .service-row:hover .service-img img {
    transform: scale(1.05);
  }

  .chip {
    transition: all 0.3s ease;
  }

  .service-row:hover .chip {
    background: var(--c-purple);
    color: #fff;
    transform: scale(1.05);
  }

  /* ========= Responsive ========= */
  @media (max-width: 1100px){
    .service-row{ grid-template-columns: 420px 1fr; }
    .service-row.is-alt{ grid-template-columns: 1fr 420px; }
  }
  @media (max-width: 980px){
    .service-row,
    .service-row.is-alt{
      grid-template-columns: 1fr;
    }
    .service-img{ max-height: 320px; }
    
    .services-page p,
    .services-page .service-content p,
    .services-page .service-description,
    .service-content h2,
    .service-content p {
      padding: 0 1rem;
      max-width: 100%;
    }

    .services-list {
      padding: 0 1rem 3rem;
    }
  }

  /* ========= Utiles por si no tienes variables globales ========= */
  :root{
    --topbar-h: 0px;
    --navbar-h: 0px;
  }
</style>
