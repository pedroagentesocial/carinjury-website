    img: '/assets/img/rehab.webp',
    copy: t('services_page.items.rehabilitation.description', currentLang)
  },
  {
    id: 'physical_therapy',
    title: t('services_page.items.physical_therapy.title', currentLang),
    img: '/assets/img/phisycal.jpg.webp',
    copy: t('services_page.items.physical_therapy.description', currentLang)
  },
  {
    id: 'hot_cold_therapy',
    title: t('services_page.items.hot_cold_therapy.title', currentLang),
    img: '/assets/img/hotcold.webp',
    copy: t('services_page.items.hot_cold_therapy.description', currentLang)
  },
  {
    id: 'massage',
    title: t('services_page.items.massage.title', currentLang),
    img: '/assets/img/masaje.jpeg',
    copy: t('services_page.items.massage.description', currentLang)
  },
  {
    id: 'ultrasound',
    title: t('services_page.items.ultrasound.title', currentLang),
    img: '/assets/img/ultrasonido.jpeg',
    copy: t('services_page.items.ultrasound.description', currentLang)
  },
  {
    id: 'tens',
    title: t('services_page.items.tens.title', currentLang),
    img: '/assets/img/tens.jpeg',
    copy: t('services_page.items.tens.description', currentLang)
  },
  /* ==== NUEVOS SERVICIOS ==== */
  {
    id: 'second_opinions',
    title: t('services_page.items.second_opinions.title', currentLang),
    img: '/assets/img/second-opinion.jpeg',
    copy: t('services_page.items.second_opinions.description', currentLang)
  },
  {
    id: 'xray',
    title: t('services_page.items.xray.title', currentLang),
    img: '/assets/img/xray.jpg',
    copy: t('services_page.items.xray.description', currentLang)
  },
  {
    id: 'mri',
    title: t('services_page.items.mri.title', currentLang),
    img: '/assets/img/mri.jpg',
    copy: t('services_page.items.mri.description', currentLang)
  },
  {
    id: 'pain_management',
    title: t('services_page.items.pain_management.title', currentLang),
    img: '/assets/img/pain-management.jpeg',
    copy: t('services_page.items.pain_management.description', currentLang)
  },
  {
    id: 'surgical_consultations',
    title: t('services_page.items.surgical_consultations.title', currentLang),
    img: '/assets/img/surgery-consult.jpeg',
    copy: t('services_page.items.surgical_consultations.description', currentLang)
  },
  {
    id: 'concussion',
    title: t('services_page.items.concussion.title', currentLang),
    img: '/assets/img/concussion.jpeg',
