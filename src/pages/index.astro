---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import StatsCounters from '../components/StatsCounters.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import Testimonials from '../components/Testimonials.astro';
import LegalServices from '../components/LegalServices.astro';
import FeatureIcons from '../components/FeatureIcons.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import MapContact from '../components/MapContact.astro';
import AboutVideo from '../components/AboutVideo.astro';
import Form from '../components/Form.astro';
import LegalVideo from '../components/LegalVideo.astro';
import esTranslations from '../i18n/es.json';
import enTranslations from '../i18n/en.json';

---

<Layout>
  <Hero durationsMs=(20000) />
  <FeatureIcons />
  <AboutVideo />
  <Form />
  <LegalVideo />
  <Testimonials />
  <MapContact />
  <Footer />
</Layout>





<script define:vars={{ esTranslations, enTranslations }}>
  if (typeof window !== 'undefined') {
    window.translations = {
      es: esTranslations,
      en: enTranslations
    };
  }
</script>
<script src="/src/utils/i18n-client.js"></script>
<script>
  // Inicialización del cliente i18n para index.astro
  document.addEventListener('DOMContentLoaded', () => {
    console.log('Index: DOMContentLoaded');
    
    // Esperar a que i18n esté listo o inicializarlo
    const initializeI18n = async () => {
      if (window.i18nClient) {
        console.log('Index: i18nClient already available');
        window.i18nClient.init();
      } else {
        console.log('Index: Waiting for i18nReady event');
        window.addEventListener('i18nReady', () => {
          console.log('Index: i18nReady event received');
          if (window.i18nClient) {
            window.i18nClient.init();
          }
        });
      }
    };
    
    initializeI18n();
  });
</script>
