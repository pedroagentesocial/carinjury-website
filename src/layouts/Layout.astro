---
// Layout.astro – plantilla principal limpia
import Nav from '../components/Nav.astro';
import FloatingButtons from '../components/FloatingButtons.astro';
import ScriptJsonLd from '../components/ScriptJsonLd.astro';
import esTranslations from '../i18n/es.json';
import enTranslations from '../i18n/en.json';

const defaultTitle = 'Car Injury Clinic | Chiropractic & Legal Services';
const defaultDescription = 'Somos especialistas en accidentes de auto. Ofrecemos atención quiropráctica y servicios legales para víctimas de accidentes.';
const pageTitle = Astro.props.title ?? defaultTitle;
const pageDescription = Astro.props.description ?? defaultDescription;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=4&t=1760745600" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/Car-Injury-Clinic-White.png" />
    <link rel="shortcut icon" href="/favicon.ico?v=4&t=1760745600" />
    <meta name="theme-color" content="#7A2E87" />

    <!-- Estilos globales -->
    <style is:global>
      @import '../styles/global.css';
    </style>

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Source+Sans+3:wght@400;600&family=Poppins:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-+3rtQyIyTPqf2V1bAliMI/xPyWaT2b8V0IcSCSm7ygyK73Apw63Tuyg9+LRHnjU3HCMYv6GS+JVB3HEUFq2T1g=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    <ScriptJsonLd
      address="3365 S 700 E, Salt Lake City, UT 84106, USA"
      telephone="+1-801-999-8888"
    />
  </head>

  <body>
    <Nav />

    <slot />

    <FloatingButtons />

    <script
      is:inline
      src="https://widgets.leadconnectorhq.com/loader.js"
      data-resources-url="https://widgets.leadconnectorhq.com/chat-widget/loader.js"
      data-widget-id="69cc5bc9af4d3484b4c4f464"
      defer
    ></script>

    <!-- Traducciones globales (única carga) -->
    <script is:inline define:vars={{ translations: { es: esTranslations, en: enTranslations } }}>
      window.translations = translations;
    </script>

    <!-- i18n + utils -->
    <script>
      import '../utils/i18n-client.js';
      import '../utils/testimonials.js';
      import '../utils/dropdown.js';
      import '../utils/animations.js';

      const initI18n = () => {
        if (!window.i18nClient) return;
        window.i18nClient.init();

        const buttonText = document.getElementById('language-button-text');
        const updateBtn = (lang) => {
          if (!buttonText) return;
          buttonText.textContent = lang === 'en' ? 'Spanish' : 'Ingles';
        };
        updateBtn(window.i18nClient.currentLang);
        window.addEventListener('languageChange', (e) => updateBtn(e.detail || window.i18nClient.currentLang));

        const langBtn = document.getElementById('language-toggle');
        if (langBtn && !langBtn.dataset.bound) {
          langBtn.dataset.bound = '1';
          langBtn.addEventListener('click', (e) => {
            e.preventDefault();
            window.i18nClient.toggleLanguage();
          });
        }

        window.dispatchEvent(new CustomEvent('i18nReady'));
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initI18n);
      } else {
        initI18n();
      }
    </script>
  </body>
</html>
